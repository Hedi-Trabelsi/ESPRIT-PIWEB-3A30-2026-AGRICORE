{% extends 'back/base_back.html.twig' %}

{% block content %}
<style>
    .page-title {
        font-weight: 700;
        font-size: 1.5rem;
        margin: 0;
    }
    .card-detail {
        background: #fff;
        border-radius: 12px;
        border: 1px solid #e8e8e8;
        padding: 20px;
        height: 100%;
    }
    .card-title-custom {
        font-size: 1.1rem;
        font-weight: 700;
        color: #1a202c;
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
    .card-title-custom::before {
        content: "";
        width: 6px;
        height: 6px;
        background: #e53e3e;
        border-radius: 50%;
        display: inline-block;
    }
    .card-title-custom.vente::before {
        background: #38a169;
    }
    .empty-state {
        color: #a0aec0;
        font-size: 0.9rem;
    }
    .item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        border-radius: 8px;
        margin-bottom: 10px;
        background: #fff;
        border-left: 4px solid #38a169;
    }
    .item-info {
        display: flex;
        flex-direction: column;
    }
    .item-name {
        font-weight: 700;
        color: #2d3748;
        font-size: 0.95rem;
    }
    .item-meta {
        font-size: 0.8rem;
        color: #a0aec0;
        display: flex;
        align-items: center;
        gap: 5px;
    }
    .item-price {
        font-weight: 700;
        color: #38a169;
        font-size: 1rem;
    }
    .btn-retour {
        background-color: #fff;
        border: 1px solid #e8e8e8;
        color: #198754;
        border-radius: 10px;
        padding: 8px 20px;
        font-weight: 500;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
</style>

<div class="row">
    <div class="col-12 d-flex justify-content-between align-items-center mb-5">
        <div class="d-flex align-items-center gap-4">
            <a href="{{ path('back_ventes_depenses') }}" class="btn-retour mb-0">
                <i class="ti ti-arrow-left"></i> Retour
            </a>
            <h1 class="page-title">Détails de l'Utilisateur : {{ user.nom }} {{ user.prenom }}</h1>
        </div>
    </div>

    <div class="row">
        <!-- Dépenses Column -->
        <div class="col-md-6">
            <div class="card-detail">
                <h3 class="card-title-custom">Dépenses</h3>
                {% if depenses is empty %}
                    <p class="empty-state">Aucune dépense enregistrée.</p>
                {% else %}
                    {% for depense in depenses %}
                        <div class="item-row" style="border-left-color: #e53e3e;">
                            <div class="item-info">
                                <span class="item-name">{{ depense.type }}</span>
                                <span class="item-meta">
                                    <i class="ti ti-calendar"></i> {{ depense.date|date('Y-m-d') }}
                                </span>
                            </div>
                            <div class="item-price" style="color: #e53e3e;">
                                - {{ depense.montant|number_format(2, '.', '') }} DT
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>

        <!-- Ventes Column -->
        <div class="col-md-6">
            <div class="card-detail">
                <h3 class="card-title-custom vente">Ventes</h3>
                {% if ventes is empty %}
                    <p class="empty-state">Aucune vente enregistrée.</p>
                {% else %}
                    {% for vente in ventes %}
                        <div class="item-row">
                            <div class="item-info">
                                <div class="d-flex align-items-center gap-2">
                                    <span class="item-name">{{ vente.produit }}</span>
                                    <span class="badge bg-success-subtle text-success small px-2">{{ vente.prixUnitaire|number_format(2, '.', '') }} × {{ vente.quantite }} u.</span>
                                </div>
                                <span class="item-meta">
                                    <i class="ti ti-calendar"></i> {{ vente.date|date('Y-m-d') }}
                                </span>
                            </div>
                            <div class="item-price">
                                + {{ vente.chiffreAffaires|number_format(2, '.', '') }} DT
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
