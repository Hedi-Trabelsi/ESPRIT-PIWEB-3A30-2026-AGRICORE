{% extends 'back/base_back.html.twig' %}
{% block title %}Admin – Suivis Animaux{% endblock %}
{% block content %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
    :root { --agri-green:#2d6a4f; --agri-dark:#061a14; }
    .page-header { background:#fff; border-radius:16px; padding:24px 32px; margin-bottom:24px; border:1px solid #e8f0eb; display:flex; justify-content:space-between; align-items:center; }
    .control-bar { background:#fff; border-radius:14px; padding:16px 24px; margin-bottom:24px; border:1px solid #e8f0eb; display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .table-card { background:#fff; border-radius:16px; border:1px solid #e8f0eb; overflow:hidden; }
    .table thead th { background:#f8faf9; color:#374151; font-weight:600; font-size:.78rem; text-transform:uppercase; letter-spacing:.05em; border-bottom:2px solid #e8f0eb; padding:12px 14px; }
    .table tbody td { padding:12px 14px; vertical-align:middle; border-bottom:1px solid #f3f4f6; font-size:.88rem; }
    .table tbody tr:hover { background:#f8faf9; }
    .sort-link { color:inherit; text-decoration:none; display:flex; align-items:center; gap:4px; }
    .sort-link:hover { color:var(--agri-green); }
    .btn-agri { background:var(--agri-green); color:#fff; border:none; border-radius:8px; padding:8px 18px; font-weight:600; font-size:.85rem; }
    .btn-agri:hover { background:#1e4d38; color:#fff; }
    .search-box, .select-sort { border:1px solid #d1d5db; border-radius:8px; padding:8px 12px; font-size:.85rem; }
    .search-box { min-width:200px; }
    .search-box:focus, .select-sort:focus { outline:none; border-color:var(--agri-green); box-shadow:0 0 0 3px rgba(45,106,79,.1); }
    .action-btn { width:30px; height:30px; border-radius:7px; display:inline-flex; align-items:center; justify-content:center; border:none; cursor:pointer; transition:.2s; }
    .btn-view { background:#eff6ff; color:#2563eb; }
    .btn-edit { background:#f0fdf4; color:#16a34a; }
    .btn-del  { background:#fef2f2; color:#dc2626; }
    .action-btn:hover { filter:brightness(.9); transform:scale(1.08); }
    .badge-etat { padding:3px 10px; border-radius:50px; font-size:.73rem; font-weight:600; }
    .etat-bon     { background:#dcfce7; color:#16a34a; }
    .etat-moyen   { background:#fef9c3; color:#ca8a04; }
    .etat-mauvais { background:#fee2e2; color:#dc2626; }
    .empty-state { text-align:center; padding:60px 20px; color:#9ca3af; }
</style>

<div class="container-fluid py-4">

    {% for msg in app.flashes('success') %}
        <div class="alert alert-success rounded-3 mb-3">{{ msg }}</div>
    {% endfor %}

    <div class="page-header">
        <div>
            <h4 class="fw-bold mb-1" style="color:var(--agri-dark)"><i class="fas fa-heartbeat me-2" style="color:var(--agri-green)"></i>Suivis Animaux</h4>
            <p class="text-muted mb-0 small">{{ suivis|length }} suivi(s) au total</p>
        </div>
        <a href="{{ path('back_suivi_new') }}" class="btn btn-agri">
            <i class="fas fa-plus me-2"></i>Ajouter un suivi
        </a>
    </div>

    <form method="get" action="{{ path('back_suivis') }}">
        <div class="control-bar">
            <input type="text" name="q" value="{{ q }}" placeholder="Rechercher (code animal, état…)" class="search-box">
            <select name="etat" class="select-sort">
                <option value="">Tous les états</option>
                <option value="Bon"     {% if filterEtat == 'Bon'     %}selected{% endif %}>Bon</option>
                <option value="Moyen"   {% if filterEtat == 'Moyen'   %}selected{% endif %}>Moyen</option>
                <option value="Mauvais" {% if filterEtat == 'Mauvais' %}selected{% endif %}>Mauvais</option>
            </select>
            <select name="activite" class="select-sort">
                <option value="">Toutes les activités</option>
                <option value="Faible" {% if filterActivite == 'Faible' %}selected{% endif %}>Faible</option>
                <option value="Modéré" {% if filterActivite == 'Modéré' %}selected{% endif %}>Modéré</option>
                <option value="Élevé"  {% if filterActivite == 'Élevé'  %}selected{% endif %}>Élevé</option>
            </select>
            <select name="sortBy" class="select-sort">
                <option value="dateSuivi"      {% if sortBy == 'dateSuivi'      %}selected{% endif %}>Trier par Date</option>
                <option value="temperature"    {% if sortBy == 'temperature'    %}selected{% endif %}>Trier par Temp.</option>
                <option value="poids"          {% if sortBy == 'poids'          %}selected{% endif %}>Trier par Poids</option>
                <option value="rythmeCardiaque"{% if sortBy == 'rythmeCardiaque'%}selected{% endif %}>Trier par Rythme</option>
                <option value="etatSante"      {% if sortBy == 'etatSante'      %}selected{% endif %}>Trier par État</option>
                <option value="niveauActivite" {% if sortBy == 'niveauActivite' %}selected{% endif %}>Trier par Activité</option>
            </select>
            <select name="order" class="select-sort">
                <option value="DESC" {% if order == 'DESC' %}selected{% endif %}>Décroissant</option>
                <option value="ASC"  {% if order == 'ASC'  %}selected{% endif %}>Croissant</option>
            </select>
            <button type="submit" class="btn btn-agri"><i class="fas fa-search me-1"></i>Filtrer</button>
            {% if q or filterEtat or filterActivite %}
                <a href="{{ path('back_suivis') }}" class="btn btn-outline-secondary rounded-3" style="font-size:.85rem">Réinitialiser</a>
            {% endif %}
        </div>
    </form>

    <div class="table-card">
        {% if suivis is empty %}
            <div class="empty-state">
                <i class="fas fa-heartbeat fa-3x mb-3" style="color:#d1d5db"></i>
                <p class="fw-semibold">Aucun suivi trouvé</p>
            </div>
        {% else %}
        <table class="table mb-0">
            <thead>
                <tr>
                    <th>Animal</th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'dateSuivi', order: sortBy=='dateSuivi' and order=='DESC' ? 'ASC' : 'DESC'}) }}" class="sort-link">Date <i class="fas fa-sort fa-xs"></i></a></th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'temperature', order: sortBy=='temperature' and order=='ASC' ? 'DESC' : 'ASC'}) }}" class="sort-link">Temp. <i class="fas fa-sort fa-xs"></i></a></th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'poids', order: sortBy=='poids' and order=='ASC' ? 'DESC' : 'ASC'}) }}" class="sort-link">Poids <i class="fas fa-sort fa-xs"></i></a></th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'rythmeCardiaque', order: sortBy=='rythmeCardiaque' and order=='ASC' ? 'DESC' : 'ASC'}) }}" class="sort-link">Rythme <i class="fas fa-sort fa-xs"></i></a></th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'niveauActivite', order: sortBy=='niveauActivite' and order=='ASC' ? 'DESC' : 'ASC'}) }}" class="sort-link">Activité <i class="fas fa-sort fa-xs"></i></a></th>
                    <th><a href="{{ path('back_suivis', {q:q, etat:filterEtat, activite:filterActivite, sortBy:'etatSante', order: sortBy=='etatSante' and order=='ASC' ? 'DESC' : 'ASC'}) }}" class="sort-link">État <i class="fas fa-sort fa-xs"></i></a></th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% for s in suivis %}
                <tr>
                    <td><span class="fw-semibold">{{ s.animal ? s.animal.codeAnimal : '—' }}</span></td>
                    <td>{{ s.dateSuivi|date('d/m/Y H:i') }}</td>
                    <td>{{ s.temperature }}°C</td>
                    <td>{{ s.poids }} kg</td>
                    <td>{{ s.rythmeCardiaque }} bpm</td>
                    <td>{{ s.niveauActivite }}</td>
                    <td>
                        <span class="badge-etat etat-{{ s.etatSante|lower }}">{{ s.etatSante }}</span>
                    </td>
                    <td class="text-center">
                        <a href="{{ path('back_suivi_show', {id: s.idSuivi}) }}" class="action-btn btn-view" title="Voir"><i class="fas fa-eye fa-xs"></i></a>
                        <a href="{{ path('back_suivi_edit', {id: s.idSuivi}) }}" class="action-btn btn-edit" title="Modifier"><i class="fas fa-pen fa-xs"></i></a>
                        <form method="post" action="{{ path('back_suivi_delete', {id: s.idSuivi}) }}" style="display:inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete'~s.idSuivi) }}">
                            <button type="submit" class="action-btn btn-del" title="Supprimer"><i class="fas fa-trash fa-xs"></i></button>
                        </form>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>
</div>
{% endblock %}
