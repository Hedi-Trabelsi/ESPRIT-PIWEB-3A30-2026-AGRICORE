{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

<style>
    :root {
        --agri-dark: #061a14;
        --agri-green: #2d6a4f;
        --glass-bg: rgba(255, 255, 255, 0.9);
        --glass-border: rgba(255, 255, 255, 0.7);

        /* Palette AgriCore */
        --color-formation: #0077b6;
        --color-tech: #8b5cf6;
        --color-recolte: #2d6a4f;
        --color-default: #10b981;
        --color-rose: #f06292;
        --color-past-red: rgba(239, 68, 68, 0.12); /* Rouge transparent */
    }

    body { background: #f0f4f3; font-family: 'Plus Jakarta Sans', sans-serif; color: var(--agri-dark); }

    /* --- Animations Staggered --- */
    .event-item { transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1); }
    .hidden-card { opacity: 0; transform: translateY(40px) scale(0.8); pointer-events: none; display: none !important; }
    .visible-card { opacity: 1; transform: translateY(0) scale(1); display: block; }

    /* --- Design des Cartes --- */
    .event-card {
        border-radius: 25px;
        overflow: hidden;
        transition: all 0.4s ease;
        height: 100%;
        position: relative;
        background: white;
        border: 1px solid var(--glass-border);
        box-shadow: 0 10px 20px rgba(0,0,0,0.02);
    }
    .event-card:hover { transform: translateY(-12px); box-shadow: 0 25px 50px rgba(0,0,0,0.1); }

    /* État Passé : Rouge Transparent */
    .card-past {
        background: var(--color-past-red) !important;
        border: 1px dashed rgba(239, 68, 68, 0.3) !important;
        backdrop-filter: blur(4px);
    }
    .card-past .icon-wrapper { color: #dc2626 !important; opacity: 0.6; }
    .card-past h6 { color: #991b1b; }

    /* État En Cours */
    .card-now { border: 2px solid var(--color-default) !important; box-shadow: 0 0 25px rgba(16, 185, 129, 0.2) !important; }

    /* Zone Visuelle */
    .visual-zone { height: 150px; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
    .visual-zone img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }
    .icon-wrapper { transition: 0.6s; font-size: 3.8rem; filter: drop-shadow(0 8px 15px rgba(0,0,0,0.1)); position: relative; z-index: 1; }
    .event-card:hover .icon-wrapper { transform: scale(1.2) rotate(8deg); }
    .visual-zone .badge { z-index: 3; }

    .icon-formation { color: var(--color-formation); }
    .icon-tech { color: var(--color-tech); }
    .icon-recolte { color: var(--color-recolte); }
    .icon-default { color: var(--color-default); }

    /* Actions Slide-up */
    .action-shelf {
        position: absolute; bottom: 0; left: 0; width: 100%;
        background: rgba(255,255,255,0.95); padding: 15px;
        display: flex; justify-content: center; gap: 15px;
        transform: translateY(100%); transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        backdrop-filter: blur(8px); border-top: 1px solid rgba(0,0,0,0.05);
    }
    .event-card:hover .action-shelf { transform: translateY(0); }

    .circle-btn {
        width: 45px; height: 45px; border-radius: 50%;
        display: flex; align-items: center; justify-content: center;
        background: white; border: 1px solid #edf2f7; transition: 0.3s; color: inherit; text-decoration: none;
    }
    .circle-btn:hover { transform: scale(1.15); background: #f8fafc; box-shadow: 0 5px 15px rgba(0,0,0,0.08); }

    /* Layout Components */
    .premium-header {
        background: var(--glass-bg); backdrop-filter: blur(15px); border-radius: 25px;
        padding: 30px 45px; margin-bottom: 25px; border: 1px solid var(--glass-border);
        display: flex; justify-content: space-between; align-items: center;
    }
    .control-panel {
        background: var(--glass-bg); border-radius: 20px; padding: 20px 35px;
        margin-bottom: 35px; border: 1px solid var(--glass-border);
    }
    .filter-pill { border-radius: 50px; font-weight: 700; padding: 10px 24px; transition: 0.3s; border: 1px solid transparent; }
    .filter-pill.active { background: var(--agri-dark) !important; color: white !important; }

    /* Modal Logs */
    .modal-content { border-radius: 35px; border: none; overflow: hidden; }
    .log-item { padding: 18px 25px; display: flex; align-items: center; gap: 15px; border-bottom: 1px solid #f1f5f9; }
    .log-icon-box { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .log-create { background: #dcfce7; color: #16a34a; }
    .log-update { background: #fef9c3; color: #ca8a04; }
    .log-delete { background: #fee2e2; color: #dc2626; }
</style>

<div class="container-fluid py-4 px-lg-5">

    <div class="premium-header animate__animated animate__fadeIn shadow-sm">
        <div>
            <h2 class="fw-bold mb-0">AgriCore <span style="color: var(--color-default);">Events</span></h2>
            <p class="text-muted small mb-0"><i class="fas fa-leaf me-2 text-success"></i>Gestionnaire d'événements intelligent</p>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-dark rounded-pill px-4 fw-bold shadow-sm" data-bs-toggle="modal" data-bs-target="#logsModal">
                <i class="fas fa-history me-2 text-primary"></i> Activités
            </button>
            <a href="{{ path('back_evenements_add') }}" class="btn btn-dark rounded-pill px-4 fw-bold shadow-sm">
                <i class="fas fa-plus-circle me-2"></i> Ajouter
            </a>
        </div>
    </div>

    <div class="control-panel shadow-sm">
        <div class="row g-3 align-items-center">
            <div class="col-md-4">
                <div class="input-group bg-white rounded-pill px-3 shadow-sm" style="border: 1px solid #e2e8f0;">
                    <span class="input-group-text bg-transparent border-0 text-muted"><i class="fas fa-search"></i></span>
                    <input type="text" id="liveSearch" class="form-control border-0 shadow-none" placeholder="Rechercher...">
                </div>
            </div>
            <div class="col-md-8 text-end">
                <button class="filter-pill btn active" data-filter="TOUT">Tous</button>
                <button class="filter-pill btn" data-filter="EN_COURS">Maintenant</button>
                <button class="filter-pill btn" data-filter="COMING">À venir</button>
                <button class="filter-pill btn" data-filter="HISTORIQUE">Archives</button>
            </div>
        </div>
    </div>

    <div class="row g-4" id="eventsGrid">
    
        {% set now_date = "now"|date('Y-m-d') %}

        {# On crée 3 listes séparées pour forcer l'ordre d'affichage #}
        {% set list_now = [] %}
        {% set list_future = [] %}
        {% set list_past = [] %}

        {% for ev in evenements %}
            {% set start = ev.date_debut|date('Y-m-d') %}
            {% set end = ev.date_fin|date('Y-m-d') %}

            {% if now_date >= start and now_date <= end %}
                {% set list_now = list_now|merge([ev]) %}
            {% elseif now_date < start %}
                {% set list_future = list_future|merge([ev]) %}
            {% else %}
                {% set list_past = list_past|merge([ev]) %}
            {% endif %}
        {% endfor %}

        {# Fusion des listes dans l'ordre demandé #}
        {% set sorted_events = list_now|merge(list_future)|merge(list_past) %}

        {% for ev in sorted_events %}
            {% set start = ev.date_debut|date('Y-m-d') %}
            {% set end = ev.date_fin|date('Y-m-d') %}

            {% set status = 'COMING' %}{% set card_class = 'card-future' %}
            {% if now_date >= start and now_date <= end %}{% set status = 'EN_COURS' %}{% set card_class = 'card-now' %}
            {% elseif now_date > end %}{% set status = 'HISTORIQUE' %}{% set card_class = 'card-past' %}{% endif %}

            {# Icône Contextuelle #}
            {% set t = ev.titre|lower %}
            {% set icon = 'fa-seedling' %}{% set col = 'icon-default' %}
            {% if 'formation' in t or 'cours' in t %}{% set icon = 'fa-graduation-cap' %}{% set col = 'icon-formation' %}
            {% elseif 'tech' in t or 'système' in t %}{% set icon = 'fa-microchip' %}{% set col = 'icon-tech' %}
            {% elseif 'récolte' in t or 'moisson' in t %}{% set icon = 'fa-wheat-awn' %}{% set col = 'icon-recolte' %}{% endif %}

            <div class="col-xl-3 col-lg-4 col-md-6 event-item visible-card"
                 data-title="{{ t }}"
                 data-status="{{ status }}"
                 data-coords="{{ ev.lieu }}">

                <div class="event-card {{ card_class }}">
                    <div class="visual-zone">
                        <span class="badge rounded-pill position-absolute shadow-sm"
                              style="top:15px; left:15px; font-size:0.65rem; padding: 6px 12px; z-index:2;
                              {% if status == 'HISTORIQUE' %}background:#dc2626;{% elseif status == 'EN_COURS' %}background:var(--color-default);{% else %}background:var(--agri-dark);{% endif %} color:white;">
                            {{ status|replace({'_': ' '}) }}
                        </span>
                        {% if ev.image %}
                            <img src="{{ ev.image|raw }}" alt="{{ ev.titre }}">
                        {% else %}
                            <div class="icon-wrapper {{ col }}"><i class="fas {{ icon }}"></i></div>
                        {% endif %}
                    </div>

                    <div class="p-4 text-center">
                        <h6 class="fw-bold mb-1 text-truncate">{{ ev.titre }}</h6>
                        <div class="small fw-bold mb-3" style="color: var(--color-rose);">{{ ev.frais_inscription }} DT</div>
                        <div class="d-flex justify-content-between text-muted" style="font-size: 0.7rem;">
                            <span><i class="far fa-calendar-alt me-1"></i> {{ start }}</span>
                            <span class="loc-display"><i class="fas fa-spinner fa-spin me-1"></i></span>
                        </div>
                    </div>

                    <div class="action-shelf">
                        <a href="{{ path('back_evenements_show', {id: ev.id_ev}) }}" class="circle-btn" title="Voir"><i class="fas fa-eye text-dark"></i></a>

                        {# Verrouillage Édition si passé #}
                        {% if status != 'HISTORIQUE' %}
                            <a href="{{ path('back_evenements_edit', {id: ev.id_ev}) }}" class="circle-btn" title="Modifier"><i class="fas fa-pen text-primary"></i></a>
                        {% else %}
                            <div class="circle-btn" style="opacity: 0.5; cursor: not-allowed;" title="Verrouillé"><i class="fas fa-lock text-danger"></i></div>
                        {% endif %}

<a href="{{ path('back_evenements_delete', {id: ev.id_ev}) }}"
   class="circle-btn">
    <i class="fas fa-trash text-danger"></i>
</a>                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<div class="modal fade" id="logsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content shadow-lg">
            <div class="modal-header border-0 bg-dark text-white p-4">
                <h5 class="modal-title fw-bold"><i class="fas fa-history me-2 text-success"></i> Journal d'activités</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="max-height: 450px; overflow-y: auto;">
                {% if action_logs is empty %}
                    <div class="text-center py-5 text-muted">
                        <i class="fas fa-history fa-2x mb-3 opacity-25"></i>
                        <p class="small fw-bold">Aucune activité enregistrée</p>
                    </div>
                {% else %}
                {% for log in action_logs %}
                    {% set act = log.getAction_type()|lower %}
                    <div class="log-item">
                        <div class="log-icon-box {% if 'create' in act %}log-create{% elseif 'update' in act %}log-update{% elseif 'delete' in act %}log-delete{% else %}bg-light{% endif %}">
                            <i class="fas {% if 'create' in act %}fa-plus{% elseif 'update' in act %}fa-pen{% elseif 'delete' in act %}fa-trash-alt{% else %}fa-info{% endif %}"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold small mb-0 text-dark">{{ log.getDescription() }}</div>
                            {% if 'update' in act %}
                                {% set old_data = log.getOld_value()|replace({'{"titre":"': '', '"}': ''}) %}
                                {% set new_data = log.getNew_value()|replace({'{"titre":"': '', '"}': ''}) %}
                                {% if old_data != new_data %}
                                <div class="text-muted" style="font-size: 0.65rem;">
                                    <span class="text-danger text-decoration-line-through">{{ old_data }}</span>
                                    <i class="fas fa-arrow-right mx-1"></i>
                                    <span class="text-success">{{ new_data }}</span>
                                </div>
                                {% endif %}
                            {% endif %}
                            <div class="text-muted" style="font-size: 0.65rem;">{{ log.getCreated_at()|date('d/m/Y H:i') }}</div>
                        </div>
                        <span class="badge rounded-pill {% if 'create' in act %}bg-success{% elseif 'update' in act %}bg-warning text-dark{% elseif 'delete' in act %}bg-danger{% else %}bg-secondary{% endif %}" style="font-size: 0.6rem;">{{ act|upper }}</span>
                    </div>
                {% endfor %}
                {% endif %}
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const items = document.querySelectorAll('.event-item');

    // --- Nominatim Reverse Geocoding ---
    items.forEach(item => {
        const coords = item.dataset.coords;
        const locBox = item.querySelector('.loc-display');
        if (coords.match(/^-?\d+(\.\d+)?,\s*-?\d+(\.\d+)?$/)) {
            const [lat, lon] = coords.split(',').map(c => c.trim());
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`)
                .then(r => r.json()).then(data => {
                    const place = data.address.city || data.address.town || data.address.village || "Secteur AgriCore";
                    locBox.innerHTML = `<i class="fas fa-map-marker-alt me-1"></i> ${place}`;
                }).catch(() => { locBox.innerHTML = `<i class="fas fa-map-marker-alt me-1"></i> Zone Rurale`; });
        } else {
            locBox.innerHTML = `<i class="fas fa-map-marker-alt me-1"></i> ${coords}`;
        }
    });

    // --- Filtrage & Animation ---
    const search = document.getElementById('liveSearch');
    const pills = document.querySelectorAll('.filter-pill');

    function updateGrid() {
        const q = search.value.toLowerCase();
        const f = document.querySelector('.filter-pill.active').dataset.filter;
        let idx = 0;
        items.forEach(el => {
            const mS = el.dataset.title.includes(q);
            const mF = (f === 'TOUT' || el.dataset.status === f);
            if (mS && mF) {
                el.classList.remove('hidden-card');
                setTimeout(() => el.classList.add('visible-card'), 50);
                el.style.transitionDelay = `${idx * 60}ms`;
                idx++;
            } else {
                el.classList.remove('visible-card');
                el.classList.add('hidden-card');
                el.style.transitionDelay = '0ms';
            }
        });
    }

    search.addEventListener('input', updateGrid);
    pills.forEach(p => p.addEventListener('click', () => {
        pills.forEach(b => b.classList.remove('active'));
        p.classList.add('active');
        updateGrid();
    }));
});
</script>
{% endblock %}