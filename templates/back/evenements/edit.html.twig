{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    :root {
        --agri-dark: #061a14;
        --agri-green: #10b981;
        --agri-soft-green: #ecfdf5;
        --glass-bg: rgba(255, 255, 255, 0.95);
        --error-red: #ef4444;
    }

    body {
        background: linear-gradient(135deg, #f0f9f4 0%, #e8f5e9 100%);
        background-attachment: fixed;
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: var(--agri-dark);
    }

    .main-card {
        background: var(--glass-bg);
        backdrop-filter: blur(12px);
        border-radius: 35px;
        border: 1px solid rgba(255, 255, 255, 1);
        box-shadow: 0 25px 60px rgba(0,0,0,0.05);
        overflow: hidden;
        margin-bottom: 50px;
    }

    .header-section {
        background: white;
        padding: 40px;
        border-bottom: 1px solid #f1f5f9;
    }

    /* --- Form Styling --- */
    .form-label {
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #64748b;
        margin-bottom: 8px;
    }

    .custom-input {
        border-radius: 15px;
        padding: 12px 18px;
        border: 1px solid #e2e8f0;
        background: #f8fafc;
        transition: all 0.3s;
    }

    .custom-input:focus {
        border-color: var(--agri-green);
        box-shadow: 0 0 0 4px rgba(16, 185, 129, 0.1);
        background: white;
    }

    /* --- Validation Styles --- */
    .was-validated .custom-input:invalid {
        border-color: var(--error-red) !important;
        background-image: none; /* Removes default browser icon */
    }

    .error-text {
        color: var(--error-red);
        font-size: 0.75rem;
        font-weight: 600;
        margin-top: 5px;
        display: none;
    }

    .was-validated :invalid ~ .error-text {
        display: block;
    }

    /* --- Map Style --- */
    #map-container {
        position: relative;
        border-radius: 28px;
        border: 8px solid white;
        box-shadow: 0 15px 40px rgba(0,0,0,0.08);
    }

    #map {
        height: 500px;
        width: 100%;
        cursor: crosshair;
        border-radius: 22px;
    }

    .btn-save {
        background: var(--agri-green);
        color: white;
        border: none;
        padding: 15px 35px;
        border-radius: 18px;
        font-weight: 800;
        transition: 0.3s;
    }

    .btn-save:hover {
        background: #059669;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.3);
    }
</style>

<div class="container py-5">
    <div class="main-card animate__animated animate__fadeIn">

        <div class="header-section">
            <div class="row align-items-center">
                <div class="col">
                    <h1 class="fw-bold mb-1" style="letter-spacing: -1.5px;">Modifier l'événement</h1>
                    <p class="text-muted mb-0">Édition des détails pour <strong>{{ event.titre }}</strong></p>
                </div>
                <div class="col-auto">
                    <a href="{{ path('back_evenements_list') }}" class="btn btn-light rounded-pill px-4">
                        <i class="bi bi-arrow-left me-2"></i>Retour
                    </a>
                </div>
            </div>
        </div>

        {{ form_start(form, {'attr': {'class': 'p-4 p-md-5', 'novalidate': 'novalidate', 'id': 'eventForm'}}) }}

            <div class="row g-5">

                <div class="col-lg-5">
                    <div class="mb-4">
                        {{ form_label(form.titre, 'Titre de l\'événement') }}
                        {{ form_widget(form.titre, {'attr': {'class': 'form-control custom-input'}}) }}
                        <div class="text-danger small">{{ form_errors(form.titre) }}</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            {{ form_label(form.capacite_max, 'Capacité Max') }}
                            {{ form_widget(form.capacite_max, {'attr': {'class': 'form-control custom-input', 'min': '1'}}) }}
                            <div class="text-danger small">{{ form_errors(form.capacite_max) }}</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.description) }}
                        <div style="position:relative;">
                            {{ form_widget(form.description, {'attr': {'class': 'form-control custom-input', 'rows': '4'}}) }}
                            <button type="button" id="aiGenBtn"
                                style="position:absolute;top:10px;right:10px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:10px;padding:6px 14px;font-size:.78rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;z-index:5;">
                                <i class="fas fa-magic"></i> Générer avec IA
                            </button>
                        </div>
                        <div id="aiStatus" style="font-size:.78rem;margin-top:6px;display:none;"></div>
                        <div class="text-danger small">{{ form_errors(form.description) }}</div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-md-6">
                            {{ form_label(form.date_debut, 'Début') }}
                            {{ form_widget(form.date_debut, {'attr': {'class': 'form-control custom-input'}}) }}
                            <div class="text-danger small">{{ form_errors(form.date_debut) }}</div>
                        </div>
                        <div class="col-md-6">
                            {{ form_label(form.date_fin, 'Fin') }}
                            {{ form_widget(form.date_fin, {'attr': {'class': 'form-control custom-input'}}) }}
                            <div class="text-danger small">{{ form_errors(form.date_fin) }}</div>
                        </div>
                    </div>

                    <div class="mb-4">
                        {{ form_label(form.frais_inscription, 'Frais (TND)') }}
                        {{ form_widget(form.frais_inscription, {'attr': {'class': 'form-control custom-input', 'min': '0', 'step': '0.01'}}) }}
                        <div class="text-danger small">{{ form_errors(form.frais_inscription) }}</div>
                    </div>

                    <div class="pt-4 border-top d-flex flex-column gap-3">
                        <button type="button" id="posterBtn"
                            style="background:linear-gradient(135deg,#f97316,#fb923c);color:#fff;border:none;border-radius:16px;padding:13px;font-weight:800;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;width:100%;">
                            <i class="fas fa-image"></i> Générer l'affiche IA
                        </button>
                        <button type="submit" class="btn btn-save w-100 shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i> Mettre à jour l'événement
                        </button>
                    </div>
                </div>

                <div class="col-lg-7">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        {{ form_label(form.lieu, 'Localisation (Tapez sur la carte)') }}
                    </div>

                    {{ form_widget(form.lieu, {'attr': {'id': 'lieu_input', 'style': 'display: none;'}}) }}

                    <div id="map-container">
                        <div id="map"></div>
                    </div>

                    <div class="mt-3 p-3 bg-white rounded-4 border d-flex align-items-center justify-content-between shadow-sm">
                        <div>
                            <small class="text-muted d-block fw-bold small uppercase">Coordonnées :</small>
                            <span id="display_coords" class="fw-bold text-primary">{{ event.lieu }}</span>
                        </div>
                        <button type="button" class="btn btn-sm btn-outline-dark rounded-pill" onclick="resetMap()">
                            <i class="bi bi-arrow-counterclockwise"></i> Reset
                        </button>
                    </div>
                    <div class="text-danger small mt-2">{{ form_errors(form.lieu) }}</div>
                </div>
            </div>

        {{ form_end(form) }}
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const lieuInput = document.getElementById('{{ form.lieu.vars.id }}');
        const displayCoords = document.getElementById('display_coords');

        // ── Map Setup ─────────────────────────────────────────────────
        const lieuVal = lieuInput.value.trim();
        const coordRegex = /^\(?\s*(-?\d+\.?\d*)\s*,\s*(-?\d+\.?\d*)\s*\)?$/;
        const coordMatch = lieuVal.match(coordRegex);

        const map = L.map('map', { zoomControl: false }).setView([36.8065, 10.1815], 6);
        L.control.zoom({ position: 'bottomright' }).addTo(map);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors',
            maxZoom: 19
        }).addTo(map);
        let marker = L.marker([36.8065, 10.1815], { draggable: true }).addTo(map);

        function updateLocation(lat, lng) {
            const formatted = `(${lat.toFixed(6)}, ${lng.toFixed(6)})`;
            lieuInput.value = formatted;
            displayCoords.innerText = 'Chargement...';
            marker.setLatLng([lat, lng]);

            // Reverse geocoding pour afficher le nom du lieu
            fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lng}&accept-language=fr`)
                .then(r => r.json())
                .then(data => {
                    const placeName = data.display_name || formatted;
                    displayCoords.innerText = placeName;
                    lieuInput.value = placeName;
                })
                .catch(() => { displayCoords.innerText = formatted; });
        }

        function initMapAt(lat, lng) {
            map.setView([lat, lng], 13);
            marker.setLatLng([lat, lng]);
        }

        // Si coordonnées directes
        if (coordMatch) {
            const lat = parseFloat(coordMatch[1]);
            const lng = parseFloat(coordMatch[2]);
            if (!isNaN(lat) && !isNaN(lng)) {
                initMapAt(lat, lng);
            }
        } else if (lieuVal.length > 2) {
            // Géocoder le nom de lieu via Nominatim
            fetch('https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(lieuVal) + '&limit=1')
                .then(r => r.json())
                .then(data => {
                    if (data.length > 0) {
                        const lat = parseFloat(data[0].lat);
                        const lng = parseFloat(data[0].lon);
                        initMapAt(lat, lng);
                        updateLocation(lat, lng);
                    }
                })
                .catch(() => {});
        }

        map.on('click', (e) => updateLocation(e.latlng.lat, e.latlng.lng));
        marker.on('dragend', () => { const p = marker.getLatLng(); updateLocation(p.lat, p.lng); });
        window.resetMap = () => { map.setView(marker.getLatLng(), 13); };
        setTimeout(() => map.invalidateSize(), 200);
        setTimeout(() => map.invalidateSize(), 800);
    });
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const aiBtn     = document.getElementById('aiGenBtn');
    const aiStatus  = document.getElementById('aiStatus');
    const descField = document.querySelector('textarea[name*="description"]');
    if (!aiBtn || !descField) return;

    aiBtn.addEventListener('click', async function() {
        const titre    = document.querySelector('input[name*="titre"]')?.value?.trim() || '';
        const lieu     = document.querySelector('input[name*="lieu"]')?.value?.trim() || '';
        const dateDebut= document.querySelector('input[name*="date_debut"]')?.value?.trim() || '';
        const prix     = document.querySelector('input[name*="frais_inscription"]')?.value?.trim() || '';
        const capacite = document.querySelector('input[name*="capacite_max"]')?.value?.trim() || '';

        if (!titre) {
            aiStatus.style.display = 'block';
            aiStatus.style.color = '#dc2626';
            aiStatus.textContent = '⚠ Remplissez d\'abord le titre.';
            return;
        }

        aiBtn.disabled = true;
        aiBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération...';
        aiStatus.style.display = 'block';
        aiStatus.style.color = '#6366f1';
        aiStatus.textContent = '✨ L\'IA rédige votre description...';

        const form = new FormData();
        form.append('titre', titre);
        form.append('lieu', lieu);
        form.append('date_debut', dateDebut);
        form.append('prix', prix);
        form.append('capacite', capacite);

        try {
            const res  = await fetch('{{ path('back_ai_generate_description') }}', { method: 'POST', body: form });
            const data = await res.json();
            if (data.description) {
                descField.value = '';
                aiStatus.style.color = '#16a34a';
                aiStatus.textContent = '✅ Description générée !';
                let i = 0;
                const text = data.description;
                const interval = setInterval(() => {
                    descField.value += text[i++];
                    if (i >= text.length) clearInterval(interval);
                }, 12);
            } else {
                aiStatus.style.color = '#dc2626';
                aiStatus.textContent = '❌ ' + (data.error || 'Erreur inconnue.');
            }
        } catch (e) {
            aiStatus.style.color = '#dc2626';
            aiStatus.textContent = '❌ Erreur réseau.';
        }
        aiBtn.disabled = false;
        aiBtn.innerHTML = '<i class="fas fa-magic"></i> Générer avec IA';
    });

    // ── Poster Generator — via PHP proxy ──
    const posterBtn = document.getElementById('posterBtn');
    if (posterBtn) {
        posterBtn.addEventListener('click', async function() {
            const titre    = document.querySelector('input[name*="titre"]')?.value?.trim() || '';
            const lieu     = document.querySelector('input[name*="lieu"]')?.value?.trim() || '';
            const dateDebut= document.querySelector('input[name*="date_debut"]')?.value?.trim() || '';
            const prix     = document.querySelector('input[name*="frais_inscription"]')?.value?.trim() || '';

            if (!titre) { alert('Remplissez d\'abord le titre.'); return; }

            document.getElementById('posterModal').style.display = 'flex';
            document.getElementById('posterImg').style.display = 'none';
            document.getElementById('posterActions').style.display = 'none';
            document.getElementById('posterSaveStatus').style.display = 'none';
            document.getElementById('posterLoading').style.display = 'flex';
            document.getElementById('posterLoading').innerHTML =
                '<div style="width:48px;height:48px;border:4px solid #f1f5f9;border-top-color:#f97316;border-radius:50%;animation:spin .8s linear infinite;"></div>'
                + '<p style="color:#64748b;font-size:.85rem;font-weight:600;text-align:center;">Génération en cours...<br><small style="opacity:.7;">Cela peut prendre 30-60 secondes</small></p>';
            window._posterImageData = null;
            const fd = new FormData();
            fd.append('titre', titre); fd.append('lieu', lieu);
            fd.append('date_debut', dateDebut); fd.append('prix', prix);
            fd.append('event_id', '{{ event.id_ev ?? 0 }}');

            try {
                const res  = await fetch('{{ path('back_ai_generate_poster') }}', { method: 'POST', body: fd });
                const data = await res.json();
                if (data.image_data) {
                    window._posterImageData = data.image_data;
                    const img = document.getElementById('posterImg');
                    img.src = data.image_data;
                    img.style.display = 'block';
                    document.getElementById('posterLoading').style.display = 'none';
                    document.getElementById('posterActions').style.display = 'flex';
                    const dl = document.getElementById('posterDownload');
                    dl.href = data.image_data;
                    dl.download = titre.replace(/\s+/g,'_') + '_affiche.jpg';
                } else {
                    document.getElementById('posterLoading').innerHTML =
                        '<p style="color:#dc2626;text-align:center;">❌ ' + (data.error || 'Erreur') + '</p>';
                }
            } catch(e) {
                document.getElementById('posterLoading').innerHTML =
                    '<p style="color:#dc2626;text-align:center;">❌ Erreur réseau.</p>';
            }
        });
    }
});
</script>

<!-- Poster Modal -->
<div id="posterModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);z-index:9999;align-items:center;justify-content:center;" onclick="if(event.target===this)this.style.display='none'">
    <div style="background:#fff;border-radius:28px;padding:32px;max-width:560px;width:90%;box-shadow:0 30px 80px rgba(0,0,0,.25);position:relative;">
        <button onclick="document.getElementById('posterModal').style.display='none'"
            style="position:absolute;top:16px;right:20px;background:none;border:none;font-size:1.4rem;color:#94a3b8;cursor:pointer;">×</button>
        <h5 style="font-weight:800;margin-bottom:6px;color:#0f172a;"><i class="fas fa-image me-2" style="color:#f97316;"></i>Affiche générée par IA</h5>
        <p style="font-size:.82rem;color:#64748b;margin-bottom:20px;">Basée sur les informations de votre événement</p>
        <div id="posterLoading" style="display:flex;flex-direction:column;align-items:center;gap:14px;padding:40px 0;">
            <div style="width:48px;height:48px;border:4px solid #f1f5f9;border-top-color:#f97316;border-radius:50%;animation:spin .8s linear infinite;"></div>
            <p style="color:#64748b;font-size:.85rem;font-weight:600;text-align:center;">Génération en cours...<br><small style="opacity:.7;">10-20 secondes</small></p>
        </div>
        <img id="posterImg" style="display:none;width:100%;border-radius:16px;box-shadow:0 8px 30px rgba(0,0,0,.1);" alt="Affiche">
        <div id="posterActions" style="display:none;margin-top:16px;gap:10px;justify-content:center;flex-wrap:wrap;">
            <button id="posterKeep" type="button"
                style="background:linear-gradient(135deg,#16a34a,#22c55e);color:#fff;border:none;border-radius:14px;padding:12px 24px;font-weight:800;font-size:.85rem;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(22,163,74,.3);">
                <i class="fas fa-check"></i> Garder avec l'événement
            </button>
            <button id="posterRegen" type="button"
                style="background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:14px;padding:12px 22px;font-weight:700;font-size:.85rem;cursor:pointer;display:flex;align-items:center;gap:8px;">
                <i class="fas fa-redo"></i> Régénérer
            </button>
            <a id="posterDownload" href="#" download
                style="display:inline-flex;align-items:center;gap:8px;background:#f1f5f9;color:#475569;text-decoration:none;border-radius:14px;padding:12px 22px;font-weight:700;font-size:.85rem;">
                <i class="fas fa-download"></i> Télécharger
            </a>
            <button id="posterIgnore" type="button"
                style="background:#fee2e2;color:#dc2626;border:none;border-radius:14px;padding:12px 22px;font-weight:700;font-size:.85rem;cursor:pointer;">
                <i class="fas fa-times"></i> Ignorer
            </button>
        </div>
        <div id="posterSaveStatus" style="display:none;margin-top:10px;text-align:center;font-size:.8rem;"></div>
    </div>
</div>
<style>@keyframes spin { to { transform: rotate(360deg); } }</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const keepBtn   = document.getElementById('posterKeep');
    const ignoreBtn = document.getElementById('posterIgnore');
    const saveStatus= document.getElementById('posterSaveStatus');

    if (keepBtn) {
        keepBtn.addEventListener('click', async function() {
            keepBtn.disabled = true;
            keepBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enregistrement...';
            saveStatus.style.display = 'block';
            saveStatus.style.color = '#64748b';
            saveStatus.textContent = 'Enregistrement en cours...';

            const fd = new FormData();
            fd.append('event_id', '{{ event.id_ev }}');
            fd.append('image_data', window._posterImageData || '');

            try {
                const res  = await fetch('{{ path('back_ai_save_poster') }}', { method: 'POST', body: fd });
                const data = await res.json();
                if (data.success) {
                    saveStatus.style.color = '#16a34a';
                    saveStatus.textContent = '✅ Affiche enregistrée avec l\'événement !';
                    keepBtn.innerHTML = '<i class="fas fa-check"></i> Enregistrée !';
                    keepBtn.style.background = '#0f172a';
                } else {
                    saveStatus.style.color = '#dc2626';
                    saveStatus.textContent = '❌ ' + (data.error || 'Erreur');
                    keepBtn.disabled = false;
                    keepBtn.innerHTML = '<i class="fas fa-check"></i> Garder avec l\'événement';
                }
            } catch(e) {
                saveStatus.style.color = '#dc2626';
                saveStatus.textContent = '❌ Erreur réseau.';
                keepBtn.disabled = false;
                keepBtn.innerHTML = '<i class="fas fa-check"></i> Garder avec l\'événement';
            }
        });
    }

    if (ignoreBtn) {
        ignoreBtn.addEventListener('click', function() {
            document.getElementById('posterModal').style.display = 'none';
            window._posterImageData = null;
        });
    }

    const regenBtn = document.getElementById('posterRegen');
    if (regenBtn) {
        regenBtn.addEventListener('click', function() {
            window._posterImageData = null;
            keepBtn.disabled = false;
            keepBtn.style.background = 'linear-gradient(135deg,#16a34a,#22c55e)';
            keepBtn.innerHTML = '<i class="fas fa-check"></i> Garder avec l\'événement';
            saveStatus.style.display = 'none';
            document.getElementById('posterBtn').click();
        });
    }
});
</script>

{% endblock %}