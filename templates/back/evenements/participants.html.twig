{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
    body { background: #f0f4f3; font-family: 'Plus Jakarta Sans', sans-serif; }
    .main-card { background: #fff; border-radius: 28px; box-shadow: 0 8px 40px rgba(0,0,0,.06); overflow: hidden; }
    .search-box { border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 10px 16px 10px 40px; font-size: .88rem; background: #f8fafc; outline: none; transition: .2s; width: 100%; }
    .search-box:focus { border-color: #16a34a; background: #fff; box-shadow: 0 0 0 3px rgba(22,163,74,.1); }
    .tab-pill { padding: 8px 22px; border-radius: 50px; border: 1.5px solid #e2e8f0; background: #fff; font-size: .82rem; font-weight: 700; cursor: pointer; transition: .2s; color: #64748b; }
    .tab-pill.active { background: #0f172a; color: #fff; border-color: #0f172a; }
    .tab-pill.green.active { background: #16a34a; border-color: #16a34a; }
    .tab-pill.amber.active { background: #f59e0b; border-color: #f59e0b; color: #fff; }
    .p-row { border-bottom: 1px solid #f1f5f9; transition: .15s; }
    .p-row:hover { background: #f0fdf4; }
    .avatar-c { width: 38px; height: 38px; border-radius: 12px; background: #ecfdf5; color: #16a34a; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: .85rem; flex-shrink: 0; }
    .hidden { display: none !important; }
    
    /* Modal Styles */
    .modal-overlay { 
        display: none; 
        position: fixed; 
        top: 0; left: 0; 
        width: 100%; height: 100%; 
        background: rgba(15, 23, 42, 0.7); 
        backdrop-filter: blur(4px);
        z-index: 9999; 
        align-items: center; 
        justify-content: center; 
        padding: 20px;
    }
    .modal-content { 
        background: white; 
        width: 100%; 
        max-width: 600px; 
        max-height: 85vh; 
        border-radius: 24px; 
        display: flex; 
        flex-direction: column; 
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    }
    .modal-body { 
        overflow-y: auto; 
        padding: 24px; 
        flex-grow: 1;
    }
    .person-tile-modal {
        width: 80px;
        height: 100px;
        border: 2px solid #f1f5f9;
        border-radius: 16px;
        background: #fff;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }
    .person-tile-modal:hover {
        border-color: #16a34a;
        transform: translateY(-4px);
        box-shadow: 0 10px 15px -3px rgba(22, 163, 74, 0.1);
    }
    .person-tile-modal.active {
        border-color: #16a34a;
        background: #f0fdf4;
    }
    .person-tile-modal.active i { color: #16a34a; }
    .person-tile-modal.active span { color: #16a34a !important; }

    /* New UI Elements */
    .verification-group {
        display: flex;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        padding: 4px;
        border-radius: 14px;
        transition: .2s;
    }
    .verification-group:focus-within {
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22, 163, 74, 0.1);
    }
    .code-input-new {
        border: none;
        background: transparent;
        padding: 8px 12px;
        width: 100px;
        font-weight: 800;
        font-size: 1rem;
        letter-spacing: 2px;
        text-align: center;
        outline: none;
    }
    .btn-verify-new {
        background: #16a34a;
        color: white;
        border: none;
        border-radius: 10px;
        padding: 8px 16px;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: .2s;
        cursor: pointer;
    }
    .btn-verify-new:hover { background: #15803d; }
    
    .btn-modify-presence {
        background: #eff6ff;
        color: #2563eb;
        border: 1px solid #dbeafe;
        border-radius: 12px;
        padding: 6px 14px;
        font-size: 0.75rem;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: .2s;
        cursor: pointer;
    }
    .btn-modify-presence:hover { background: #dbeafe; }

    .progress-compact {
        height: 8px;
        width: 120px;
        background: #e2e8f0;
        border-radius: 10px;
        overflow: hidden;
        border: 1px solid #e2e8f0;
    }
    .progress-bar-fill {
        height: 100%;
        background: #16a34a;
        transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    }
</style>

<div class="container py-5">
    <div class="main-card">

        <!-- Header -->
        <div class="page-header" style="background:#fff;border-bottom:1px solid #f1f5f9;padding:28px 40px;">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <a href="{{ path('back_evenements_show', {id: evenement.id_ev}) }}"
                       style="color:#94a3b8;text-decoration:none;font-size:.82rem;font-weight:700;">
                        <i class="fas fa-arrow-left me-2"></i>Retour à l'événement
                    </a>
                    <h2 class="fw-bold mb-0 mt-2" style="letter-spacing:-1px;color:#0f172a;">Gestion des participants</h2>
                    <p style="color:#94a3b8;margin:4px 0 0;font-size:.88rem;">{{ evenement.titre }}</p>
                </div>
                <div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:16px;padding:16px 24px;text-align:center;">
                    <div style="color:#16a34a;font-size:1.8rem;font-weight:900;">{{ participants|length }}</div>
                    <div style="color:#64748b;font-size:.75rem;font-weight:700;">inscrits</div>
                </div>
            </div>
        </div>

        <div class="p-4">

            <!-- Search + Tabs -->
            <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                <div class="position-relative" style="flex:1;min-width:220px;">
                    <i class="fas fa-search position-absolute" style="left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;"></i>
                    <input type="text" id="searchInput" class="search-box" placeholder="Rechercher par nom...">
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="tab-pill active" data-tab="TOUT">Tous <span class="ms-1" id="cnt-tout"></span></button>
                    <button class="tab-pill green" data-tab="attended">Présents <span class="ms-1" id="cnt-attended"></span></button>
                    <button class="tab-pill amber" data-tab="confirmed">En attente <span class="ms-1" id="cnt-confirmed"></span></button>
                </div>
            </div>

            <!-- Table -->
            <div class="rounded-4 border overflow-hidden">
                <table class="table align-middle mb-0" style="font-size:.85rem;">
                    <thead style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
                        <tr>
                            <th class="ps-4 py-3 fw-bold">Participant</th>
                            <th class="fw-bold text-center">Taux de Présence</th>
                            <th class="fw-bold text-center pe-4">Validation & Accès</th>
                        </tr>
                    </thead>
                    <tbody id="participantTable">
                        {% for p in participants %}
                        <tr class="p-row"
                            data-name="{{ p.nom_participant|lower }}"
                            data-status="{{ p.confirmation }}"
                            id="prow-{{ p.id_participant }}"
                            style="border-left: 4px solid {% if p.confirmation == 'attended' %}#16a34a{% elseif p.confirmation == 'confirmed' %}#f59e0b{% else %}#e2e8f0{% endif %};">

                            <td class="ps-4 py-4">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-c" style="width: 45px; height: 45px; font-size: 1.2rem;">{{ p.nom_participant|slice(0,1)|upper }}</div>
                                    <div class="d-flex flex-column">
                                        <span class="fw-bold text-dark" style="font-size: 1rem;">{{ p.nom_participant }}</span>
                                        <span class="text-muted" style="font-size: 0.8rem;">{{ p.email ?? '—' }}</span>
                                        <span class="badge mt-1" style="background:#f1f5f9;color:#475569;font-size: 0.7rem; width: fit-content;">
                                            <i class="fas fa-users me-1"></i>{{ p.nbr_places }} réservée{{ p.nbr_places > 1 ? 's' : '' }}
                                        </span>
                                    </div>
                                </div>
                            </td>

                            <td class="text-center">
                                <div class="d-flex flex-column align-items-center gap-2">
                                    {% set pct = p.nbr_places > 0 ? (p.nbr_presents / p.nbr_places * 100)|round(0) : 0 %}
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="d-flex flex-column align-items-end">
                                            <span class="fw-bold text-dark" style="font-size: 0.9rem;">
                                                <span id="row-present-count-{{ p.id_participant }}">{{ p.nbr_presents }}</span> / {{ p.nbr_places }}
                                            </span>
                                            <span class="text-muted" id="row-pct-{{ p.id_participant }}" style="font-size: 0.65rem; font-weight: 800; color: #16a34a !important;">{{ pct }}% PRÉSENT</span>
                                        </div>
                                        <div class="progress-compact">
                                            <div class="progress-bar-fill" id="bar-{{ p.id_participant }}" style="width: {{ pct }}%;"></div>
                                        </div>
                                    </div>

                                    {% if p.confirmation == 'attended' %}
                                        <button class="btn-modify-presence" 
                                                onclick="openAttendanceModal({{ p.id_participant }}, '{{ p.nom_participant|escape('js') }}', {{ p.nbr_places }}, {{ p.nbr_presents }})">
                                            <i class="fas fa-user-check"></i>
                                            Gérer présences
                                        </button>
                                    {% endif %}
                                </div>
                            </td>

                            <td class="text-center pe-4 py-3" id="verify-{{ p.id_participant }}">
                                {% if p.confirmation != 'attended' %}
                                <div class="d-inline-flex">
                                    <div class="verification-group">
                                        <input type="number" id="code-{{ p.id_participant }}" class="code-input-new" placeholder="0000">
                                        <button class="btn-verify-new" onclick="verifyCode({{ p.id_participant }})">
                                            <i class="fas fa-key"></i>
                                            Valider
                                        </button>
                                    </div>
                                </div>
                                <div id="msg-{{ p.id_participant }}" class="small mt-1" style="font-size: 0.7rem; font-weight: 700;"></div>
                                {% else %}
                                    <div class="d-flex align-items-center justify-content-center gap-3">
                                        <div class="d-flex align-items-center gap-2 px-3 py-2 rounded-pill" style="background: #f0fdf4; border: 1px solid #bbf7d0; color: #16a34a;">
                                            <i class="fas fa-check-circle"></i>
                                            <span class="fw-bold" style="font-size: 0.8rem;">Code Validé</span>
                                        </div>
                                        <button class="btn btn-link btn-sm text-danger p-0" onclick="resetAttendance({{ p.id_participant }})" title="Réinitialiser">
                                            <i class="fas fa-rotate-left"></i>
                                        </button>
                                    </div>
                                {% endif %}
                            </td>
                        </tr>
                        {% endfor %}
                        
                        {% if participants is empty %}
                        <tr><td colspan="3" class="text-center py-5 text-muted"><i class="fas fa-users-slash me-2"></i>Aucun participant</td></tr>
                        {% endif %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- MODAL GESTION DES PRÉSENCES -->
<div id="attendanceModal" class="modal-overlay" onclick="if(event.target === this) closeAttendanceModal()">
    <div class="modal-content">
        <div class="modal-header d-flex justify-content-between align-items-center p-4" style="background:#f8fafc; border-bottom:1px solid #e2e8f0; border-radius: 24px 24px 0 0;">
            <div>
                <h5 class="mb-0 fw-bold text-dark" style="font-size: 1.2rem;" id="modalParticipantName">Gestion des Présences</h5>
                <p class="text-muted small mb-0" id="modalSubTitle">Cliquez sur les participants arrivés</p>
            </div>
            <button class="btn-close" onclick="closeAttendanceModal()" style="background: none; border: none; font-size: 1.5rem; color: #94a3b8; cursor: pointer;">&times;</button>
        </div>
        <div class="modal-body">
            <div id="modalAttendanceGrid" class="d-flex flex-wrap gap-3 justify-content-center py-2">
                <!-- Les tuiles seront injectées ici via JS -->
            </div>
        </div>
        <div class="modal-footer p-4" style="background:#f8fafc; border-top:1px solid #e2e8f0; border-radius: 0 0 24px 24px; display: flex; justify-content: space-between; align-items: center;">
            <div class="d-flex flex-column">
                <span class="text-muted small fw-bold">TOTAL PRÉSENTS</span>
                <span class="fw-bold" style="color:#16a34a; font-size: 1.1rem;">
                    <span id="modalCurrentCount">0</span> / <span id="modalMaxCount">0</span>
                </span>
            </div>
            <button class="btn px-5 py-2 rounded-pill fw-bold" 
                    style="background:#16a34a; color:white; border:none; box-shadow: 0 4px 14px 0 rgba(22,163,74,0.39); cursor: pointer;"
                    onclick="closeAttendanceModal()">
                Terminer
            </button>
        </div>
    </div>
</div>

<script>
// ── Counts ──
function updateCounts() {
    const rows = document.querySelectorAll('#participantTable tr[data-status]');
    let tot = 0, att = 0, con = 0;
    rows.forEach(r => {
        tot++;
        if (r.dataset.status === 'attended') att++;
        else con++;
    });
    const tout = document.getElementById('cnt-tout');
    const attended = document.getElementById('cnt-attended');
    const confirmed = document.getElementById('cnt-confirmed');
    if(tout) tout.textContent = '(' + tot + ')';
    if(attended) attended.textContent = '(' + att + ')';
    if(confirmed) confirmed.textContent = '(' + con + ')';
}

// ── Filter ──
let currentTab = 'TOUT', currentSearch = '';

function applyFilter() {
    document.querySelectorAll('#participantTable tr[data-status]').forEach(r => {
        const matchTab    = currentTab === 'TOUT' || r.dataset.status === currentTab;
        const matchSearch = r.dataset.name.includes(currentSearch);
        r.classList.toggle('hidden', !(matchTab && matchSearch));
    });
}

const searchInput = document.getElementById('searchInput');
if(searchInput) {
    searchInput.addEventListener('input', function() {
        currentSearch = this.value.toLowerCase().trim();
        applyFilter();
    });
}

document.querySelectorAll('.tab-pill').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-pill').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentTab = this.dataset.tab;
        applyFilter();
    });
});

// ── Attendance Modal ──
let currentModalId = null;

function openAttendanceModal(id, name, maxPlaces, currentPresents) {
    currentModalId = id;
    document.getElementById('modalParticipantName').textContent = name;
    document.getElementById('modalMaxCount').textContent = maxPlaces;
    document.getElementById('modalCurrentCount').textContent = currentPresents;
    
    const grid = document.getElementById('modalAttendanceGrid');
    grid.innerHTML = '';
    
    for (let i = 1; i <= maxPlaces; i++) {
        const isActive = i <= currentPresents;
        const tile = document.createElement('div');
        tile.className = 'person-tile-modal' + (isActive ? ' active' : '');
        tile.id = `modal-tile-${i}`;
        tile.onclick = () => updateModalAttendance(i);
        tile.innerHTML = `
            <i class="fas fa-user-circle" style="font-size: 2rem; color: ${isActive ? '#16a34a' : '#cbd5e1'}; transition: 0.3s;"></i>
            <span class="mt-2 fw-bold" style="font-size: 0.75rem; color: ${isActive ? '#16a34a' : '#94a3b8'};">P${i}</span>
        `;
        grid.appendChild(tile);
    }
    
    document.getElementById('attendanceModal').style.display = 'flex';
}

function closeAttendanceModal() {
    document.getElementById('attendanceModal').style.display = 'none';
    currentModalId = null;
}

async function updateModalAttendance(clickedIndex) {
    if (!currentModalId) return;
    
    const grid = document.getElementById('modalAttendanceGrid');
    const tiles = grid.querySelectorAll('.person-tile-modal');
    const currentlyPresentCount = Array.from(tiles).filter(t => t.classList.contains('active')).length;
    
    let newCount = clickedIndex;
    if (clickedIndex === currentlyPresentCount) {
        newCount = clickedIndex - 1;
    }

    const body = new FormData();
    body.append('count', newCount);

    try {
        const res = await fetch('/back/participants/' + currentModalId + '/update-attendance', { method: 'POST', body });
        const data = await res.json();
        if (data.success) {
            document.getElementById('modalCurrentCount').textContent = data.nbr_presents;
            tiles.forEach((tile, index) => {
                const isActive = (index + 1 <= data.nbr_presents);
                tile.className = 'person-tile-modal' + (isActive ? ' active' : '');
                const icon = tile.querySelector('i');
                const span = tile.querySelector('span');
                icon.style.color = isActive ? '#16a34a' : '#cbd5e1';
                span.style.color = isActive ? '#16a34a' : '#94a3b8';
            });
            
            // Update Table Row UI
            const rowCount = document.getElementById('row-present-count-' + currentModalId);
            const rowBar = document.getElementById('bar-' + currentModalId);
            const rowPct = document.getElementById('row-pct-' + currentModalId);
            
            const max = parseInt(document.getElementById('modalMaxCount').textContent);
            const newPct = Math.round((data.nbr_presents / max) * 100);

            if (rowCount) rowCount.textContent = data.nbr_presents;
            if (rowBar) rowBar.style.width = newPct + '%';
            if (rowPct) rowPct.textContent = newPct + '% PRÉSENT';
            
            updateCounts();
        }
    } catch(e) { console.error(e); }
}

async function verifyCode(id) {
    const input = document.getElementById('code-' + id);
    const msg   = document.getElementById('msg-' + id);
    if(!input || !msg) return;
    msg.textContent = '';
    input.style.borderColor = '#e2e8f0';

    const body = new FormData();
    body.append('code', input.value);

    try {
        const res  = await fetch('/back/participants/' + id + '/attend', { method: 'POST', body });
        const data = await res.json();
        if (data.success) {
            location.reload(); 
        } else {
            msg.style.color = '#dc2626';
            msg.textContent = '❌ Code incorrect';
            input.style.borderColor = '#dc2626';
        }
    } catch(e) {
        msg.style.color = '#dc2626'; msg.textContent = '❌ Erreur';
    }
}

async function resetAttendance(id) {
    if(!confirm('Voulez-vous annuler la présence de ce participant ?')) return;
    const body = new FormData();
    body.append('count', 0);
    await fetch('/back/participants/' + id + '/update-attendance', { method: 'POST', body });
    location.reload();
}

updateCounts();
</script>
{% endblock %}