{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<style>
    body { background: #f0f4f3; font-family: 'Plus Jakarta Sans', sans-serif; }
    .main-card { background: #fff; border-radius: 28px; box-shadow: 0 8px 40px rgba(0,0,0,.06); overflow: hidden; }
    .page-header { background: linear-gradient(135deg, #0f172a, #1e3a2f); padding: 32px 40px; }
    .search-box { border: 1.5px solid #e2e8f0; border-radius: 14px; padding: 10px 16px 10px 40px; font-size: .88rem; background: #f8fafc; outline: none; transition: .2s; width: 100%; }
    .search-box:focus { border-color: #16a34a; background: #fff; box-shadow: 0 0 0 3px rgba(22,163,74,.1); }
    .tab-pill { padding: 8px 22px; border-radius: 50px; border: 1.5px solid #e2e8f0; background: #fff; font-size: .82rem; font-weight: 700; cursor: pointer; transition: .2s; color: #64748b; }
    .tab-pill.active { background: #0f172a; color: #fff; border-color: #0f172a; }
    .tab-pill.green.active { background: #16a34a; border-color: #16a34a; }
    .tab-pill.amber.active { background: #f59e0b; border-color: #f59e0b; color: #fff; }
    .tab-pill.grey.active  { background: #94a3b8; border-color: #94a3b8; color: #fff; }
    .p-row { border-bottom: 1px solid #f1f5f9; transition: .15s; }
    .p-row:hover { background: #f8fafc; }
    .avatar-c { width: 38px; height: 38px; border-radius: 12px; background: #ecfdf5; color: #16a34a; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: .85rem; flex-shrink: 0; }
    .badge-attended { background: #dcfce7; color: #16a34a; border: 1px solid #86efac; }
    .badge-confirmed { background: #fef9c3; color: #b45309; border: 1px solid #fde68a; }
    .badge-pending   { background: #f1f5f9; color: #94a3b8; border: 1px solid #e2e8f0; }
    .code-input { width: 90px; padding: 6px 10px; border: 1.5px solid #e2e8f0; border-radius: 10px; font-size: .82rem; text-align: center; outline: none; transition: .2s; }
    .code-input:focus { border-color: #16a34a; }
    .btn-verify { background: #16a34a; color: #fff; border: none; border-radius: 10px; padding: 6px 14px; font-weight: 700; font-size: .8rem; cursor: pointer; transition: .2s; }
    .btn-verify:hover { background: #15803d; }
    .hidden { display: none !important; }
</style>

<div class="container py-5">
    <div class="main-card">

        <!-- Header -->
        <div class="page-header">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                <div>
                    <a href="{{ path('back_evenements_show', {id: evenement.id_ev}) }}"
                       style="color:rgba(255,255,255,.6);text-decoration:none;font-size:.82rem;font-weight:700;">
                        <i class="fas fa-arrow-left me-2"></i>Retour à l'événement
                    </a>
                    <h2 class="text-white fw-900 mb-0 mt-2" style="letter-spacing:-1px;">Gestion des participants</h2>
                    <p style="color:rgba(255,255,255,.6);margin:4px 0 0;font-size:.88rem;">{{ evenement.titre }}</p>
                </div>
                <div style="background:rgba(255,255,255,.1);border-radius:16px;padding:16px 24px;text-align:center;">
                    <div style="color:#4ade80;font-size:1.8rem;font-weight:900;">{{ participants|length }}</div>
                    <div style="color:rgba(255,255,255,.6);font-size:.75rem;font-weight:700;">inscrits</div>
                </div>
            </div>
        </div>

        <div class="p-4">

            <!-- Search + Tabs -->
            <div class="d-flex flex-wrap gap-3 align-items-center mb-4">
                <div class="position-relative" style="flex:1;min-width:220px;">
                    <i class="fas fa-search position-absolute" style="left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.82rem;"></i>
                    <input type="text" id="searchInput" class="search-box" placeholder="Rechercher par nom...">
                </div>
                <div class="d-flex gap-2 flex-wrap">
                    <button class="tab-pill active" data-tab="TOUT">Tous <span class="ms-1" id="cnt-tout"></span></button>
                    <button class="tab-pill green" data-tab="attended">Présents <span class="ms-1" id="cnt-attended"></span></button>
                    <button class="tab-pill amber" data-tab="confirmed">Inscrits <span class="ms-1" id="cnt-confirmed"></span></button>
                    <button class="tab-pill grey"  data-tab="pending">En attente <span class="ms-1" id="cnt-pending"></span></button>
                </div>
            </div>

            <!-- Table -->
            <div class="rounded-4 border overflow-hidden">
                <table class="table align-middle mb-0" style="font-size:.85rem;">
                    <thead style="background:#f8fafc;">
                        <tr>
                            <th class="ps-4 py-3 fw-bold">Participant</th>
                            <th class="fw-bold">Email</th>
                            <th class="fw-bold">Places</th>
                            <th class="fw-bold">Inscription</th>
                            <th class="fw-bold text-center">Statut</th>
                            {% if evenement.statut == 'EN_COURS' %}
                            <th class="fw-bold text-center pe-4">Vérifier code</th>
                            {% endif %}
                        </tr>
                    </thead>
                    <tbody id="participantTable">
                        {% for p in participants %}
                        <tr class="p-row"
                            data-name="{{ p.nom_participant|lower }}"
                            data-status="{{ p.confirmation }}"
                            id="prow-{{ p.id_participant }}">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="avatar-c">{{ p.nom_participant|slice(0,1)|upper }}</div>
                                    <span class="fw-bold">{{ p.nom_participant }}</span>
                                </div>
                            </td>
                            <td class="text-muted">{{ p.email ?? '—' }}</td>
                            <td><span class="badge rounded-pill" style="background:#f1f5f9;color:#475569;">{{ p.nbr_places }} place{{ p.nbr_places > 1 ? 's' : '' }}</span></td>
                            <td class="text-muted">{{ p.date_inscription|date('d/m/Y') }}</td>
                            <td class="text-center" id="status-{{ p.id_participant }}">
                                {% if p.confirmation == 'attended' %}
                                    <span class="badge rounded-pill px-3 badge-attended"><i class="fas fa-check me-1"></i>Présent</span>
                                {% elseif p.confirmation == 'confirmed' %}
                                    <span class="badge rounded-pill px-3 badge-confirmed"><i class="fas fa-clock me-1"></i>Inscrit</span>
                                {% else %}
                                    <span class="badge rounded-pill px-3 badge-pending"><i class="fas fa-envelope me-1"></i>En attente</span>
                                {% endif %}
                            </td>
                            {% if evenement.statut == 'EN_COURS' %}
                            <td class="text-center pe-4" id="verify-{{ p.id_participant }}">
                                {% if p.confirmation != 'attended' %}
                                <div class="d-flex gap-2 justify-content-center align-items-center">
                                    <input type="number" id="code-{{ p.id_participant }}" class="code-input" placeholder="Code...">
                                    <button class="btn-verify" onclick="verifyCode({{ p.id_participant }}, {{ p.entry_code }})">
                                        <i class="fas fa-check"></i>
                                    </button>
                                </div>
                                <div id="msg-{{ p.id_participant }}" style="font-size:.72rem;margin-top:4px;min-height:16px;"></div>
                                {% else %}
                                    <span style="color:#16a34a;font-size:.8rem;font-weight:700;"><i class="fas fa-check-circle me-1"></i>Validé</span>
                                {% endif %}
                            </td>
                            {% endif %}
                        </tr>
                        {% else %}
                        <tr><td colspan="6" class="text-center py-5 text-muted"><i class="fas fa-users-slash me-2"></i>Aucun participant</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<script>
// ── Counts ──
function updateCounts() {
    const rows = document.querySelectorAll('#participantTable tr[data-status]');
    let tot = 0, att = 0, con = 0, pen = 0;
    rows.forEach(r => {
        tot++;
        if (r.dataset.status === 'attended') att++;
        else if (r.dataset.status === 'confirmed') con++;
        else pen++;
    });
    document.getElementById('cnt-tout').textContent     = '(' + tot + ')';
    document.getElementById('cnt-attended').textContent = '(' + att + ')';
    document.getElementById('cnt-confirmed').textContent= '(' + con + ')';
    document.getElementById('cnt-pending').textContent  = '(' + pen + ')';
}

// ── Filter ──
let currentTab = 'TOUT', currentSearch = '';

function applyFilter() {
    document.querySelectorAll('#participantTable tr[data-status]').forEach(r => {
        const matchTab    = currentTab === 'TOUT' || r.dataset.status === currentTab;
        const matchSearch = r.dataset.name.includes(currentSearch);
        r.classList.toggle('hidden', !(matchTab && matchSearch));
    });
}

document.getElementById('searchInput').addEventListener('input', function() {
    currentSearch = this.value.toLowerCase().trim();
    applyFilter();
});

document.querySelectorAll('.tab-pill').forEach(btn => {
    btn.addEventListener('click', function() {
        document.querySelectorAll('.tab-pill').forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentTab = this.dataset.tab;
        applyFilter();
    });
});

// ── Verify code ──
async function verifyCode(id, correct) {
    const input = document.getElementById('code-' + id);
    const msg   = document.getElementById('msg-' + id);
    if (parseInt(input.value) !== correct) {
        msg.style.color = '#dc2626';
        msg.textContent = '❌ Code incorrect';
        input.style.borderColor = '#dc2626';
        return;
    }
    try {
        const res = await fetch('/back/participants/' + id + '/attend', { method: 'POST' });
        const data = await res.json();
        if (data.success) {
            document.getElementById('status-' + id).innerHTML =
                '<span class="badge rounded-pill px-3 badge-attended"><i class="fas fa-check me-1"></i>Présent</span>';
            document.getElementById('verify-' + id).innerHTML =
                '<span style="color:#16a34a;font-size:.8rem;font-weight:700;"><i class="fas fa-check-circle me-1"></i>Validé</span>';
            const row = document.getElementById('prow-' + id);
            row.dataset.status = 'attended';
            updateCounts();
            applyFilter();
        }
    } catch(e) {
        msg.style.color = '#dc2626'; msg.textContent = '❌ Erreur';
    }
}

updateCounts();
</script>
{% endblock %}
