{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>

<style>
    :root {
        --agri-dark: #061a14;
        --agri-green: #10b981;
        --error-red: #ef4444;
    }

    .main-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        border-radius: 35px;
        border: 1px solid #ffffff;
        box-shadow: 0 30px 60px rgba(0,0,0,0.08);
        padding: 50px;
    }

    .form-group { position: relative; margin-bottom: 1.5rem; }

    .form-control {
        border-radius: 18px;
        padding: 14px 45px 14px 22px;
        border: 2px solid #f1f5f9;
        background: #f8fafc;
        transition: all 0.3s;
    }

    .validation-icon {
        position: absolute;
        right: 20px;
        top: 48px;
        font-size: 1.1rem;
        display: none;
        z-index: 5;
    }

    .is-valid-field { border-color: var(--agri-green) !important; background-color: #f0fdf4 !important; }
    .is-invalid-field { border-color: var(--error-red) !important; background-color: #fef2f2 !important; }

    .error-msg {
        color: var(--error-red);
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 5px;
        display: none;
    }

    #map-selector {
        height: 580px;
        width: 100%;
        border-radius: 25px;
        border: 8px solid white;
        box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    }

    .btn-submit-agri {
        background: var(--agri-dark);
        color: white;
        padding: 16px 40px;
        border-radius: 20px;
        font-weight: 800;
        border: none;
        transition: 0.3s;
    }
</style>

<div class="container py-5">
    <div class="main-card animate__animated animate__fadeInUp">
        <form method="post" id="eventForm" novalidate>
            <div class="row g-5">
                <div class="col-lg-6">
                    <h5 class="mb-4 fw-bold">Configuration de l'événement</h5>

                    <div class="form-group">
                        <label class="form-label fw-bold small text-uppercase">Titre</label>
                        <input type="text" name="titre" id="titre" class="form-control" placeholder="Min. 5 caractères">
                        <i class="fas fa-check-circle text-success validation-icon" id="titre-check"></i>
                        <div class="error-msg" id="titre-error">Le titre est requis (min. 5).</div>
                    </div>

                    <div class="form-group">
                        <label class="form-label fw-bold small text-uppercase">Description</label>
                        <textarea name="description" id="description" class="form-control" rows="2" placeholder="Détails..."></textarea>
                        <i class="fas fa-check-circle text-success validation-icon" id="description-check" style="top: 48px;"></i>
                        <div class="error-msg" id="description-error">La description est requise (min. 10).</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold small text-uppercase">Date de Début</label>
                                <input type="datetime-local" name="date_debut" id="date_debut" class="form-control">
                                <i class="fas fa-check-circle text-success validation-icon" id="date_debut-check"></i>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label fw-bold small text-uppercase">Date de Fin</label>
                                <input type="datetime-local" name="date_fin" id="date_fin" class="form-control">
                                <i class="fas fa-check-circle text-success validation-icon" id="date_fin-check"></i>
                                <div class="error-msg" id="date-error">La fin doit être après le début.</div>
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label fw-bold small text-uppercase">Lieu</label>
                        <input type="text" id="lieu-input" name="lieu" class="form-control" placeholder="Tapez ou cliquez la carte...">
                        <i class="fas fa-check-circle text-success validation-icon" id="lieu-check"></i>
                        <div class="error-msg" id="lieu-error">Lieu non trouvé.</div>
                    </div>

                    <div class="row">
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label fw-bold small text-uppercase">Prix (DT)</label>
                                <input type="number" name="frais_inscription" id="frais" class="form-control" min="0" step="0.01">
                                <i class="fas fa-check-circle text-success validation-icon" id="frais-check"></i>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="form-group">
                                <label class="form-label fw-bold small text-uppercase">Capacité</label>
                                <input type="number" name="capacite" id="capacite" class="form-control">
                                <i class="fas fa-check-circle text-success validation-icon" id="capacite-check"></i>
                                <div class="error-msg" id="capacite-error">La capacité doit être supérieure à 1.</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div id="map-selector"></div>
                </div>
            </div>

            <div class="mt-5 pt-4 border-top d-flex justify-content-end">
                <button class="btn btn-submit-agri" type="submit" id="submitBtn">Enregistrer l'événement</button>
            </div>
        </form>
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('eventForm');
    const lieuInput = document.getElementById('lieu-input');
    let locationFound = false;

    // --- MAP SETUP ---
    var map = L.map('map-selector', { zoomControl: false }).setView([36.8065, 10.1815], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 19
    }).addTo(map);
    var marker = L.marker([36.8065, 10.1815]).addTo(map);

    // --- VALIDATION ENGINE ---
    const setValid = (el, errId) => {
        el.classList.add('is-valid-field'); el.classList.remove('is-invalid-field');
        const chk = document.getElementById(el.id + '-check');
        if (chk) chk.style.display = 'block';
        if (errId) document.getElementById(errId).style.display = 'none';
    };
    const setInvalid = (el, errId) => {
        el.classList.remove('is-valid-field'); el.classList.add('is-invalid-field');
        const chk = document.getElementById(el.id + '-check');
        if (chk) chk.style.display = 'none';
        if (errId) document.getElementById(errId).style.display = 'block';
    };

    const checkTitre = () => {
        const el = document.getElementById('titre');
        const ok = el.value.trim().length >= 5;
        ok ? setValid(el, 'titre-error') : setInvalid(el, 'titre-error'); return ok;
    };
    const checkDescription = () => {
        const el = document.getElementById('description');
        const ok = el.value.trim().length >= 10;
        ok ? setValid(el, 'description-error') : setInvalid(el, 'description-error'); return ok;
    };
    const checkCapacite = () => {
        const el = document.getElementById('capacite');
        const ok = el.value !== '' && parseInt(el.value) > 0;
        ok ? setValid(el, 'capacite-error') : setInvalid(el, 'capacite-error'); return ok;
    };
    const checkFrais = () => {
        const el = document.getElementById('frais');
        const ok = el.value !== '' && parseFloat(el.value) >= 0;
        ok ? setValid(el, null) : setInvalid(el, null); return ok;
    };
    const checkDates = () => {
        const d1 = document.getElementById('date_debut');
        const d2 = document.getElementById('date_fin');
        if (!d1.value) { setInvalid(d1, null); return false; }
        setValid(d1, null);
        if (!d2.value) { setInvalid(d2, 'date-error'); return false; }
        const ok = new Date(d2.value) > new Date(d1.value);
        ok ? setValid(d2, 'date-error') : setInvalid(d2, 'date-error'); return ok;
    };

    // --- REAL-TIME LISTENERS ---
    document.getElementById('titre').addEventListener('input', checkTitre);
    document.getElementById('description').addEventListener('input', checkDescription);
    document.getElementById('capacite').addEventListener('input', checkCapacite);
    document.getElementById('frais').addEventListener('input', checkFrais);
    document.getElementById('date_debut').addEventListener('change', checkDates);
    document.getElementById('date_fin').addEventListener('change', checkDates);

    // --- MAP LOGIC ---
    map.on('click', function(e) {
        marker.setLatLng(e.latlng);
        fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${e.latlng.lat}&lon=${e.latlng.lng}&accept-language=fr`)
            .then(res => res.json())
            .then(data => {
                const name = data.address.city || data.address.town || data.address.village
                           || data.address.county || data.display_name;
                lieuInput.value = name;
                locationFound = true;
                hideSuggestions();
                validate('lieu-input', true, 'lieu-error');
            });
    });

    // --- SUGGESTIONS DROPDOWN ---
    const suggestBox = document.createElement('div');
    suggestBox.id = 'lieu-suggestions';
    suggestBox.style.cssText = 'position:absolute;top:100%;left:0;right:0;background:#fff;border:1.5px solid #10b981;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:9999;max-height:200px;overflow-y:auto;display:none;margin-top:4px;';
    lieuInput.parentElement.style.position = 'relative';
    lieuInput.parentElement.appendChild(suggestBox);

    function hideSuggestions() { suggestBox.style.display = 'none'; suggestBox.innerHTML = ''; }

    function showSuggestions(results) {
        suggestBox.innerHTML = '';
        if (!results.length) { hideSuggestions(); return; }
        results.forEach(r => {
            const item = document.createElement('div');
            item.textContent = r.display_name;
            item.style.cssText = 'padding:10px 16px;cursor:pointer;font-size:13px;border-bottom:1px solid #f1f5f9;';
            item.addEventListener('mouseenter', () => item.style.background = '#f0fdf4');
            item.addEventListener('mouseleave', () => item.style.background = '#fff');
            item.addEventListener('mousedown', (e) => {
                e.preventDefault();
                lieuInput.value = r.display_name;
                map.flyTo([r.lat, r.lon], 14);
                marker.setLatLng([r.lat, r.lon]);
                locationFound = true;
                hideSuggestions();
                validate('lieu-input', true, 'lieu-error');
            });
            suggestBox.appendChild(item);
        });
        suggestBox.style.display = 'block';
    }

    let searchTimer;
    lieuInput.addEventListener('input', function() {
        locationFound = false;
        clearTimeout(searchTimer);
        if (this.value.length < 3) { hideSuggestions(); return validate('lieu-input', false, 'lieu-error'); }
        searchTimer = setTimeout(() => {
            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(this.value)}&limit=5&accept-language=fr`)
                .then(res => res.json())
                .then(data => {
                    if (data.length > 0) {
                        showSuggestions(data);
                        map.flyTo([data[0].lat, data[0].lon], 13);
                        marker.setLatLng([data[0].lat, data[0].lon]);
                        locationFound = true;
                        validate('lieu-input', true, 'lieu-error');
                    } else {
                        hideSuggestions();
                        validate('lieu-input', false, 'lieu-error');
                    }
                });
        }, 500);
    });

    lieuInput.addEventListener('blur', () => setTimeout(hideSuggestions, 150));
    lieuInput.addEventListener('focus', () => { if (suggestBox.children.length) suggestBox.style.display = 'block'; });

    // --- FORM SUBMIT GUARD ---
    form.addEventListener('submit', function(e) {
        const ok = [checkTitre(), checkDescription(), checkDates(),
                    validate('lieu-input', locationFound || lieuInput.value.length > 5, 'lieu-error'),
                    checkFrais(), checkCapacite()];
        if (ok.includes(false)) {
            e.preventDefault();
            const btn = document.getElementById('submitBtn');
            btn.classList.add('animate__animated', 'animate__shakeX');
            setTimeout(() => btn.classList.remove('animate__shakeX'), 1000);
        }
    });
});
</script>
{% endblock %}