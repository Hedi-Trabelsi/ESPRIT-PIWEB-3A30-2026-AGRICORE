{% extends 'back/base_back.html.twig' %}

{% block content %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"/>

<style>
    :root {
        --agri-dark: #061a14;
        --agri-green: #10b981;
        --error-red: #ef4444;
    }

    .main-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(15px);
        border-radius: 35px;
        border: 1px solid #ffffff;
        box-shadow: 0 30px 60px rgba(0,0,0,0.08);
        padding: 50px;
    }

    .form-group { position: relative; margin-bottom: 1.5rem; }

    .form-control {
        border-radius: 18px;
        padding: 14px 45px 14px 22px;
        border: 2px solid #f1f5f9;
        background: #f8fafc;
        transition: all 0.3s;
    }

    .validation-icon {
        position: absolute;
        right: 20px;
        top: 48px;
        font-size: 1.1rem;
        display: none;
        z-index: 5;
    }

    .is-valid-field { border-color: var(--agri-green) !important; background-color: #f0fdf4 !important; }
    .is-invalid-field { border-color: var(--error-red) !important; background-color: #fef2f2 !important; }

    .error-msg {
        color: var(--error-red);
        font-size: 0.75rem;
        font-weight: 700;
        margin-top: 5px;
        display: none;
    }

    #map-selector {
        height: 580px;
        width: 100%;
        border-radius: 25px;
        border: 8px solid white;
        box-shadow: 0 15px 40px rgba(0,0,0,0.06);
    }

    .btn-submit-agri {
        background: var(--agri-dark);
        color: white;
        padding: 16px 40px;
        border-radius: 20px;
        font-weight: 800;
        border: none;
        transition: 0.3s;
    }
</style>

<div class="container py-5">
    <div class="main-card animate__animated animate__fadeInUp">
        {{ form_start(form, {'attr': {'class': 'row g-5', 'novalidate': 'novalidate', 'id': 'eventForm'}}) }}
            <input type="hidden" name="poster_image_data" id="posterImageDataField">

            <div class="col-lg-6">
                <h5 class="mb-4 fw-bold">Configuration de l'événement</h5>

                <div class="form-group">
                    {{ form_label(form.titre, 'Titre') }}
                    {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Min. 5 caractères'}}) }}
                    <div class="text-danger small">{{ form_errors(form.titre) }}</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.description, 'Description') }}
                    <div style="position:relative;">
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Détails...', 'id': 'desc_field'}}) }}
                        <button type="button" id="aiGenBtn"
                            style="position:absolute;top:10px;right:10px;background:linear-gradient(135deg,#6366f1,#8b5cf6);color:#fff;border:none;border-radius:10px;padding:6px 14px;font-size:.78rem;font-weight:700;cursor:pointer;display:flex;align-items:center;gap:6px;transition:.2s;z-index:5;">
                            <i class="fas fa-magic"></i> Générer avec IA
                        </button>
                    </div>
                    <div id="aiStatus" style="font-size:.78rem;margin-top:6px;display:none;"></div>
                    <div class="text-danger small">{{ form_errors(form.description) }}</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.date_debut, 'Date de Début') }}
                    {{ form_widget(form.date_debut, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger small">{{ form_errors(form.date_debut) }}</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.date_fin, 'Date de Fin') }}
                    {{ form_widget(form.date_fin, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger small">{{ form_errors(form.date_fin) }}</div>
                </div>

                <div class="form-group">
                    {{ form_label(form.lieu, 'Lieu') }}
                    {{ form_widget(form.lieu, {'attr': {'class': 'form-control', 'id': 'lieu-input', 'placeholder': 'Tapez ou cliquez la carte...'}}) }}
                    <div class="text-danger small">{{ form_errors(form.lieu) }}</div>
                </div>

                <div class="row">
                    <div class="col-6">
                        <div class="form-group">
                            {{ form_label(form.frais_inscription, 'Prix (DT)') }}
                            {{ form_widget(form.frais_inscription, {'attr': {'class': 'form-control', 'min': '0', 'step': '0.01'}}) }}
                            <div class="text-danger small">{{ form_errors(form.frais_inscription) }}</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="form-group">
                            {{ form_label(form.capacite_max, 'Capacité') }}
                            {{ form_widget(form.capacite_max, {'attr': {'class': 'form-control', 'min': '1'}}) }}
                            <div class="text-danger small">{{ form_errors(form.capacite_max) }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-6">
                <div id="map-selector"></div>
            </div>
        
            <div class="mt-5 pt-4 border-top d-flex justify-content-between w-100">
                <button type="button" id="posterBtn"
                    style="background:linear-gradient(135deg,#f97316,#fb923c);color:#fff;border:none;border-radius:20px;padding:14px 28px;font-weight:800;cursor:pointer;display:flex;align-items:center;gap:8px;transition:.2s;">
                    <i class="fas fa-image"></i> Générer l'affiche IA
                </button>
                <button class="btn btn-submit-agri" type="submit" id="submitBtn">Enregistrer l'événement</button>
            </div>

        {{ form_end(form) }}
    </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const lieuInput = document.getElementById('{{ form.lieu.vars.id }}');
    const form = document.getElementById('eventForm');

    // --- MAP SETUP ---
    var map = L.map('map-selector', { zoomControl: false }).setView([36.8065, 10.1815], 11);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '© OpenStreetMap contributors',
        maxZoom: 19
    }).addTo(map);
    var marker = L.marker([36.8065, 10.1815]).addTo(map);

    // --- SUGGESTIONS DROPDOWN ---
    const suggestBox = document.createElement('div');
    suggestBox.id = 'lieu-suggestions';
    suggestBox.style.cssText = 'position:absolute;top:100%;left:0;right:0;background:#fff;border:1.5px solid #10b981;border-radius:12px;box-shadow:0 8px 24px rgba(0,0,0,.1);z-index:9999;max-height:200px;overflow-y:auto;display:none;margin-top:4px;';
    lieuInput.parentElement.style.position = 'relative';
    lieuInput.parentElement.appendChild(suggestBox);

    function hideSuggestions() { suggestBox.style.display = 'none'; suggestBox.innerHTML = ''; }

    function showSuggestions(results) {
        suggestBox.innerHTML = '';
        if (!results.length) { hideSuggestions(); return; }
        results.forEach(r => {
            const item = document.createElement('div');
            item.textContent = r.display_name;
            item.style.cssText = 'padding:10px 16px;cursor:pointer;font-size:13px;border-bottom:1px solid #f1f5f9;';
            item.addEventListener('mouseenter', () => item.style.background = '#f0fdf4');
            item.addEventListener('mouseleave', () => item.style.background = '#fff');
            item.addEventListener('mousedown', (e) => {
                e.preventDefault();
                lieuInput.value = r.display_name;
                map.flyTo([r.lat, r.lon], 14);
                marker.setLatLng([r.lat, r.lon]);
                hideSuggestions();
            });
            suggestBox.appendChild(item);
        });
        suggestBox.style.display = 'block';
    }

    let searchTimer;
    lieuInput.addEventListener('input', function() {
        clearTimeout(searchTimer);
        if (this.value.length < 3) { hideSuggestions(); return; }
        searchTimer = setTimeout(() => {
            fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(this.value)}&limit=5&accept-language=fr`)
                .then(res => res.json())
                .then(data => {
                    if (data.length > 0) {
                        showSuggestions(data);
                        map.flyTo([data[0].lat, data[0].lon], 13);
                        marker.setLatLng([data[0].lat, data[0].lon]);
                    } else {
                        hideSuggestions();
                    }
                });
        }, 500);
    });

    lieuInput.addEventListener('blur', () => setTimeout(hideSuggestions, 150));
    lieuInput.addEventListener('focus', () => { if (suggestBox.children.length) suggestBox.style.display = 'block'; });

    // --- MAP CLICK HANDLER ---
    map.on('click', function(e) {
        marker.setLatLng(e.latlng);
        fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${e.latlng.lat}&lon=${e.latlng.lng}&accept-language=fr`)
            .then(res => res.json())
            .then(data => {
                const name = data.address.city || data.address.town || data.address.village
                           || data.address.county || data.display_name;
                lieuInput.value = name;
                hideSuggestions();
            });
    });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const aiBtn    = document.getElementById('aiGenBtn');
    const aiStatus = document.getElementById('aiStatus');
    const descField = document.getElementById('desc_field')
                   || document.querySelector('textarea[name*="description"]');
    if (!aiBtn || !descField) return;

    aiBtn.addEventListener('click', async function() {
        const titre    = document.querySelector('input[name*="titre"]')?.value?.trim() || '';
        const lieu     = document.getElementById('{{ form.lieu.vars.id }}')?.value?.trim() || '';
        const dateDebut= document.querySelector('input[name*="date_debut"]')?.value?.trim() || '';
        const prix     = document.querySelector('input[name*="frais_inscription"]')?.value?.trim() || '';
        const capacite = document.querySelector('input[name*="capacite_max"]')?.value?.trim() || '';

        if (!titre) {
            aiStatus.style.display = 'block';
            aiStatus.style.color = '#dc2626';
            aiStatus.textContent = '⚠ Remplissez d\'abord le titre.';
            return;
        }

        aiBtn.disabled = true;
        aiBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Génération...';
        aiStatus.style.display = 'block';
        aiStatus.style.color = '#6366f1';
        aiStatus.textContent = '✨ L\'IA rédige votre description...';

        const form = new FormData();
        form.append('titre', titre);
        form.append('lieu', lieu);
        form.append('date_debut', dateDebut);
        form.append('prix', prix);
        form.append('capacite', capacite);

        try {
            const res  = await fetch('{{ path('back_ai_generate_description') }}', { method: 'POST', body: form });
            const data = await res.json();

            if (data.description) {
                // Animate typing effect
                descField.value = '';
                aiStatus.style.color = '#16a34a';
                aiStatus.textContent = '✅ Description générée !';
                let i = 0;
                const text = data.description;
                const interval = setInterval(() => {
                    descField.value += text[i++];
                    if (i >= text.length) clearInterval(interval);
                }, 12);
            } else {
                aiStatus.style.color = '#dc2626';
                aiStatus.textContent = '❌ ' + (data.error || 'Erreur inconnue.');
            }
        } catch (e) {
            aiStatus.style.color = '#dc2626';
            aiStatus.textContent = '❌ Erreur réseau.';
        }

        aiBtn.disabled = false;
        aiBtn.innerHTML = '<i class="fas fa-magic"></i> Générer avec IA';
    });

    // ── Poster Generator — via PHP proxy ──
    const posterBtn = document.getElementById('posterBtn');
    if (posterBtn) {
        posterBtn.addEventListener('click', async function() {
            const titre    = document.querySelector('input[name*="titre"]')?.value?.trim() || '';
            const lieu     = document.getElementById('{{ form.lieu.vars.id }}')?.value?.trim() || '';
            const dateDebut= document.querySelector('input[name*="date_debut"]')?.value?.trim() || '';
            const prix     = document.querySelector('input[name*="frais_inscription"]')?.value?.trim() || '';

            if (!titre) { alert('Remplissez d\'abord le titre.'); return; }

            // Reset modal state
            document.getElementById('posterModal').style.display = 'flex';
            document.getElementById('posterImg').style.display = 'none';
            document.getElementById('posterActions').style.display = 'none';
            document.getElementById('posterKeptMsg').style.display = 'none';
            document.getElementById('posterLoading').style.display = 'flex';
            document.getElementById('posterLoading').innerHTML =
                '<div style="width:48px;height:48px;border:4px solid #f1f5f9;border-top-color:#f97316;border-radius:50%;animation:spin .8s linear infinite;"></div>'
                + '<p style="color:#64748b;font-size:.85rem;font-weight:600;text-align:center;">Génération en cours...<br><small style="opacity:.7;">Cela peut prendre 30-60 secondes</small></p>';

            const fd = new FormData();
            fd.append('titre', titre); fd.append('lieu', lieu);
            fd.append('date_debut', dateDebut); fd.append('prix', prix);

            try {
                const res  = await fetch('{{ path('back_ai_generate_poster') }}', { method: 'POST', body: fd });
                const data = await res.json();
                if (data.image_data) {
                    const img = document.getElementById('posterImg');
                    img.src = data.image_data;
                    img.style.display = 'block';
                    document.getElementById('posterLoading').style.display = 'none';
                    document.getElementById('posterActions').style.display = 'flex';
                    // Pre-fill download link
                    const dl = document.getElementById('posterDownload');
                    dl.href = data.image_data;
                    dl.download = titre.replace(/\s+/g,'_') + '_affiche.jpg';
                    // Store temp key for form submission
                    if (data.temp_key) {
                        document.getElementById('posterImageDataField').value = data.temp_key;
                    }
                    // Reset keep button
                    const kb = document.getElementById('posterKeepAdd');
                    kb.disabled = false;
                    kb.style.background = 'linear-gradient(135deg,#16a34a,#22c55e)';
                    kb.innerHTML = '<i class="fas fa-check"></i> Garder avec l\'événement';
                } else {
                    document.getElementById('posterLoading').innerHTML =
                        '<p style="color:#dc2626;text-align:center;">❌ ' + (data.error || 'Erreur') + '</p>';
                }
            } catch(e) {
                document.getElementById('posterLoading').innerHTML =
                    '<p style="color:#dc2626;text-align:center;">❌ Erreur réseau.</p>';
            }
        });
    }
});
</script>

<!-- Poster Modal -->
<div id="posterModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);backdrop-filter:blur(6px);z-index:9999;align-items:center;justify-content:center;" onclick="if(event.target===this)this.style.display='none'">
    <div style="background:#fff;border-radius:28px;padding:32px;max-width:560px;width:90%;box-shadow:0 30px 80px rgba(0,0,0,.25);position:relative;">
        <button onclick="document.getElementById('posterModal').style.display='none'"
            style="position:absolute;top:16px;right:20px;background:none;border:none;font-size:1.4rem;color:#94a3b8;cursor:pointer;">×</button>
        <h5 style="font-weight:800;margin-bottom:6px;color:#0f172a;"><i class="fas fa-image me-2" style="color:#f97316;"></i>Affiche générée par IA</h5>
        <p style="font-size:.82rem;color:#64748b;margin-bottom:20px;">Basée sur les informations de votre événement</p>

        <div id="posterLoading" style="display:flex;flex-direction:column;align-items:center;gap:14px;padding:40px 0;">
            <div style="width:48px;height:48px;border:4px solid #f1f5f9;border-top-color:#f97316;border-radius:50%;animation:spin .8s linear infinite;"></div>
            <p style="color:#64748b;font-size:.85rem;font-weight:600;">Génération de l'affiche en cours...<br><small style="opacity:.7;">Cela peut prendre 10-20 secondes</small></p>
        </div>

        <img id="posterImg" style="display:none;width:100%;border-radius:16px;box-shadow:0 8px 30px rgba(0,0,0,.1);" alt="Affiche événement">

        <div id="posterActions" style="display:none;margin-top:16px;gap:10px;justify-content:center;flex-wrap:wrap;">
            <button type="button" id="posterKeepAdd"
                style="background:linear-gradient(135deg,#16a34a,#22c55e);color:#fff;border:none;border-radius:14px;padding:12px 24px;font-weight:800;font-size:.85rem;cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 6px 20px rgba(22,163,74,.3);">
                <i class="fas fa-check"></i> Garder avec l'événement
            </button>
            <a id="posterDownload" href="#" download style="display:inline-flex;align-items:center;gap:8px;background:#f1f5f9;color:#475569;text-decoration:none;border-radius:14px;padding:12px 22px;font-weight:700;font-size:.85rem;">
                <i class="fas fa-download"></i> Télécharger
            </a>
            <button type="button" id="posterIgnoreAdd"
                style="background:#fee2e2;color:#dc2626;border:none;border-radius:14px;padding:12px 22px;font-weight:700;font-size:.85rem;cursor:pointer;">
                <i class="fas fa-times"></i> Ignorer
            </button>
            <p id="posterKeptMsg" style="display:none;font-size:.78rem;color:#16a34a;font-weight:700;text-align:center;width:100%;margin:0;">
                ✅ Affiche sélectionnée — elle sera enregistrée avec l'événement.
            </p>
        </div>
    </div>
</div>

<style>
@keyframes spin { to { transform: rotate(360deg); } }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const keepBtn   = document.getElementById('posterKeepAdd');
    const ignoreBtn = document.getElementById('posterIgnoreAdd');

    if (keepBtn) {
        keepBtn.addEventListener('click', function() {
            document.getElementById('posterKeptMsg').style.display = 'block';
            keepBtn.innerHTML = '<i class="fas fa-check"></i> Sélectionnée !';
            keepBtn.style.background = '#0f172a';
            keepBtn.disabled = true;
            setTimeout(() => document.getElementById('posterModal').style.display = 'none', 800);
        });
    }

    if (ignoreBtn) {
        ignoreBtn.addEventListener('click', function() {
            document.getElementById('posterImageDataField').value = '';
            document.getElementById('posterModal').style.display = 'none';
        });
    }
});
</script>

{% endblock %}