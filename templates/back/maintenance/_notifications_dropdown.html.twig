<div class="p-3 border-bottom d-flex justify-content-between align-items-center">
    <h6 class="mb-0 fw-semibold">Notifications</h6>
    {% if unreadCount > 0 %}
        <span class="badge bg-warning text-dark" id="maintenanceUnreadCountLabel">{{ unreadCount }}</span>
    {% else %}
        <span class="badge bg-light text-muted" id="maintenanceUnreadCountLabel">0</span>
    {% endif %}
</div>

<div class="message-body" style="max-height: 300px; overflow-y: auto;">
    {% for notif in pendingNotifications|slice(0, 5) %}
        <a href="{{ path('app_maintenance_detail_back', {'id_maintenance': notif.id_maintenance}) }}"
           class="py-3 px-7 d-flex align-items-center dropdown-item gap-3 border-bottom">
            <span class="d-flex align-items-center justify-content-center bg-light-warning text-warning rounded-circle p-2">
                <i class="ti ti-alert-triangle fs-6"></i>
            </span>
            <div class="w-75 d-inline-block v-middle">
                <h6 class="mb-1 fw-semibold">Action requise</h6>
                <span class="d-block text-muted small">{{ notif.nomMaintenance }}</span>
            </div>
            {% if notif.isRead %}
                <span class="text-muted small maintenance-notif-state" data-id="{{ notif.id_maintenance }}">(lu)</span>
            {% else %}
                <span class="text-danger small maintenance-notif-state" data-id="{{ notif.id_maintenance }}">(non lu)</span>
            {% endif %}
        </a>
    {% else %}
        <div class="p-4 text-center">
            <p class="mb-0 text-muted">Aucune nouvelle demande</p>
        </div>
    {% endfor %}
</div>

<div class="p-2 border-top text-center">
    <a href="{{ path('app_maintenance_notifications_back') }}" class="btn btn-sm btn-outline-primary">Ouvrir les notifications</a>
</div>