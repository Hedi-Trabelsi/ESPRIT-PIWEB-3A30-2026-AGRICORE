<script>
document.addEventListener('DOMContentLoaded', function () {
    const bell = document.getElementById('drop1');
    const stateUrl = '{{ path('app_maintenance_notifications_state_back') }}';

    const setBellBadge = (count) => {
        if (!bell) {
            return;
        }

        const badge = bell.querySelector('.notification');
        if (!badge) {
            return;
        }

        if (count > 0) {
            badge.textContent = String(count);
            Object.assign(badge.style, {
                position: 'absolute',
                top: '-5px',
                right: '-5px',
                width: '18px',
                height: '18px',
                backgroundColor: '#fa896b',
                color: 'white',
                fontSize: '10px',
                fontWeight: 'bold',
                borderRadius: '50%',
                display: 'flex',
                alignItems: 'center',
                justifyContent: 'center'
            });
        } else {
            badge.style.display = 'none';
            badge.textContent = '';
        }
    };

    const updateStateLabels = (readMap) => {
        document.querySelectorAll('.maintenance-notif-state[data-id], .maintenance-notif-list-state[data-id]').forEach((el) => {
            const id = Number(el.dataset.id || '0');
            if (!id || !(id in readMap)) {
                return;
            }

            const isRead = !!readMap[id];
            el.textContent = isRead ? '(lu)' : '(non lu)';
            el.classList.toggle('text-muted', isRead);
            el.classList.toggle('text-danger', !isRead);
        });
    };

    const updateHeaderCount = (count) => {
        const headerBadge = document.getElementById('maintenanceUnreadCountLabel');
        if (!headerBadge) {
            return;
        }

        headerBadge.textContent = String(count);
        headerBadge.classList.toggle('bg-warning', count > 0);
        headerBadge.classList.toggle('text-dark', count > 0);
        headerBadge.classList.toggle('bg-light', count === 0);
        headerBadge.classList.toggle('text-muted', count === 0);
    };

    const refreshNotificationState = async () => {
        try {
            const response = await fetch(stateUrl, {
                cache: 'no-store',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });

            if (!response.ok) {
                return;
            }

            const payload = await response.json();
            const unreadCount = Number(payload.unreadCount || 0);
            const readMap = payload.readMap || {};

            setBellBadge(unreadCount);
            updateHeaderCount(unreadCount);
            updateStateLabels(readMap);
        } catch (error) {
        }
    };

    if (bell) {
        bell.style.cursor = 'pointer';
        bell.addEventListener('click', function (event) {
            event.preventDefault();
            window.location.href = '{{ path('app_maintenance_notifications_back') }}';
        });
    }

    refreshNotificationState();
    window.addEventListener('pageshow', function (event) {
        refreshNotificationState();

        if (event.persisted) {
            setTimeout(refreshNotificationState, 100);
        }
    });
    window.addEventListener('focus', refreshNotificationState);
    document.addEventListener('visibilitychange', function () {
        if (document.visibilityState === 'visible') {
            refreshNotificationState();
        }
    });
});
</script>