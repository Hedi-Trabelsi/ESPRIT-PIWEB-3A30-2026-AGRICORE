{% extends 'back/base_back.html.twig' %}

{% block notification_badge %}
    {% if new_users is defined and new_users|length > 0 %}
        <span style="position:absolute;top:2px;right:2px;width:18px;height:18px;background:#dc2626;color:#fff;border-radius:50%;font-size:10px;font-weight:700;display:flex;align-items:center;justify-content:center;">{{ new_users|length }}</span>
    {% endif %}
{% endblock %}

{% block content %}
<link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">

<style>
    .u-toolbar {
        background: #fff;
        border-radius: 16px;
        padding: 20px 24px;
        box-shadow: 0 1px 8px rgba(0,0,0,.04);
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        align-items: center;
        margin-bottom: 24px;
    }
    .u-search-wrap {
        flex: 1;
        min-width: 220px;
        position: relative;
    }
    .u-search-wrap i {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: #94a3b8;
        font-size: 14px;
    }
    .u-search-wrap input {
        width: 100%;
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px 14px 10px 38px;
        font-size: 14px;
        transition: .2s;
        background: #f8fafc;
    }
    .u-search-wrap input:focus {
        outline: none;
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22,163,74,.1);
        background: #fff;
    }
    .u-filter-select {
        border: 1px solid #e2e8f0;
        border-radius: 12px;
        padding: 10px 16px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        background: #f8fafc;
        min-width: 150px;
        cursor: pointer;
        transition: .2s;
    }
    .u-filter-select:focus {
        outline: none;
        border-color: #16a34a;
        box-shadow: 0 0 0 3px rgba(22,163,74,.1);
    }
    .u-result-count {
        font-size: 13px;
        color: #94a3b8;
        font-weight: 500;
        white-space: nowrap;
    }
    .u-result-count b { color: #1e293b; }

    .u-table tbody tr { transition: background .15s; }
    .u-table tbody tr:hover { background: #f8fafc; }
    .u-row-banned { opacity: .6; }
    .u-row-banned:hover { opacity: .8; }

    .u-empty-filter {
        text-align: center;
        padding: 60px 20px;
        color: #94a3b8;
        display: none;
    }
    .u-empty-filter i { font-size: 2.5rem; margin-bottom: 8px; }

    .u-sortable { cursor: pointer; user-select: none; white-space: nowrap; }
    .u-sortable:hover { color: #16a34a; }
    .u-sortable i { font-size: 10px; margin-left: 4px; opacity: .4; }

    /* New user notification banner */
    .u-notif-banner {
        background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
        border: 1px solid #bbf7d0;
        border-radius: 16px;
        padding: 18px 24px;
        margin-bottom: 20px;
        display: flex;
        align-items: flex-start;
        gap: 14px;
    }
    .u-notif-icon {
        width: 42px; height: 42px;
        background: #16a34a;
        color: #fff;
        border-radius: 12px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px;
        flex-shrink: 0;
    }
    .u-notif-body { flex: 1; }
    .u-notif-title { font-weight: 700; color: #15803d; font-size: 14px; margin-bottom: 4px; }
    .u-notif-list { font-size: 13px; color: #475569; margin: 0; padding: 0; list-style: none; }
    .u-notif-list li {
        padding: 6px 0;
        border-bottom: 1px solid #dcfce7;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .u-notif-list li:last-child { border-bottom: none; }
    .u-notif-avatar {
        width: 28px; height: 28px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #bbf7d0;
    }
    .u-notif-dismiss {
        background: none;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        font-size: 18px;
        padding: 4px;
        transition: .2s;
        align-self: flex-start;
    }
    .u-notif-dismiss:hover { color: #475569; }
</style>

<div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-start">
        <div>
            <h4 class="fw-bold mb-1">Gestion des utilisateurs</h4>
            <p class="text-muted mb-0">Consulter, modifier, bannir ou supprimer les utilisateurs de la plateforme.</p>
        </div>
        <div class="d-flex gap-2">
            <div class="dropdown">
                <button class="btn btn-outline-success d-flex align-items-center gap-2 dropdown-toggle" type="button" data-bs-toggle="dropdown" style="border-radius:12px;padding:10px 20px;font-weight:600;font-size:13px;">
                    <i class="ti ti-mail fs-5"></i> Envoyer un email
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                    <li><a class="dropdown-item" href="#" onclick="_openGroupEmail('1','Agriculteurs');return false;"><i class="ti ti-plant me-2"></i>Tous les agriculteurs</a></li>
                    <li><a class="dropdown-item" href="#" onclick="_openGroupEmail('2','Techniciens');return false;"><i class="ti ti-tools me-2"></i>Tous les techniciens</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li><a class="dropdown-item" href="#" onclick="_openGroupEmail('all','utilisateurs');return false;"><i class="ti ti-users me-2"></i>Tous les utilisateurs</a></li>
                </ul>
            </div>
            <a href="{{ path('back_utilisateurs_export_excel') }}" class="btn btn-success d-flex align-items-center gap-2" style="border-radius:12px;padding:10px 20px;font-weight:600;font-size:13px;">
                <i class="ti ti-file-spreadsheet fs-5"></i> Exporter en Excel
            </a>
        </div>
    </div>
</div>

{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="ti ti-check me-1"></i> {{ msg }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{% for msg in app.flashes('error') %}
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="ti ti-alert-circle me-1"></i> {{ msg }}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
{% endfor %}

{# New user notification #}
{% if new_users is defined and new_users|length > 0 %}
<div class="u-notif-banner" id="notifBanner">
    <div class="u-notif-icon"><i class="ti ti-user-plus"></i></div>
    <div class="u-notif-body">
        <div class="u-notif-title">{{ new_users|length }} nouveau{{ new_users|length > 1 ? 'x' : '' }} utilisateur{{ new_users|length > 1 ? 's' : '' }} depuis votre derniere visite</div>
        <ul class="u-notif-list">
            {% for nu in new_users %}
            <li>
                {% if nu.image %}
                    <img src="data:image/jpeg;base64,{{ nu.image }}" class="u-notif-avatar" alt="">
                {% else %}
                    <img src="{{ asset('img/profile.webp') }}" class="u-notif-avatar" alt="">
                {% endif %}
                <span><strong>{{ nu.prenom }} {{ nu.nom }}</strong> — {{ nu.email }}
                {% if nu.role == 1 %}
                    <span class="u-badge u-badge-agriculteur" style="font-size:10px;padding:2px 8px;"><i class="ti ti-plant me-1"></i>Agriculteur</span>
                {% elseif nu.role == 2 %}
                    <span class="u-badge u-badge-technicien" style="font-size:10px;padding:2px 8px;"><i class="ti ti-tools me-1"></i>Technicien</span>
                {% endif %}
                </span>
            </li>
            {% endfor %}
        </ul>
    </div>
    <button class="u-notif-dismiss" onclick="document.getElementById('notifBanner').style.display='none'" title="Fermer">
        <i class="ti ti-x"></i>
    </button>
</div>
{% endif %}

{# Stats cards #}
<div class="row mb-4 g-3">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="u-stat-icon" style="background:#f0fdf4;color:#16a34a;"><i class="ti ti-users fs-5"></i></div>
                <div>
                    <div class="u-stat-number">{{ users|length }}</div>
                    <div class="u-stat-label">Total</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="u-stat-icon" style="background:#fef3c7;color:#d97706;"><i class="ti ti-plant fs-5"></i></div>
                <div>
                    <div class="u-stat-number">{{ users|filter(u => u.role == 1)|length }}</div>
                    <div class="u-stat-label">Agriculteurs</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="u-stat-icon" style="background:#dbeafe;color:#2563eb;"><i class="ti ti-tools fs-5"></i></div>
                <div>
                    <div class="u-stat-number">{{ users|filter(u => u.role == 2)|length }}</div>
                    <div class="u-stat-label">Techniciens</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="u-stat-icon" style="background:#fef2f2;color:#dc2626;"><i class="ti ti-ban fs-5"></i></div>
                <div>
                    <div class="u-stat-number">{{ users|filter(u => u.banned)|length }}</div>
                    <div class="u-stat-label">Bannis</div>
                </div>
            </div>
        </div>
    </div>
</div>

{# Charts Dashboard (Chart.js) #}
<script src="https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js"></script>
<div class="row mb-4 g-3">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body">
                <h6 class="fw-bold mb-3" style="font-size:14px;color:#374151;"><i class="ti ti-chart-donut me-1" style="color:#16a34a;"></i> Repartition par role</h6>
                <canvas id="chartRole" style="max-height:240px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body">
                <h6 class="fw-bold mb-3" style="font-size:14px;color:#374151;"><i class="ti ti-gender-bigender me-1" style="color:#ec4899;"></i> Repartition par genre</h6>
                <canvas id="chartGender" style="max-height:240px;"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card border-0 shadow-sm" style="border-radius:12px;">
            <div class="card-body">
                <h6 class="fw-bold mb-3" style="font-size:14px;color:#374151;"><i class="ti ti-chart-bar me-1" style="color:#f59e0b;"></i> Statut des comptes</h6>
                <canvas id="chartStatus" style="max-height:240px;"></canvas>
            </div>
        </div>
    </div>
</div>
<script>
new Chart(document.getElementById('chartRole'), {
    type: 'doughnut',
    data: {
        labels: ['Agriculteurs', 'Techniciens', 'Administrateurs'],
        datasets: [{
            data: [{{ users|filter(u => u.role == 1)|length }}, {{ users|filter(u => u.role == 2)|length }}, {{ users|filter(u => u.role == 0)|length }}],
            backgroundColor: ['#16a34a', '#2563eb', '#7c3aed'],
            borderWidth: 2, borderColor: '#fff'
        }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true } } } }
});
new Chart(document.getElementById('chartGender'), {
    type: 'pie',
    data: {
        labels: ['Homme', 'Femme'],
        datasets: [{
            data: [{{ users|filter(u => u.genre == 'Homme')|length }}, {{ users|filter(u => u.genre == 'Femme')|length }}],
            backgroundColor: ['#3b82f6', '#ec4899'],
            borderWidth: 2, borderColor: '#fff'
        }]
    },
    options: { responsive: true, plugins: { legend: { position: 'bottom', labels: { padding: 12, usePointStyle: true } } } }
});
new Chart(document.getElementById('chartStatus'), {
    type: 'bar',
    data: {
        labels: ['Actifs', 'Bannis', 'Profil complet', 'Profil incomplet'],
        datasets: [{
            data: [{{ users|filter(u => not u.banned)|length }}, {{ users|filter(u => u.banned)|length }}, {{ users|filter(u => u.profileComplete)|length }}, {{ users|filter(u => not u.profileComplete)|length }}],
            backgroundColor: ['#16a34a', '#dc2626', '#f59e0b', '#94a3b8'],
            borderRadius: 6, borderSkipped: false
        }]
    },
    options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } }, x: { grid: { display: false } } } }
});
</script>

{# Toolbar: Search + Filters #}
<div class="u-toolbar">
    <div class="u-search-wrap">
        <i class="ti ti-search"></i>
        <input type="text" id="uSearch" placeholder="Rechercher par nom, email, adresse...">
    </div>
    <select id="uFilterRole" class="u-filter-select">
        <option value="all">Tous les roles</option>
        <option value="0">Administrateurs</option>
        <option value="1">Agriculteurs</option>
        <option value="2">Techniciens</option>
    </select>
    <select id="uFilterStatus" class="u-filter-select" style="min-width:120px;">
        <option value="all">Tout statut</option>
        <option value="active">Actifs</option>
        <option value="banned">Bannis</option>
    </select>
    <div class="u-result-count"><b id="uCount">{{ users|length }}</b> resultats</div>
</div>

{# Users Table #}
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0 u-table" id="uTable">
                <thead>
                    <tr>
                        <th class="ps-4 u-sortable" data-sort="id"># <i class="ti ti-arrows-sort"></i></th>
                        <th class="u-sortable" data-sort="name">Utilisateur <i class="ti ti-arrows-sort"></i></th>
                        <th>Email</th>
                        <th>Telephone</th>
                        <th>Role</th>
                        <th>Statut</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody id="uBody">
                    {% for user in users %}
                    <tr class="u-row {% if user.banned %}u-row-banned{% endif %} {% if new_users is defined and user.id in new_users|map(u => u.id) %}table-success{% endif %}"
                        data-name="{{ user.prenom|lower }} {{ user.nom|lower }}"
                        data-email="{{ user.email|lower }}"
                        data-adresse="{{ user.adresse|lower }}"
                        data-role="{{ user.role }}"
                        data-status="{{ user.banned ? 'banned' : 'active' }}"
                        data-id="{{ user.id }}">
                        <td class="ps-4 fw-semibold text-muted">
                            {{ user.id }}
                            {% if new_users is defined and user.id in new_users|map(u => u.id) %}
                                <span style="display:inline-block;width:8px;height:8px;background:#16a34a;border-radius:50%;margin-left:4px;" title="Nouveau"></span>
                            {% endif %}
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-3">
                                <div class="u-avatar">
                                    {% if user.image %}
                                        <img src="data:image/jpeg;base64,{{ user.image }}" alt="">
                                    {% else %}
                                        <img src="{{ asset('img/profile.webp') }}" alt="">
                                    {% endif %}
                                </div>
                                <div>
                                    <div class="fw-semibold">{{ user.prenom }} {{ user.nom }}</div>
                                    <div class="text-muted" style="font-size:12px;">{{ user.adresse }}</div>
                                </div>
                            </div>
                        </td>
                        <td><span style="font-size:13px;">{{ user.email }}</span></td>
                        <td>{{ user.numeroT }}</td>
                        <td>
                            {% if user.role == 0 %}
                                <span class="u-badge u-badge-admin"><i class="ti ti-shield-check me-1"></i>Admin</span>
                            {% elseif user.role == 1 %}
                                <span class="u-badge u-badge-agriculteur"><i class="ti ti-plant me-1"></i>Agriculteur</span>
                            {% else %}
                                <span class="u-badge u-badge-technicien"><i class="ti ti-tools me-1"></i>Technicien</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if user.banned %}
                                <span class="u-badge u-badge-banned"><i class="ti ti-ban me-1"></i>Banni</span>
                            {% else %}
                                <span class="u-badge u-badge-active"><i class="ti ti-check me-1"></i>Actif</span>
                            {% endif %}
                        </td>
                        <td class="text-center">
                            <div class="d-flex justify-content-center gap-2">
                                <a href="{{ path('back_utilisateur_modifier', {id: user.id}) }}" class="u-action-btn u-action-edit" title="Modifier">
                                    <i class="ti ti-edit"></i>
                                </a>
                                <button type="button" class="u-action-btn u-action-email" title="Envoyer un email"
                                    onclick="_openUserEmail({{ user.id }},'{{ user.prenom|replace({"'": "\\'"}) }}','{{ user.nom|replace({"'": "\\'"}) }}','{{ user.email }}')">
                                    <i class="ti ti-mail"></i>
                                </button>
                                {% if user.role != 0 %}
                                    <a href="{{ path('back_utilisateur_ban', {id: user.id}) }}" class="u-action-btn {% if user.banned %}u-action-unban{% else %}u-action-ban{% endif %}" title="{% if user.banned %}Debannir{% else %}Bannir{% endif %}">
                                        <i class="ti ti-{% if user.banned %}lock-open{% else %}ban{% endif %}"></i>
                                    </a>
                                    <a href="{{ path('back_utilisateur_supprimer', {id: user.id}) }}" class="u-action-btn u-action-delete" title="Supprimer" onclick="return confirm('Etes-vous sur de vouloir supprimer cet utilisateur ?')">
                                        <i class="ti ti-trash"></i>
                                    </a>
                                {% endif %}
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="ti ti-users-minus fs-1 d-block mb-2"></i>
                            Aucun utilisateur trouve.
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="u-empty-filter" id="uEmpty">
            <i class="ti ti-filter-off d-block mb-2"></i>
            Aucun utilisateur ne correspond a vos filtres.
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    var searchInput  = document.getElementById('uSearch');
    var roleFilter   = document.getElementById('uFilterRole');
    var statusFilter = document.getElementById('uFilterStatus');
    var countEl      = document.getElementById('uCount');
    var emptyEl      = document.getElementById('uEmpty');
    var rows         = document.querySelectorAll('#uBody .u-row');

    function applyFilters() {
        var q      = searchInput.value.toLowerCase().trim();
        var role   = roleFilter.value;
        var status = statusFilter.value;
        var visible = 0;

        rows.forEach(function(row) {
            var matchSearch = !q
                || row.dataset.name.indexOf(q) !== -1
                || row.dataset.email.indexOf(q) !== -1
                || row.dataset.adresse.indexOf(q) !== -1;
            var matchRole   = (role === 'all')   || row.dataset.role === role;
            var matchStatus = (status === 'all') || row.dataset.status === status;

            if (matchSearch && matchRole && matchStatus) {
                row.style.display = '';
                visible++;
            } else {
                row.style.display = 'none';
            }
        });

        countEl.textContent = visible;
        emptyEl.style.display = (visible === 0 && rows.length > 0) ? 'block' : 'none';
    }

    searchInput.addEventListener('input', applyFilters);
    roleFilter.addEventListener('change', applyFilters);
    statusFilter.addEventListener('change', applyFilters);

    // Column sorting
    var sortDir = {};
    document.querySelectorAll('.u-sortable').forEach(function(th) {
        th.addEventListener('click', function() {
            var key = th.dataset.sort;
            sortDir[key] = !sortDir[key];
            var arr = Array.from(rows);
            arr.sort(function(a, b) {
                var va, vb;
                if (key === 'id') {
                    va = parseInt(a.dataset.id);
                    vb = parseInt(b.dataset.id);
                } else {
                    va = a.dataset.name;
                    vb = b.dataset.name;
                }
                if (va < vb) return sortDir[key] ? -1 : 1;
                if (va > vb) return sortDir[key] ? 1 : -1;
                return 0;
            });
            var tbody = document.getElementById('uBody');
            arr.forEach(function(row) { tbody.appendChild(row); });
        });
    });
});
</script>

{# ============= EMAIL OVERLAY (custom, no Bootstrap modal) ============= #}
<div id="emailOverlay" style="display:none;position:fixed;top:0;left:0;right:0;bottom:0;z-index:99999;background:rgba(0,0,0,.45);align-items:center;justify-content:center;">
    <div style="background:#fff;border-radius:14px;width:540px;max-width:95vw;max-height:90vh;overflow-y:auto;box-shadow:0 20px 60px rgba(0,0,0,.3);">
        <div style="background:linear-gradient(135deg,#0F4229,#348E38);padding:18px 24px;border-radius:14px 14px 0 0;display:flex;align-items:center;gap:10px;">
            <i class="ti ti-mail" style="color:#fff;font-size:20px;"></i>
            <span id="emailModalTitle" style="color:#fff;font-size:16px;font-weight:600;flex:1;">Envoyer un email</span>
            <button type="button" onclick="document.getElementById('emailOverlay').style.display='none'" style="background:none;border:none;color:#fff;font-size:22px;cursor:pointer;line-height:1;">&times;</button>
        </div>
        <form id="emailForm" method="post">
            <div style="padding:24px;">
                <div style="margin-bottom:16px;">
                    <label style="font-size:13px;font-weight:700;color:#374151;display:block;margin-bottom:6px;">Destinataire</label>
                    <div id="emailRecipient" style="background:#f3f4f6;padding:8px 14px;border-radius:8px;font-size:13px;color:#555;"></div>
                </div>
                <div style="margin-bottom:16px;">
                    <label style="font-size:13px;font-weight:700;color:#374151;display:block;margin-bottom:6px;">Sujet</label>
                    <input type="text" name="subject" id="emailSubject" required placeholder="Objet de l'email" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:8px 12px;font-size:13px;outline:none;box-sizing:border-box;">
                </div>
                <div style="margin-bottom:16px;">
                    <label style="font-size:13px;font-weight:700;color:#374151;display:block;margin-bottom:6px;">Modele</label>
                    <select id="emailTemplate" onchange="_emailApplyTemplate()" style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:8px 12px;font-size:13px;outline:none;box-sizing:border-box;background:#fff;">
                        <option value="personnalise" selected>Personnalise</option>
                        <option value="bienvenue">Bienvenue</option>
                        <option value="rappel">Rappel profil</option>
                        <option value="avertissement">Avertissement</option>
                    </select>
                </div>
                <div style="margin-bottom:0;">
                    <label style="font-size:13px;font-weight:700;color:#374151;display:block;margin-bottom:6px;">Message</label>
                    <textarea name="message" id="emailMessage" rows="6" required placeholder="Redigez votre message..." style="width:100%;border:1px solid #d1d5db;border-radius:8px;padding:8px 12px;font-size:13px;outline:none;resize:vertical;box-sizing:border-box;font-family:inherit;"></textarea>
                </div>
                <input type="hidden" name="role" id="emailGroupRole" value="">
            </div>
            <div style="border-top:1px solid #f0f0f0;padding:14px 24px;display:flex;justify-content:flex-end;gap:10px;">
                <button type="button" onclick="document.getElementById('emailOverlay').style.display='none'" style="padding:8px 18px;border-radius:8px;border:1px solid #d1d5db;background:#fff;font-size:13px;cursor:pointer;">Annuler</button>
                <button type="submit" style="padding:8px 18px;border-radius:8px;border:none;background:#16a34a;color:#fff;font-size:13px;font-weight:600;cursor:pointer;display:flex;align-items:center;gap:6px;">
                    <i class="ti ti-send"></i> Envoyer
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .u-action-email {
        color: #16a34a;
        background: #f0fdf4;
        border: 1px solid #bbf7d0;
        width: 32px; height: 32px;
        display: inline-flex; align-items: center; justify-content: center;
        border-radius: 8px; cursor: pointer; transition: all .2s;
        font-size: 16px; text-decoration: none;
    }
    .u-action-email:hover { background: #16a34a; color: #fff; border-color: #16a34a; }
</style>

<script>
var _emailTpls = {
    bienvenue: { subject: 'Bienvenue sur Agricore !', message: "Bienvenue sur Agricore ! Votre compte a ete cree avec succes. Vous pouvez desormais acceder a toutes les fonctionnalites de la plateforme : gestion d'equipements, suivi de vos animaux, ventes et depenses.\n\nN'hesitez pas a completer votre profil pour profiter de la meteo locale et du QR code de contact." },
    rappel: { subject: 'Rappel : completez votre profil Agricore', message: "Nous avons remarque que votre profil n'est pas encore complet. Pensez a ajouter votre photo de profil, votre numero de telephone et votre adresse pour profiter de toutes les fonctionnalites d'Agricore (meteo locale, carte d'identite PDF, QR code vCard)." },
    avertissement: { subject: 'Avertissement concernant votre compte Agricore', message: "Ce message vous est envoye pour vous informer que votre activite sur Agricore a ete signalee. Veuillez respecter les conditions d'utilisation de la plateforme.\n\nEn cas de non-respect, votre compte pourra etre suspendu." },
    personnalise: { subject: '', message: '' }
};

function _emailApplyTemplate() {
    var t = _emailTpls[document.getElementById('emailTemplate').value];
    if (t) { document.getElementById('emailSubject').value = t.subject; document.getElementById('emailMessage').value = t.message; }
}

function _emailShow() {
    document.getElementById('emailOverlay').style.display = 'flex';
}

function _openUserEmail(id, prenom, nom, email) {
    document.getElementById('emailForm').action = '/back/utilisateurs/email/' + id;
    document.getElementById('emailModalTitle').textContent = 'Envoyer un email';
    document.getElementById('emailRecipient').innerHTML = '<i class="ti ti-user" style="margin-right:4px;"></i> <strong>' + prenom + ' ' + nom + '</strong> (' + email + ')';
    document.getElementById('emailGroupRole').value = '';
    document.getElementById('emailTemplate').value = 'personnalise';
    document.getElementById('emailSubject').value = '';
    document.getElementById('emailMessage').value = '';
    _emailShow();
}

function _openGroupEmail(role, label) {
    document.getElementById('emailForm').action = '/back/utilisateurs/email-group';
    document.getElementById('emailModalTitle').textContent = 'Email de groupe';
    document.getElementById('emailRecipient').innerHTML = '<i class="ti ti-users" style="margin-right:4px;"></i> Tous les <strong>' + label + '</strong> (actifs, non bannis)';
    document.getElementById('emailGroupRole').value = role;
    document.getElementById('emailTemplate').value = 'personnalise';
    document.getElementById('emailSubject').value = '';
    document.getElementById('emailMessage').value = '';
    _emailShow();
}

// Close overlay when clicking the dark backdrop
document.getElementById('emailOverlay').addEventListener('click', function(e) {
    if (e.target === this) this.style.display = 'none';
});
</script>

{% endblock %}
