{% extends 'back/base_back.html.twig' %}

{% block content %}
<link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">

{% set user = app.session.get('user') %}

<div class="row mb-4">
    <div class="col-12">
        <h4 class="fw-bold mb-1">Mon profil</h4>
        <p class="text-muted mb-0">Informations de votre compte administrateur.</p>
    </div>
</div>

{% if user %}
<div class="row g-4">
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center py-5">
                <div class="u-avatar-lg mx-auto mb-3">
                    {% if user.image %}
                        <img src="data:image/jpeg;base64,{{ user.image }}" alt="">
                    {% else %}
                        <img src="{{ asset('img/profile.webp') }}" alt="">
                    {% endif %}
                </div>
                <h5 class="fw-bold mb-1">{{ user.prenom }} {{ user.nom }}</h5>
                <p class="text-muted mb-3" style="font-size:14px;">{{ user.email }}</p>
                {% if user.role == 0 %}
                    <span class="u-badge u-badge-admin"><i class="ti ti-shield-check me-1"></i>Administrateur</span>
                {% elseif user.role == 1 %}
                    <span class="u-badge u-badge-agriculteur"><i class="ti ti-plant me-1"></i>Agriculteur</span>
                {% else %}
                    <span class="u-badge u-badge-technicien"><i class="ti ti-tools me-1"></i>Technicien</span>
                {% endif %}

                <hr class="my-4">

                <div class="text-start px-3">
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="ti ti-phone text-success"></i>
                        <span style="font-size:14px;">{{ user.numeroT }}</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="ti ti-map-pin text-success"></i>
                        <span style="font-size:14px;">{{ user.adresse }}</span>
                    </div>
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <i class="ti ti-gender-bigender text-success"></i>
                        <span style="font-size:14px;">{{ user.genre }}</span>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <i class="ti ti-calendar text-success"></i>
                        <span style="font-size:14px;">
                            {% if user.date %}
                                {{ user.date|date('d/m/Y') }}
                            {% else %}
                                Non renseigne
                            {% endif %}
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent border-bottom py-3">
                <h6 class="fw-bold mb-0"><i class="ti ti-id me-2 text-success"></i>Informations detaillees</h6>
            </div>
            <div class="card-body p-0">
                <table class="table table-borderless mb-0">
                    <tbody>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold" style="width:200px;">ID</td>
                            <td class="py-3">#{{ user.id }}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Nom complet</td>
                            <td class="py-3">{{ user.prenom }} {{ user.nom }}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Email</td>
                            <td class="py-3">{{ user.email }}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Telephone</td>
                            <td class="py-3">{{ user.numeroT }}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Adresse</td>
                            <td class="py-3">{{ user.adresse }}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Date de naissance</td>
                            <td class="py-3">{% if user.date %}{{ user.date|date('d/m/Y') }}{% else %}Non renseigne{% endif %}</td>
                        </tr>
                        <tr class="border-bottom">
                            <td class="ps-4 py-3 text-muted fw-semibold">Genre</td>
                            <td class="py-3">{{ user.genre }}</td>
                        </tr>
                        <tr>
                            <td class="ps-4 py-3 text-muted fw-semibold">Role</td>
                            <td class="py-3">
                                {% if user.role == 0 %}Administrateur
                                {% elseif user.role == 1 %}Agriculteur
                                {% else %}Technicien{% endif %}
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-3">
            <a href="{{ path('utilisateur_logout') }}" class="btn btn-outline-danger">
                <i class="ti ti-logout me-1"></i> Deconnexion
            </a>
        </div>
    </div>
</div>
{% else %}
<div class="card border-0 shadow-sm">
    <div class="card-body text-center py-5">
        <i class="ti ti-user-off fs-1 text-muted"></i>
        <p class="text-muted mt-2">Vous devez etre connecte.</p>
        <a href="{{ path('front_login') }}" class="btn btn-success">Se connecter</a>
    </div>
</div>
{% endif %}

{% endblock %}
