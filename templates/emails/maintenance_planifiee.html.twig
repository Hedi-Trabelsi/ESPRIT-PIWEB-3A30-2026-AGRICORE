<!doctype html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Maintenance planifiee</title>
</head>
<body style="margin:0;padding:0;background:#ffffff;font-family:Arial,sans-serif;color:#111827;">
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="background:#ffffff;padding:16px 0;">
    <tr>
        <td style="padding:0 20px;">
            <table role="presentation" width="700" cellspacing="0" cellpadding="0" style="max-width:700px;width:100%;background:#ffffff;overflow:hidden;">
                <tr>
                    <td style="padding:22px 24px 14px 24px;border-bottom:1px solid #eef0f3;">
                        {% if logoCid %}
                            <img src="{{ logoCid }}" alt="AgriCore" width="150" style="display:block;margin:0 0 10px 0;">
                        {% endif %}
                        <p style="margin:0;color:#94a3b8;font-size:12px;letter-spacing:.4px;text-transform:uppercase;">Notification maintenance</p>
                        <h1 style="margin:6px 0 0 0;font-size:24px;line-height:1.25;color:#0f172a;">Maintenance planifiee</h1>
                    </td>
                </tr>
                <tr>
                    <td style="padding:24px;">
                        <p style="margin:0 0 14px 0;font-size:22px;line-height:1.25;color:#111827;font-weight:700;">
                            Bonjour {{ agriculteur and agriculteur.prenom ? agriculteur.prenom : 'cher client' }},
                        </p>
                        <p style="margin:0 0 14px 0;font-size:15px;line-height:1.7;color:#111827;">
                            Nous avons planifie votre maintenance <strong>{{ maintenance.nomMaintenance }}</strong> pour le
                            <strong>{{ tache.datePrevue|date('d/m/Y') }}</strong>.
                        </p>
                        <p style="margin:0 0 18px 0;font-size:15px;line-height:1.7;color:#111827;">
                            Vous trouverez les details complets dans le PDF joint a cet email.
                        </p>

                        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="border-collapse:separate;border-spacing:0;background:#ffffff;border:1px solid #e5e7eb;border-radius:8px;overflow:hidden;">
                            <tr>
                                <td style="padding:12px 14px;font-size:14px;line-height:1.5;color:#111827;">
                                    <span style="display:inline-block;min-width:95px;color:#64748b;">Technicien</span>
                                    <strong>{{ technicien and technicien.prenom ? technicien.prenom : '' }} {{ technicien and technicien.nom ? technicien.nom : 'Non assigne' }}</strong>
                                </td>
                            </tr>
                            <tr>
                                <td style="padding:12px 14px;border-top:1px solid #e5e7eb;font-size:14px;line-height:1.5;color:#111827;">
                                    <span style="display:inline-block;min-width:95px;color:#64748b;">Tache</span>
                                    <strong>{{ tache.nomTache }}</strong>
                                </td>
                            </tr>
                        </table>

                        <p style="margin:22px 0 0 0;font-size:14px;color:#0f172a;line-height:1.7;">
                            Merci de votre confiance,<br>
                            L'equipe AgriCore
                        </p>
                    </td>
                </tr>
            </table>
        </td>
    </tr>
</table>
</body>
</html>
