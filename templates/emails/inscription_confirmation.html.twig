<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Confirmation d'inscription</title>
</head>
<body style="margin:0;padding:0;background:#f0fdf4;font-family:'Segoe UI',Arial,sans-serif;">
<table width="100%" cellpadding="0" cellspacing="0" style="background:#f0fdf4;padding:40px 0;">
  <tr><td align="center">
    <table width="600" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:24px;overflow:hidden;box-shadow:0 8px 40px rgba(0,0,0,.08);">

      <!-- Header -->
      <tr>
        <td style="background:linear-gradient(135deg,#0f172a 0%,#1e3a2f 100%);padding:40px 48px;text-align:center;">
          <div style="display:inline-block;background:rgba(22,163,74,.25);border-radius:16px;padding:14px 20px;margin-bottom:20px;">
            <span style="font-size:2rem;">🌱</span>
          </div>
          <h1 style="color:#ffffff;margin:0;font-size:1.8rem;font-weight:900;letter-spacing:-1px;">AgriCore Events</h1>
          <p style="color:rgba(255,255,255,.6);margin:8px 0 0;font-size:.9rem;">Votre inscription est confirmée</p>
        </td>
      </tr>

      <!-- Body -->
      <tr>
        <td style="padding:48px;">
          <p style="color:#0f172a;font-size:1rem;margin:0 0 8px;">Bonjour <strong>{{ nom }}</strong>,</p>
          <p style="color:#64748b;font-size:.95rem;line-height:1.7;margin:0 0 32px;">
            Votre inscription à l'événement <strong style="color:#16a34a;">{{ evenement }}</strong> a bien été enregistrée. Voici le récapitulatif de votre réservation.
          </p>

          <!-- Event card -->
          <table width="100%" cellpadding="0" cellspacing="0" style="background:#f8fafc;border-radius:16px;border:1px solid #e2e8f0;margin-bottom:32px;">
            <tr>
              <td style="padding:28px 32px;">
                <h2 style="color:#0f172a;margin:0 0 20px;font-size:1.2rem;font-weight:800;">{{ evenement }}</h2>
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="padding:8px 0;border-bottom:1px solid #e2e8f0;">
                      <span style="color:#94a3b8;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">📅 Date</span><br>
                      <span style="color:#0f172a;font-weight:700;font-size:.95rem;">{{ date_debut }} → {{ date_fin }}</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:8px 0;border-bottom:1px solid #e2e8f0;">
                      <span style="color:#94a3b8;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">📍 Lieu</span><br>
                      <span style="color:#0f172a;font-weight:700;font-size:.95rem;">{{ lieu }}</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:8px 0;border-bottom:1px solid #e2e8f0;">
                      <span style="color:#94a3b8;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">🎟 Places réservées</span><br>
                      <span style="color:#0f172a;font-weight:700;font-size:.95rem;">{{ nbr_places }} place{{ nbr_places > 1 ? 's' : '' }}</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:8px 0;border-bottom:1px solid #e2e8f0;">
                      <span style="color:#94a3b8;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">💰 Montant</span><br>
                      <span style="color:#0f172a;font-weight:700;font-size:.95rem;">{{ montant }} DT</span>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:8px 0;">
                      <span style="color:#94a3b8;font-size:.8rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;">🔑 Code d'entrée</span><br>
                      <span style="color:#16a34a;font-weight:900;font-size:1.6rem;letter-spacing:4px;">{{ entry_code }}</span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>

          <p style="color:#64748b;font-size:.85rem;line-height:1.7;margin:0 0 32px;">
            Présentez votre <strong>code d'entrée</strong> le jour de l'événement. Ce code est personnel et non transférable.
          </p>

          <!-- CTA -->
          <table width="100%" cellpadding="0" cellspacing="0">
            <tr>
              <td align="center" style="padding-bottom:20px;">
                <table cellpadding="0" cellspacing="0">
                  <tr>
                    <td align="center" bgcolor="#16a34a" style="border-radius:14px;">
                      <a href="{{ confirm_url }}"
                         target="_blank"
                         style="display:inline-block;background-color:#16a34a;color:#ffffff;text-decoration:none;padding:18px 40px;border-radius:14px;font-weight:800;font-size:16px;font-family:Arial,sans-serif;mso-padding-alt:0;text-align:center;">
                        Confirmer ma participation
                      </a>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
            <tr>
              <td align="center" style="padding-bottom:16px;">
                <p style="color:#94a3b8;font-size:.78rem;font-family:Arial,sans-serif;margin:0;">
                  Ou copiez ce lien dans votre navigateur :<br>
                  <span style="color:#16a34a;word-break:break-all;font-size:.72rem;">{{ confirm_url }}</span>
                </p>
              </td>
            </tr>
            <tr>
              <td align="center">
                <a href="{{ url }}"
                   target="_blank"
                   style="display:inline-block;background-color:#f1f5f9;color:#475569;text-decoration:none;padding:12px 32px;border-radius:12px;font-weight:700;font-size:14px;font-family:Arial,sans-serif;">
                  Voir l'evenement
                </a>
              </td>
            </tr>
          </table>
        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td style="background:#f8fafc;padding:24px 48px;text-align:center;border-top:1px solid #e2e8f0;">
          <p style="color:#94a3b8;font-size:.78rem;margin:0;">© AgriCore — Plateforme agricole intelligente</p>
          <p style="color:#cbd5e1;font-size:.72rem;margin:6px 0 0;">Cet email a été envoyé automatiquement, merci de ne pas y répondre.</p>
        </td>
      </tr>

    </table>
  </td></tr>
</table>
</body>
</html>
