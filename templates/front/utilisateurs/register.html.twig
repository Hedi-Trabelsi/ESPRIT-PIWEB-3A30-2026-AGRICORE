<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Inscription - Agricore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="{{ asset('img/logoo.png') }}" rel="icon">
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@500;600;700&family=Open+Sans:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">
</head>
<body>

<div class="auth-wrapper">

    {# ===== Left Brand Panel ===== #}
    <div class="auth-brand-panel">
        <img src="{{ asset('img/champ-image.jpg') }}" alt="" class="auth-brand-bg">
        <div class="auth-brand-content">
            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-brand-logo">
            <h1>Rejoignez la communaute Agricore</h1>
            <p>Creez votre compte en quelques etapes et commencez a optimiser la gestion de votre exploitation agricole.</p>
            <div class="auth-dots">
                <span></span>
                <span class="active"></span>
                <span></span>
            </div>
        </div>
        <div class="auth-brand-footer">
            &copy; 2026 Agricore. Tous droits reserves.
        </div>
    </div>

    {# ===== Right Form Panel ===== #}
    <div class="auth-form-panel register-scroll">
        <div class="auth-form-inner">

            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-mobile-logo">

            <h2>Creer un compte</h2>
            <p class="auth-desc">Remplissez vos informations pour commencer</p>

            {% for msg in app.flashes('error') %}
                <div class="auth-alert auth-alert-error">
                    <i class="fas fa-exclamation-circle"></i> {{ msg }}
                </div>
            {% endfor %}

            <div class="oauth-buttons">
                <a href="{{ path('oauth_connect', {provider: 'google'}) }}" class="oauth-btn oauth-btn-google" title="S'inscrire avec Google">
                    <i class="fab fa-google"></i> Google
                </a>
                <a href="{{ path('oauth_connect', {provider: 'facebook'}) }}" class="oauth-btn oauth-btn-facebook" title="S'inscrire avec Facebook">
                    <i class="fab fa-facebook-f"></i> Facebook
                </a>
                <a href="{{ path('oauth_connect', {provider: 'github'}) }}" class="oauth-btn oauth-btn-github" title="S'inscrire avec GitHub">
                    <i class="fab fa-github"></i> GitHub
                </a>
            </div>
            <div class="oauth-divider"><span>OU REMPLISSEZ LE FORMULAIRE</span></div>

            <style>
                .oauth-divider { display: flex; align-items: center; margin: 16px 0; color: #888; font-size: 12px; }
                .oauth-divider::before, .oauth-divider::after { content: ""; flex: 1; height: 1px; background: #e0e0e0; }
                .oauth-divider span { padding: 0 12px; }
                .oauth-buttons { display: flex; gap: 10px; margin-bottom: 6px; }
                .oauth-btn { flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 10px 6px; border-radius: 8px; text-decoration: none; font-weight: 600; font-size: 13px; border: 1px solid #e0e0e0; transition: all .2s; color: #333; background: #fff; }
                .oauth-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 10px rgba(0,0,0,.08); }
                .oauth-btn-google:hover { color: #DB4437; border-color: #DB4437; }
                .oauth-btn-facebook:hover { color: #fff; background: #1877F2; border-color: #1877F2; }
                .oauth-btn-github:hover { color: #fff; background: #24292e; border-color: #24292e; }
            </style>

            {# novalidate to show server-side errors as per the PDF workshop #}
            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

                {# --- Role selection (expanded radio) --- #}
                <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;display:block;">Vous etes</label>
                <div class="role-selector">
                    {% for child in form.role %}
                        <label class="role-card">
                            {{ form_widget(child) }}
                            <div class="role-card-body">
                                {% if child.vars.value == '1' %}
                                    <div class="role-icon"><i class="fas fa-seedling"></i></div>
                                    <div>
                                        <div class="role-name">Agriculteur</div>
                                        <div class="role-hint">Gerer ma ferme</div>
                                    </div>
                                {% else %}
                                    <div class="role-icon"><i class="fas fa-tools"></i></div>
                                    <div>
                                        <div class="role-name">Technicien</div>
                                        <div class="role-hint">Support technique</div>
                                    </div>
                                {% endif %}
                            </div>
                        </label>
                    {% endfor %}
                </div>
                <div class="field-error">{{ form_errors(form.role) }}</div>

                {# --- Nom & Prenom --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.nom.vars.id }}">Nom</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-user fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.nom) }}</div>
                    </div>
                    <div class="field">
                        <label for="{{ form.prenom.vars.id }}">Prenom</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-user fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.prenom) }}</div>
                    </div>
                </div>

                {# --- Email with validation --- #}
                <div class="field">
                    <label for="{{ form.email.vars.id }}">Adresse email</label>
                    <div class="field-input-wrap email-validate-wrap">
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-envelope fi-icon"></i>
                        <span class="email-status" id="emailStatus"></span>
                    </div>
                    <div class="email-status-msg" id="emailMsg"></div>
                    <div class="field-error">{{ form_errors(form.email) }}</div>
                </div>

                {# --- Password (RepeatedType: first + second) --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.password.first.vars.id }}">Mot de passe</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.password.first, {'attr': {'class': 'form-control', 'oninput': 'checkStrength(this.value)'}}) }}
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('{{ form.password.first.vars.id }}',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        {# Password strength meter #}
                        <div class="pw-strength-wrap">
                            <div class="pw-strength-bar"><div class="pw-strength-fill" id="pwFill"></div></div>
                            <span class="pw-strength-text" id="pwText"></span>
                        </div>
                        <div class="pw-criteria" id="pwCriteria">
                            <div class="pw-rule" id="ruleLen"><i class="fas fa-circle"></i> Min. 6 caracteres</div>
                            <div class="pw-rule" id="ruleLower"><i class="fas fa-circle"></i> Une minuscule</div>
                            <div class="pw-rule" id="ruleUpper"><i class="fas fa-circle"></i> Une majuscule</div>
                            <div class="pw-rule" id="ruleNum"><i class="fas fa-circle"></i> Un chiffre</div>
                        </div>
                    </div>
                    <div class="field">
                        <label for="{{ form.password.second.vars.id }}">Confirmer</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.password.second, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('{{ form.password.second.vars.id }}',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="field-error">{{ form_errors(form.password.first) }}{{ form_errors(form.password) }}</div>

                {# --- Genre & Date de naissance --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.genre.vars.id }}">Genre</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.genre, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-venus-mars fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.genre) }}</div>
                    </div>
                    <div class="field">
                        <label for="{{ form.date.vars.id }}">Date de naissance <span class="field-optional">(optionnel)</span></label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-calendar-alt fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.date) }}</div>
                    </div>
                </div>

                {# --- Telephone --- #}
                <div class="field">
                    <label for="{{ form.numeroT.vars.id }}">Numero de telephone</label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.numeroT, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-phone-alt fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.numeroT) }}</div>
                </div>

                {# --- Adresse --- #}
                <div class="field">
                    <label for="{{ form.adresse.vars.id }}">Adresse</label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.adresse, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-map-marker-alt fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.adresse) }}</div>
                </div>

                {# --- Image --- #}
                <div class="field">
                    <label for="{{ form.imageFile.vars.id }}">Photo de profil <span class="field-optional">(optionnel)</span></label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-camera fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.imageFile) }}</div>
                </div>

                {# --- hCaptcha --- #}
                <div class="field">
                    <label>Verification de securite</label>
                    {{ form_widget(form.captcha) }}
                    <div class="field-error">{{ form_errors(form.captcha) }}</div>
                </div>

                <button type="submit" class="auth-submit">
                    Creer mon compte <i class="fas fa-arrow-right"></i>
                </button>

            {{ form_end(form) }}

            <div class="auth-footer-link">
                Deja inscrit ? <a href="{{ path('front_login') }}">Se connecter</a>
            </div>

        </div>
    </div>

</div>

<script>
function togglePw(id, btn) {
    var f = document.getElementById(id),
        i = btn.querySelector('i');
    if (f.type === 'password') {
        f.type = 'text';
        i.className = 'fas fa-eye-slash';
    } else {
        f.type = 'password';
        i.className = 'fas fa-eye';
    }
}

function checkStrength(pw) {
    var fill = document.getElementById('pwFill');
    var text = document.getElementById('pwText');
    var score = 0;

    var hasLen = pw.length >= 6;
    var hasLower = /[a-z]/.test(pw);
    var hasUpper = /[A-Z]/.test(pw);
    var hasNum = /[0-9]/.test(pw);
    var hasSpecial = /[^a-zA-Z0-9]/.test(pw);

    setRule('ruleLen', hasLen);
    setRule('ruleLower', hasLower);
    setRule('ruleUpper', hasUpper);
    setRule('ruleNum', hasNum);

    if (hasLen) score++;
    if (hasLower) score++;
    if (hasUpper) score++;
    if (hasNum) score++;
    if (hasSpecial) score++;

    if (pw.length === 0) {
        fill.style.width = '0%';
        fill.className = 'pw-strength-fill';
        text.textContent = '';
        return;
    }

    var levels = [
        { w: '20%', c: 'pw-str-weak',   t: 'Tres faible' },
        { w: '40%', c: 'pw-str-weak',   t: 'Faible' },
        { w: '60%', c: 'pw-str-medium', t: 'Moyen' },
        { w: '80%', c: 'pw-str-good',   t: 'Fort' },
        { w: '100%',c: 'pw-str-strong', t: 'Tres fort' }
    ];

    var lvl = levels[Math.min(score, 4)];
    fill.style.width = lvl.w;
    fill.className = 'pw-strength-fill ' + lvl.c;
    text.textContent = lvl.t;
    text.className = 'pw-strength-text ' + lvl.c;
}

function setRule(id, pass) {
    var el = document.getElementById(id);
    if (pass) {
        el.classList.add('pw-rule-pass');
        el.querySelector('i').className = 'fas fa-check-circle';
    } else {
        el.classList.remove('pw-rule-pass');
        el.querySelector('i').className = 'fas fa-circle';
    }
}

// ====== Email Validation (Abstract API) ======
var emailTimer = null;
var emailField = document.getElementById('{{ form.email.vars.id }}');
if (emailField) {
    emailField.addEventListener('blur', function() {
        var email = this.value.trim();
        var status = document.getElementById('emailStatus');
        var msg = document.getElementById('emailMsg');
        if (!email || email.indexOf('@') === -1) {
            status.innerHTML = '';
            msg.innerHTML = '';
            return;
        }
        status.innerHTML = '<i class="fas fa-spinner fa-spin" style="color:#9ca3af;"></i>';
        msg.innerHTML = '<span style="color:#9ca3af;">Verification en cours...</span>';

        var formData = new FormData();
        formData.append('email', email);

        fetch('{{ path("api_validate_email") }}', { method: 'POST', body: formData })
            .then(function(r) { return r.json(); })
            .then(function(data) {
                if (data.status === 'valid') {
                    status.innerHTML = '<i class="fas fa-check-circle" style="color:#16a34a;"></i>';
                    msg.innerHTML = '<span class="ev-valid"><i class="fas fa-check-circle"></i> ' + data.message + '</span>';
                } else if (data.status === 'disposable') {
                    status.innerHTML = '<i class="fas fa-ban" style="color:#dc2626;"></i>';
                    msg.innerHTML = '<span class="ev-invalid"><i class="fas fa-ban"></i> ' + data.message + '</span>';
                } else if (data.status === 'invalid') {
                    status.innerHTML = '<i class="fas fa-times-circle" style="color:#dc2626;"></i>';
                    msg.innerHTML = '<span class="ev-invalid"><i class="fas fa-times-circle"></i> ' + data.message + '</span>';
                } else if (data.status === 'skip') {
                    status.innerHTML = '';
                    msg.innerHTML = '';
                } else {
                    status.innerHTML = '<i class="fas fa-question-circle" style="color:#f59e0b;"></i>';
                    msg.innerHTML = '<span class="ev-warning"><i class="fas fa-question-circle"></i> ' + data.message + '</span>';
                }
            })
            .catch(function() {
                status.innerHTML = '';
                msg.innerHTML = '';
            });
    });
}
</script>
</body>
</html>
