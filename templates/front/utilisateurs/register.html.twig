<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Inscription - Agricore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="{{ asset('img/logoo.png') }}" rel="icon">
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@500;600;700&family=Open+Sans:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">
</head>
<body>

<div class="auth-wrapper">

    {# ===== Left Brand Panel ===== #}
    <div class="auth-brand-panel">
        <img src="{{ asset('img/champ-image.jpg') }}" alt="" class="auth-brand-bg">
        <div class="auth-brand-content">
            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-brand-logo">
            <h1>Rejoignez la communaute Agricore</h1>
            <p>Creez votre compte en quelques etapes et commencez a optimiser la gestion de votre exploitation agricole.</p>
            <div class="auth-dots">
                <span></span>
                <span class="active"></span>
                <span></span>
            </div>
        </div>
        <div class="auth-brand-footer">
            &copy; 2026 Agricore. Tous droits reserves.
        </div>
    </div>

    {# ===== Right Form Panel ===== #}
    <div class="auth-form-panel register-scroll">
        <div class="auth-form-inner">

            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-mobile-logo">

            <h2>Creer un compte</h2>
            <p class="auth-desc">Remplissez vos informations pour commencer</p>

            {% for msg in app.flashes('error') %}
                <div class="auth-alert auth-alert-error">
                    <i class="fas fa-exclamation-circle"></i> {{ msg }}
                </div>
            {% endfor %}

            {# novalidate to show server-side errors as per the PDF workshop #}
            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'enctype': 'multipart/form-data'}}) }}

                {# --- Role selection (expanded radio) --- #}
                <label style="font-size:13px;font-weight:600;color:#374151;margin-bottom:7px;display:block;">Vous etes</label>
                <div class="role-selector">
                    {% for child in form.role %}
                        <label class="role-card">
                            {{ form_widget(child) }}
                            <div class="role-card-body">
                                {% if child.vars.value == '1' %}
                                    <div class="role-icon"><i class="fas fa-seedling"></i></div>
                                    <div>
                                        <div class="role-name">Agriculteur</div>
                                        <div class="role-hint">Gerer ma ferme</div>
                                    </div>
                                {% else %}
                                    <div class="role-icon"><i class="fas fa-tools"></i></div>
                                    <div>
                                        <div class="role-name">Technicien</div>
                                        <div class="role-hint">Support technique</div>
                                    </div>
                                {% endif %}
                            </div>
                        </label>
                    {% endfor %}
                </div>
                <div class="field-error">{{ form_errors(form.role) }}</div>

                {# --- Nom & Prenom --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.nom.vars.id }}">Nom</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.nom, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-user fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.nom) }}</div>
                    </div>
                    <div class="field">
                        <label for="{{ form.prenom.vars.id }}">Prenom</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.prenom, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-user fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.prenom) }}</div>
                    </div>
                </div>

                {# --- Email --- #}
                <div class="field">
                    <label for="{{ form.email.vars.id }}">Adresse email</label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.email, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-envelope fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.email) }}</div>
                </div>

                {# --- Password (RepeatedType: first + second) --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.password.first.vars.id }}">Mot de passe</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.password.first, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('{{ form.password.first.vars.id }}',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                    <div class="field">
                        <label for="{{ form.password.second.vars.id }}">Confirmer</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.password.second, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('{{ form.password.second.vars.id }}',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>
                </div>
                <div class="field-error">{{ form_errors(form.password.first) }}{{ form_errors(form.password) }}</div>

                {# --- Genre & Date de naissance --- #}
                <div class="field-row">
                    <div class="field">
                        <label for="{{ form.genre.vars.id }}">Genre</label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.genre, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-venus-mars fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.genre) }}</div>
                    </div>
                    <div class="field">
                        <label for="{{ form.date.vars.id }}">Date de naissance <span class="field-optional">(optionnel)</span></label>
                        <div class="field-input-wrap">
                            {{ form_widget(form.date, {'attr': {'class': 'form-control'}}) }}
                            <i class="fas fa-calendar-alt fi-icon"></i>
                        </div>
                        <div class="field-error">{{ form_errors(form.date) }}</div>
                    </div>
                </div>

                {# --- Telephone --- #}
                <div class="field">
                    <label for="{{ form.numeroT.vars.id }}">Numero de telephone</label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.numeroT, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-phone-alt fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.numeroT) }}</div>
                </div>

                {# --- Adresse --- #}
                <div class="field">
                    <label for="{{ form.adresse.vars.id }}">Adresse</label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.adresse, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-map-marker-alt fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.adresse) }}</div>
                </div>

                {# --- Image --- #}
                <div class="field">
                    <label for="{{ form.imageFile.vars.id }}">Photo de profil <span class="field-optional">(optionnel)</span></label>
                    <div class="field-input-wrap">
                        {{ form_widget(form.imageFile, {'attr': {'class': 'form-control'}}) }}
                        <i class="fas fa-camera fi-icon"></i>
                    </div>
                    <div class="field-error">{{ form_errors(form.imageFile) }}</div>
                </div>

                <button type="submit" class="auth-submit">
                    Creer mon compte <i class="fas fa-arrow-right"></i>
                </button>

            {{ form_end(form) }}

            <div class="auth-footer-link">
                Deja inscrit ? <a href="{{ path('front_login') }}">Se connecter</a>
            </div>

        </div>
    </div>

</div>

<script>
function togglePw(id, btn) {
    var f = document.getElementById(id),
        i = btn.querySelector('i');
    if (f.type === 'password') {
        f.type = 'text';
        i.className = 'fas fa-eye-slash';
    } else {
        f.type = 'password';
        i.className = 'fas fa-eye';
    }
}
</script>
</body>
</html>
