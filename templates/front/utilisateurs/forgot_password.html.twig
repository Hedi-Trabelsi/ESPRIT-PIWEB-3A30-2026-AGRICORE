<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8">
    <title>Mot de passe oublie - Agricore</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link href="{{ asset('img/logoo.png') }}" rel="icon">
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@500;600;700&family=Open+Sans:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="{{ asset('css/bootstrap.min.css') }}" rel="stylesheet">
    <link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">
    {% if step == 'verify' %}
    <script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
    {% endif %}
</head>
<body>

<div class="auth-wrapper">

    {# ===== Left Brand Panel ===== #}
    <div class="auth-brand-panel">
        <img src="{{ asset('img/champ-image.jpg') }}" alt="" class="auth-brand-bg">
        <div class="auth-brand-content">
            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-brand-logo">
            {% if step == 'email' %}
                <h1>Reinitialiser votre mot de passe</h1>
                <p>Entrez votre adresse email pour commencer la verification via Google Authenticator.</p>
            {% elseif step == 'verify' %}
                <h1>Verification Authenticator</h1>
                <p>Scannez le QR code avec Google Authenticator puis entrez le code a 6 chiffres pour verifier votre identite.</p>
            {% elseif step == 'reset' %}
                <h1>Nouveau mot de passe</h1>
                <p>Choisissez un nouveau mot de passe securise pour votre compte Agricore.</p>
            {% endif %}
            <div class="auth-dots">
                <span></span>
                <span></span>
                <span class="active"></span>
            </div>
        </div>
        <div class="auth-brand-footer">
            &copy; 2026 Agricore. Tous droits reserves.
        </div>
    </div>

    {# ===== Right Form Panel ===== #}
    <div class="auth-form-panel">
        <div class="auth-form-inner">

            <img src="{{ asset('img/logo.png') }}" alt="Agricore" class="auth-mobile-logo">

            {# --- Step Indicator --- #}
            <div class="fp-steps">
                <div class="fp-step {% if step == 'email' %}fp-step-active{% elseif step in ['verify','reset'] %}fp-step-done{% endif %}">
                    <div class="fp-step-circle">{% if step in ['verify','reset'] %}<i class="fas fa-check"></i>{% else %}1{% endif %}</div>
                    <span>Email</span>
                </div>
                <div class="fp-step-line {% if step in ['verify','reset'] %}fp-step-line-active{% endif %}"></div>
                <div class="fp-step {% if step == 'verify' %}fp-step-active{% elseif step == 'reset' %}fp-step-done{% endif %}">
                    <div class="fp-step-circle">{% if step == 'reset' %}<i class="fas fa-check"></i>{% else %}2{% endif %}</div>
                    <span>Verifier</span>
                </div>
                <div class="fp-step-line {% if step == 'reset' %}fp-step-line-active{% endif %}"></div>
                <div class="fp-step {% if step == 'reset' %}fp-step-active{% endif %}">
                    <div class="fp-step-circle">3</div>
                    <span>Reinitialiser</span>
                </div>
            </div>

            {# Flash messages #}
            {% for msg in app.flashes('error') %}
                <div class="auth-alert auth-alert-error">
                    <i class="fas fa-exclamation-circle"></i> {{ msg }}
                </div>
            {% endfor %}
            {% for msg in app.flashes('success') %}
                <div class="auth-alert auth-alert-success">
                    <i class="fas fa-check-circle"></i> {{ msg }}
                </div>
            {% endfor %}

            {# ======================== STEP 1: EMAIL ======================== #}
            {% if step == 'email' %}
                <h2>Mot de passe oublie ?</h2>
                <p class="auth-desc">Entrez votre email pour commencer la verification</p>

                <form method="post">
                    <input type="hidden" name="step" value="email">
                    <div class="field">
                        <label for="email">Adresse email</label>
                        <div class="field-input-wrap">
                            <input type="email" id="email" name="email" placeholder="nom@exemple.com" required>
                            <i class="fas fa-envelope fi-icon"></i>
                        </div>
                    </div>

                    <button type="submit" class="auth-submit">
                        Continuer <i class="fas fa-arrow-right"></i>
                    </button>
                </form>

            {# ======================== STEP 2: VERIFY ======================== #}
            {% elseif step == 'verify' %}
                <h2>Verification Authenticator</h2>
                <p class="auth-desc">Scannez ce QR code avec Google Authenticator</p>

                <div class="fp-qr-wrap">
                    <div id="qrcode"></div>
                </div>

                <ol class="fp-instructions">
                    <li>Ouvrez <strong>Google Authenticator</strong> sur votre telephone</li>
                    <li>Appuyez sur <strong>+</strong> puis <strong>Scanner un QR code</strong></li>
                    <li>Scannez le QR code ci-dessus</li>
                    <li>Entrez le code a 6 chiffres affiche dans l'application</li>
                </ol>

                <form method="post">
                    <input type="hidden" name="step" value="verify">
                    <div class="field">
                        <label for="totp_code">Code a 6 chiffres</label>
                        <div class="field-input-wrap">
                            <input type="text" id="totp_code" name="totp_code" class="fp-code-input" placeholder="000000" maxlength="6" pattern="[0-9]{6}" inputmode="numeric" autocomplete="one-time-code" required>
                            <i class="fas fa-shield-alt fi-icon"></i>
                        </div>
                    </div>

                    <button type="submit" class="auth-submit">
                        Verifier le code <i class="fas fa-check"></i>
                    </button>
                </form>

            {# ======================== STEP 3: RESET ======================== #}
            {% elseif step == 'reset' %}
                <h2>Nouveau mot de passe</h2>
                <p class="auth-desc">Choisissez un mot de passe securise</p>

                <form method="post">
                    <input type="hidden" name="step" value="reset">

                    <div class="field">
                        <label for="password">Nouveau mot de passe</label>
                        <div class="field-input-wrap">
                            <input type="password" id="password" name="password" placeholder="Min. 6 caracteres" required oninput="checkStrength(this.value)">
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('password',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                        <div class="pw-strength-wrap">
                            <div class="pw-strength-bar"><div class="pw-strength-fill" id="pwFill"></div></div>
                            <span class="pw-strength-text" id="pwText"></span>
                        </div>
                        <div class="pw-criteria" id="pwCriteria">
                            <div class="pw-rule" id="ruleLen"><i class="fas fa-circle"></i> Min. 6 caracteres</div>
                            <div class="pw-rule" id="ruleLower"><i class="fas fa-circle"></i> Une minuscule</div>
                            <div class="pw-rule" id="ruleUpper"><i class="fas fa-circle"></i> Une majuscule</div>
                            <div class="pw-rule" id="ruleNum"><i class="fas fa-circle"></i> Un chiffre</div>
                        </div>
                    </div>

                    <div class="field">
                        <label for="password_confirm">Confirmer le mot de passe</label>
                        <div class="field-input-wrap">
                            <input type="password" id="password_confirm" name="password_confirm" placeholder="Retapez le mot de passe" required>
                            <i class="fas fa-lock fi-icon"></i>
                            <button type="button" class="field-toggle" onclick="togglePw('password_confirm',this)">
                                <i class="fas fa-eye"></i>
                            </button>
                        </div>
                    </div>

                    <button type="submit" class="auth-submit">
                        Reinitialiser le mot de passe <i class="fas fa-lock"></i>
                    </button>
                </form>
            {% endif %}

            <div class="auth-footer-link">
                <a href="{{ path('front_login') }}"><i class="fas fa-arrow-left"></i> Retour a la connexion</a>
            </div>

        </div>
    </div>

</div>

<script>
function togglePw(id, btn) {
    var f = document.getElementById(id),
        i = btn.querySelector('i');
    if (f.type === 'password') {
        f.type = 'text';
        i.className = 'fas fa-eye-slash';
    } else {
        f.type = 'password';
        i.className = 'fas fa-eye';
    }
}

function checkStrength(pw) {
    var fill = document.getElementById('pwFill');
    var text = document.getElementById('pwText');
    if (!fill) return;
    var score = 0;
    var hasLen = pw.length >= 6;
    var hasLower = /[a-z]/.test(pw);
    var hasUpper = /[A-Z]/.test(pw);
    var hasNum = /[0-9]/.test(pw);
    var hasSpecial = /[^a-zA-Z0-9]/.test(pw);
    setRule('ruleLen', hasLen);
    setRule('ruleLower', hasLower);
    setRule('ruleUpper', hasUpper);
    setRule('ruleNum', hasNum);
    if (hasLen) score++;
    if (hasLower) score++;
    if (hasUpper) score++;
    if (hasNum) score++;
    if (hasSpecial) score++;
    if (pw.length === 0) { fill.style.width = '0%'; fill.className = 'pw-strength-fill'; text.textContent = ''; return; }
    var levels = [
        { w: '20%', c: 'pw-str-weak', t: 'Tres faible' },
        { w: '40%', c: 'pw-str-weak', t: 'Faible' },
        { w: '60%', c: 'pw-str-medium', t: 'Moyen' },
        { w: '80%', c: 'pw-str-good', t: 'Fort' },
        { w: '100%', c: 'pw-str-strong', t: 'Tres fort' }
    ];
    var lvl = levels[Math.min(score, 4)];
    fill.style.width = lvl.w;
    fill.className = 'pw-strength-fill ' + lvl.c;
    text.textContent = lvl.t;
    text.className = 'pw-strength-text ' + lvl.c;
}

function setRule(id, pass) {
    var el = document.getElementById(id);
    if (!el) return;
    if (pass) { el.classList.add('pw-rule-pass'); el.querySelector('i').className = 'fas fa-check-circle'; }
    else { el.classList.remove('pw-rule-pass'); el.querySelector('i').className = 'fas fa-circle'; }
}

{% if step == 'verify' and provisioningUri is defined %}
document.addEventListener('DOMContentLoaded', function() {
    new QRCode(document.getElementById("qrcode"), {
        text: "{{ provisioningUri|e('js') }}",
        width: 200,
        height: 200,
        colorDark: "#0F4229",
        colorLight: "#ffffff",
        correctLevel: QRCode.CorrectLevel.H
    });
});
{% endif %}
</script>
</body>
</html>
