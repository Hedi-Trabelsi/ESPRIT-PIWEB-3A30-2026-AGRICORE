{% extends 'front/base_front.html.twig' %}

{% block title %}Mon Profil - Agricore{% endblock %}

{% block body %}

<link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

{# ===== Hero Section ===== #}
<div class="profile-hero">
    <div class="container">
        {% if app.session.get('user') and app.session.get('user').image %}
            <img src="data:image/jpeg;base64,{{ app.session.get('user').image }}" alt="Photo" class="profile-hero-avatar">
        {% else %}
            <img src="{{ asset('img/profile.webp') }}" alt="Photo" class="profile-hero-avatar">
        {% endif %}

        {% if app.session.get('user') %}
            <h2>{{ app.session.get('user').prenom }} {{ app.session.get('user').nom }}</h2>
            <p class="profile-hero-email"><i class="fas fa-envelope me-1"></i> {{ app.session.get('user').email }}</p>
            {% if app.session.get('user').role == 0 %}
                <span class="profile-hero-role role-admin"><i class="fas fa-user-shield me-1"></i> Administrateur</span>
            {% elseif app.session.get('user').role == 1 %}
                <span class="profile-hero-role role-agriculteur"><i class="fas fa-seedling me-1"></i> Agriculteur</span>
            {% else %}
                <span class="profile-hero-role role-technicien"><i class="fas fa-tools me-1"></i> Technicien</span>
            {% endif %}
        {% else %}
            <h2>Utilisateur</h2>
            <p class="profile-hero-email">Veuillez vous connecter</p>
        {% endif %}
    </div>
</div>

{# ===== Profile Content ===== #}
<div class="container profile-content">

    {% for msg in app.flashes('success') %}
        <div class="auth-alert auth-alert-success mb-3">
            <i class="fas fa-check-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {% if app.session.get('user') %}
    <div class="row g-4">

        {# --- Main Info --- #}
        <div class="col-lg-8">
            <div class="p-card">
                <div class="p-card-head">
                    <i class="fas fa-id-card"></i>
                    <h4>Informations personnelles</h4>
                </div>
                <div class="p-card-body">

                    <div class="info-row">
                        <div class="info-icon green"><i class="fas fa-user"></i></div>
                        <div class="info-text">
                            <div class="info-label">Nom complet</div>
                            <div class="info-value">{{ app.session.get('user').prenom }} {{ app.session.get('user').nom }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon blue"><i class="fas fa-envelope"></i></div>
                        <div class="info-text">
                            <div class="info-label">Email</div>
                            <div class="info-value">{{ app.session.get('user').email }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon amber"><i class="fas fa-phone-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Telephone</div>
                            <div class="info-value">{{ app.session.get('user').numeroT }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon purple"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Adresse</div>
                            <div class="info-value">{{ app.session.get('user').adresse }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon rose"><i class="fas fa-calendar-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Date de naissance</div>
                            <div class="info-value">
                                {% if app.session.get('user').date %}
                                    {{ app.session.get('user').date|date('d/m/Y') }}
                                {% else %}
                                    Non renseignee
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon teal"><i class="fas fa-venus-mars"></i></div>
                        <div class="info-text">
                            <div class="info-label">Genre</div>
                            <div class="info-value">{{ app.session.get('user').genre }}</div>
                        </div>
                    </div>


                </div>
            </div>

            <div class="profile-actions">
                <a href="{{ path('app_profile_edit') }}" class="pbtn pbtn-green">
                    <i class="fas fa-edit"></i> Modifier mon profil
                </a>
                <a href="{{ path('utilisateur_logout') }}" class="pbtn pbtn-outline">
                    <i class="fas fa-sign-out-alt"></i> Deconnexion
                </a>
            </div>
        </div>

        {# --- Sidebar --- #}
        <div class="col-lg-4">

            <div class="sidebar-mini-card">
                <h5><i class="fas fa-info-circle me-2"></i> Apercu du compte</h5>
                <div class="sidebar-item">
                    <i class="fas fa-user-tag"></i>
                    <span>Role : <strong>{% if app.session.get('user').role == 0 %}Administrateur{% elseif app.session.get('user').role == 1 %}Agriculteur{% else %}Technicien{% endif %}</strong></span>
                </div>
                <div class="sidebar-item">
                    <i class="fas fa-check-double"></i>
                    <span>Profil : <strong>{% if app.session.get('user').profileComplete %}Complet{% else %}Incomplet{% endif %}</strong></span>
                </div>
                <div class="sidebar-item">
                    <i class="fas fa-venus-mars"></i>
                    <span>Genre : <strong>{{ app.session.get('user').genre }}</strong></span>
                </div>
            </div>

            {# Weather Widget (OpenWeatherMap API) #}
            <div class="sidebar-mini-card">
                <h5><i class="fas fa-cloud-sun me-2"></i> Meteo locale</h5>
                {% if weatherData %}
                <div class="weather-content">
                    <div class="weather-main">
                        <img src="https://openweathermap.org/img/wn/{{ weatherData.icon }}@2x.png" alt="{{ weatherData.desc }}" class="weather-icon">
                        <div>
                            <div class="weather-temp">{{ weatherData.temp }}°C</div>
                            <div class="weather-desc">{{ weatherData.desc }}</div>
                        </div>
                    </div>
                    <div class="weather-details">
                        <div class="weather-detail"><i class="fas fa-tint"></i> {{ weatherData.humidity }}%</div>
                        <div class="weather-detail"><i class="fas fa-wind"></i> {{ weatherData.wind }} km/h</div>
                        <div class="weather-detail"><i class="fas fa-eye"></i> {{ weatherData.visibility }} km</div>
                    </div>
                    <div class="weather-city"><i class="fas fa-map-marker-alt"></i> {{ weatherData.city }}</div>
                </div>
                {% else %}
                <div class="weather-error"><i class="fas fa-exclamation-triangle"></i> Meteo indisponible</div>
                {% endif %}
            </div>

            {# Map Widget (LocationIQ + Leaflet) #}
            {% if geoData %}
            <div class="sidebar-mini-card" style="padding-bottom:16px;">
                <h5><i class="fas fa-map-marked-alt me-2"></i> Ma localisation</h5>
                <div id="profileMap" class="profile-map"></div>
                <p style="font-size:11px;color:#6b7280;margin-top:10px;text-align:center;line-height:1.4;"><i class="fas fa-map-pin" style="color:#348E38;"></i> {{ geoData.display_name }}</p>
            </div>
            {% else %}
            <div class="sidebar-mini-card">
                <h5><i class="fas fa-map-marked-alt me-2"></i> Ma localisation</h5>
                <div class="weather-error"><i class="fas fa-map"></i> Localisation indisponible</div>
            </div>
            {% endif %}

            <div class="sidebar-mini-card">
                <h5><i class="fas fa-chart-pie me-2"></i> Activite</h5>
                <div class="stats-grid">
                    <div class="stat-box">
                        <i class="fas fa-tractor"></i>
                        <div class="stat-label">Equipements</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-wrench"></i>
                        <div class="stat-label">Maintenances</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-coins"></i>
                        <div class="stat-label">Ventes</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-receipt"></i>
                        <div class="stat-label">Depenses</div>
                    </div>
                </div>
            </div>

            {# QR Code vCard #}
            <div class="sidebar-mini-card text-center">
                <h5><i class="fas fa-qrcode me-2"></i> Ma carte de contact</h5>
                <p style="font-size:12px;color:#6b7280;margin-bottom:14px;">Scannez ce QR code pour ajouter mes coordonnees a vos contacts</p>
                <div class="profile-qr-wrap">
                    <img src="{{ path('app_profile_qrcode') }}" alt="QR Code vCard" class="profile-qr-img">
                </div>
                <a href="{{ path('app_profile_qrcode') }}" download="contact_{{ app.session.get('user').prenom }}_{{ app.session.get('user').nom }}.svg" class="pbtn pbtn-green" style="display:inline-flex;flex:none;padding:8px 20px;font-size:13px;margin-top:14px;">
                    <i class="fas fa-download"></i> Telecharger
                </a>
            </div>

        </div>

    </div>
    {% else %}
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="p-card">
                    <div class="p-card-body profile-empty">
                        <i class="fas fa-user-lock"></i>
                        <p>Vous devez etre connecte pour acceder a votre profil.</p>
                        <a href="{{ path('front_login') }}" class="pbtn pbtn-green" style="display:inline-flex;flex:none;padding:13px 32px;">
                            <i class="fas fa-sign-in-alt"></i> Se connecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

{% if geoData is defined and geoData %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var lat = {{ geoData.lat }};
    var lon = {{ geoData.lon }};
    var map = L.map('profileMap', { scrollWheelZoom: false }).setView([lat, lon], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap'
    }).addTo(map);
    var greenIcon = L.divIcon({
        html: '<i class="fas fa-map-marker-alt" style="font-size:28px;color:#348E38;text-shadow:0 2px 4px rgba(0,0,0,.3);"></i>',
        iconSize: [28, 36],
        iconAnchor: [14, 36],
        className: ''
    });
    L.marker([lat, lon], { icon: greenIcon }).addTo(map);
    setTimeout(function() { map.invalidateSize(); }, 500);
});
</script>
{% endif %}

{% endblock %}
