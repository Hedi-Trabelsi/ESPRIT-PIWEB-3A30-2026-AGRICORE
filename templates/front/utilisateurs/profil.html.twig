{% extends 'front/base_front.html.twig' %}

{% block title %}Mon Profil - Agricore{% endblock %}

{% block body %}

<link href="{{ asset('css/utilisateur/utilisateur.css') }}" rel="stylesheet">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

{# ===== Hero Section ===== #}
<div class="profile-hero">
    <div class="container">
        {% if app.session.get('user') and app.session.get('user').image %}
            <img src="data:image/jpeg;base64,{{ app.session.get('user').image }}" alt="Photo" class="profile-hero-avatar">
        {% else %}
            <img src="{{ asset('img/profile.webp') }}" alt="Photo" class="profile-hero-avatar">
        {% endif %}

        {% if app.session.get('user') %}
            <h2>{{ app.session.get('user').prenom }} {{ app.session.get('user').nom }}</h2>
            <p class="profile-hero-email"><i class="fas fa-envelope me-1"></i> {{ app.session.get('user').email }}</p>
            {% if app.session.get('user').role == 0 %}
                <span class="profile-hero-role role-admin"><i class="fas fa-user-shield me-1"></i> Administrateur</span>
            {% elseif app.session.get('user').role == 1 %}
                <span class="profile-hero-role role-agriculteur"><i class="fas fa-seedling me-1"></i> Agriculteur</span>
            {% else %}
                <span class="profile-hero-role role-technicien"><i class="fas fa-tools me-1"></i> Technicien</span>
            {% endif %}
        {% else %}
            <h2>Utilisateur</h2>
            <p class="profile-hero-email">Veuillez vous connecter</p>
        {% endif %}
    </div>
</div>

{# ===== Profile Content ===== #}
<div class="container profile-content">

    {% for msg in app.flashes('success') %}
        <div class="auth-alert auth-alert-success mb-3">
            <i class="fas fa-check-circle"></i> {{ msg }}
        </div>
    {% endfor %}

    {% if app.session.get('user') %}
    <div class="row g-4">

        {# --- Main Info --- #}
        <div class="col-lg-8">
            <div class="p-card">
                <div class="p-card-head">
                    <i class="fas fa-id-card"></i>
                    <h4>Informations personnelles</h4>
                </div>
                <div class="p-card-body">

                    <div class="info-row">
                        <div class="info-icon green"><i class="fas fa-user"></i></div>
                        <div class="info-text">
                            <div class="info-label">Nom complet</div>
                            <div class="info-value">{{ app.session.get('user').prenom }} {{ app.session.get('user').nom }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon blue"><i class="fas fa-envelope"></i></div>
                        <div class="info-text">
                            <div class="info-label">Email</div>
                            <div class="info-value">{{ app.session.get('user').email }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon amber"><i class="fas fa-phone-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Telephone</div>
                            <div class="info-value">{{ app.session.get('user').numeroT }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon purple"><i class="fas fa-map-marker-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Adresse</div>
                            <div class="info-value">{{ app.session.get('user').adresse }}</div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon rose"><i class="fas fa-calendar-alt"></i></div>
                        <div class="info-text">
                            <div class="info-label">Date de naissance</div>
                            <div class="info-value">
                                {% if app.session.get('user').date %}
                                    {{ app.session.get('user').date|date('d/m/Y') }}
                                {% else %}
                                    Non renseignee
                                {% endif %}
                            </div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon teal"><i class="fas fa-venus-mars"></i></div>
                        <div class="info-text">
                            <div class="info-label">Genre</div>
                            <div class="info-value">{{ app.session.get('user').genre }}</div>
                        </div>
                    </div>


                </div>
            </div>

            <div class="profile-actions">
                <a href="{{ path('app_profile_edit') }}" class="pbtn pbtn-green">
                    <i class="fas fa-edit"></i> Modifier mon profil
                </a>
                <a href="{{ path('utilisateur_logout') }}" class="pbtn pbtn-outline">
                    <i class="fas fa-sign-out-alt"></i> Deconnexion
                </a>
            </div>
        </div>

        {# --- Sidebar --- #}
        <div class="col-lg-4">

            <div class="sidebar-mini-card">
                <h5><i class="fas fa-info-circle me-2"></i> Apercu du compte</h5>
                <div class="sidebar-item">
                    <i class="fas fa-user-tag"></i>
                    <span>Role : <strong>{% if app.session.get('user').role == 0 %}Administrateur{% elseif app.session.get('user').role == 1 %}Agriculteur{% else %}Technicien{% endif %}</strong></span>
                </div>
                <div class="sidebar-item">
                    <i class="fas fa-check-double"></i>
                    <span>Profil : <strong>{% if app.session.get('user').profileComplete %}Complet{% else %}Incomplet{% endif %}</strong></span>
                </div>
                <div class="sidebar-item">
                    <i class="fas fa-venus-mars"></i>
                    <span>Genre : <strong>{{ app.session.get('user').genre }}</strong></span>
                </div>
            </div>

            {# Weather Widget (OpenWeatherMap API) #}
            <div class="sidebar-mini-card">
                <h5><i class="fas fa-cloud-sun me-2"></i> Meteo locale</h5>
                {% if weatherData %}
                <div class="weather-content">
                    <div class="weather-main">
                        <img src="https://openweathermap.org/img/wn/{{ weatherData.icon }}@2x.png" alt="{{ weatherData.desc }}" class="weather-icon">
                        <div>
                            <div class="weather-temp">{{ weatherData.temp }}°C</div>
                            <div class="weather-desc">{{ weatherData.desc }}</div>
                        </div>
                    </div>
                    <div class="weather-details">
                        <div class="weather-detail"><i class="fas fa-tint"></i> {{ weatherData.humidity }}%</div>
                        <div class="weather-detail"><i class="fas fa-wind"></i> {{ weatherData.wind }} km/h</div>
                        <div class="weather-detail"><i class="fas fa-eye"></i> {{ weatherData.visibility }} km</div>
                    </div>
                    <div class="weather-city"><i class="fas fa-map-marker-alt"></i> {{ weatherData.city }}</div>
                </div>
                {% else %}
                <div class="weather-error"><i class="fas fa-exclamation-triangle"></i> Meteo indisponible</div>
                {% endif %}
            </div>

            {# Map Widget (LocationIQ + Leaflet) #}
            {% if geoData %}
            <div class="sidebar-mini-card" style="padding-bottom:16px;">
                <h5><i class="fas fa-map-marked-alt me-2"></i> Ma localisation</h5>
                <div id="profileMap" class="profile-map"></div>
                <p style="font-size:11px;color:#6b7280;margin-top:10px;text-align:center;line-height:1.4;"><i class="fas fa-map-pin" style="color:#348E38;"></i> {{ geoData.display_name }}</p>
            </div>
            {% else %}
            <div class="sidebar-mini-card">
                <h5><i class="fas fa-map-marked-alt me-2"></i> Ma localisation</h5>
                <div class="weather-error"><i class="fas fa-map"></i> Localisation indisponible</div>
            </div>
            {% endif %}

            <div class="sidebar-mini-card">
                <h5><i class="fas fa-chart-pie me-2"></i> Activite</h5>
                <div class="stats-grid">
                    <div class="stat-box">
                        <i class="fas fa-tractor"></i>
                        <div class="stat-label">Equipements</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-wrench"></i>
                        <div class="stat-label">Maintenances</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-coins"></i>
                        <div class="stat-label">Ventes</div>
                    </div>
                    <div class="stat-box">
                        <i class="fas fa-receipt"></i>
                        <div class="stat-label">Depenses</div>
                    </div>
                </div>
            </div>

            {# QR Code vCard #}
            <div class="sidebar-mini-card text-center">
                <h5><i class="fas fa-qrcode me-2"></i> Ma carte de contact</h5>
                <p style="font-size:12px;color:#6b7280;margin-bottom:14px;">Scannez ce QR code pour ajouter mes coordonnees a vos contacts</p>
                <div class="profile-qr-wrap">
                    <img src="{{ path('app_profile_qrcode') }}" alt="QR Code vCard" class="profile-qr-img">
                </div>
                <a href="{{ path('app_profile_qrcode') }}" download="contact_{{ app.session.get('user').prenom }}_{{ app.session.get('user').nom }}.svg" class="pbtn pbtn-green" style="display:inline-flex;flex:none;padding:8px 20px;font-size:13px;margin-top:14px;">
                    <i class="fas fa-download"></i> Telecharger
                </a>
            </div>

            {# PDF ID Card #}
            <div class="sidebar-mini-card text-center">
                <h5><i class="fas fa-id-card me-2"></i> Ma carte d'identite</h5>
                <p style="font-size:12px;color:#6b7280;margin-bottom:14px;">Telechargez votre carte de membre Agricore au format PDF, prete a imprimer.</p>
                <a href="{{ path('app_profile_id_card') }}" class="pbtn pbtn-green" style="display:inline-flex;flex:none;padding:8px 20px;font-size:13px;">
                    <i class="fas fa-file-pdf"></i> Telecharger PDF
                </a>
            </div>

        </div>

    </div>
    {% else %}
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="p-card">
                    <div class="p-card-body profile-empty">
                        <i class="fas fa-user-lock"></i>
                        <p>Vous devez etre connecte pour acceder a votre profil.</p>
                        <a href="{{ path('front_login') }}" class="pbtn pbtn-green" style="display:inline-flex;flex:none;padding:13px 32px;">
                            <i class="fas fa-sign-in-alt"></i> Se connecter
                        </a>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
</div>

{% if geoData is defined and geoData %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    var lat = {{ geoData.lat }};
    var lon = {{ geoData.lon }};
    var map = L.map('profileMap', { scrollWheelZoom: false }).setView([lat, lon], 13);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap'
    }).addTo(map);
    var greenIcon = L.divIcon({
        html: '<i class="fas fa-map-marker-alt" style="font-size:28px;color:#348E38;text-shadow:0 2px 4px rgba(0,0,0,.3);"></i>',
        iconSize: [28, 36],
        iconAnchor: [14, 36],
        className: ''
    });
    L.marker([lat, lon], { icon: greenIcon }).addTo(map);
    setTimeout(function() { map.invalidateSize(); }, 500);
});
</script>
{% endif %}

{# =============== AI Chatbot (Groq + Llama) =============== #}
{% if app.session.get('user') %}
<style>
    .ai-chat-bubble {
        position: fixed; right: 24px; bottom: 24px; z-index: 9999;
        width: 60px; height: 60px; border-radius: 50%;
        background: linear-gradient(135deg, #0F4229 0%, #348E38 100%);
        color: #fff; border: none; cursor: pointer;
        box-shadow: 0 8px 24px rgba(15, 66, 41, .35);
        display: flex; align-items: center; justify-content: center;
        font-size: 22px; transition: transform .2s;
    }
    .ai-chat-bubble:hover { transform: scale(1.08); }
    .ai-chat-bubble .pulse-dot {
        position: absolute; top: 10px; right: 10px;
        width: 12px; height: 12px; border-radius: 50%;
        background: #ff4444; border: 2px solid #fff;
        animation: ai-pulse 1.5s infinite;
    }
    @keyframes ai-pulse {
        0%   { box-shadow: 0 0 0 0 rgba(255, 68, 68, .6); }
        70%  { box-shadow: 0 0 0 10px rgba(255, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(255, 68, 68, 0); }
    }
    .ai-chat-panel {
        position: fixed; right: 24px; bottom: 24px; z-index: 9999;
        width: 370px; height: 520px; max-height: calc(100vh - 40px);
        background: #fff; border-radius: 14px; overflow: hidden;
        box-shadow: 0 20px 50px rgba(0, 0, 0, .25);
        display: none; flex-direction: column;
        font-family: 'Jost', 'Open Sans', sans-serif;
    }
    .ai-chat-panel.open { display: flex; }
    .ai-chat-header {
        background: linear-gradient(135deg, #0F4229 0%, #348E38 100%);
        color: #fff; padding: 14px 16px;
        display: flex; align-items: center; gap: 10px;
    }
    .ai-chat-header .ai-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: rgba(255,255,255,.18);
        display: flex; align-items: center; justify-content: center;
        font-size: 18px;
    }
    .ai-chat-header .ai-title { flex: 1; line-height: 1.2; }
    .ai-chat-header .ai-title strong { display: block; font-size: 14px; }
    .ai-chat-header .ai-title small { font-size: 11px; opacity: .85; }
    .ai-chat-header .ai-clear, .ai-chat-header .ai-close {
        background: none; border: none; color: #fff; cursor: pointer;
        font-size: 12px; padding: 4px 6px; opacity: .85;
    }
    .ai-chat-header .ai-clear:hover, .ai-chat-header .ai-close:hover { opacity: 1; }
    .ai-chat-header .ai-close { font-size: 20px; line-height: 1; }
    .ai-chat-body {
        flex: 1; overflow-y: auto; padding: 16px;
        background: #f7f9f7; display: flex; flex-direction: column; gap: 10px;
    }
    .ai-msg { max-width: 80%; padding: 9px 13px; border-radius: 14px; font-size: 13px; line-height: 1.4; white-space: pre-wrap; word-wrap: break-word; }
    .ai-msg.user { align-self: flex-end; background: #0F4229; color: #fff; border-bottom-right-radius: 4px; }
    .ai-msg.bot  { align-self: flex-start; background: #fff; color: #222; border: 1px solid #e5e5e5; border-bottom-left-radius: 4px; }
    .ai-typing { align-self: flex-start; background: #fff; border: 1px solid #e5e5e5; padding: 10px 14px; border-radius: 14px; border-bottom-left-radius: 4px; display: inline-flex; gap: 4px; }
    .ai-typing span { width: 6px; height: 6px; border-radius: 50%; background: #348E38; animation: ai-bounce 1.2s infinite; }
    .ai-typing span:nth-child(2) { animation-delay: .15s; }
    .ai-typing span:nth-child(3) { animation-delay: .3s; }
    @keyframes ai-bounce {
        0%, 60%, 100% { transform: translateY(0); opacity: .5; }
        30%           { transform: translateY(-5px); opacity: 1; }
    }
    .ai-chat-footer {
        border-top: 1px solid #e5e5e5; padding: 10px;
        display: flex; gap: 8px; background: #fff;
    }
    .ai-chat-footer textarea {
        flex: 1; border: 1px solid #dfe5e1; border-radius: 10px;
        padding: 8px 10px; resize: none; font-size: 13px;
        font-family: inherit; height: 38px; outline: none;
    }
    .ai-chat-footer textarea:focus { border-color: #348E38; }
    .ai-chat-footer .ai-send {
        width: 38px; height: 38px; border-radius: 50%; border: none;
        background: #0F4229; color: #fff; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        transition: background .2s;
    }
    .ai-chat-footer .ai-send:hover { background: #348E38; }
    .ai-chat-footer .ai-send:disabled { background: #aaa; cursor: not-allowed; }
    @media (max-width: 480px) {
        .ai-chat-panel { width: calc(100vw - 20px); right: 10px; bottom: 10px; height: calc(100vh - 20px); }
    }
</style>

<button id="aiChatBubble" class="ai-chat-bubble" title="Assistant Agricore">
    <i class="fas fa-comments"></i>
    <span class="pulse-dot"></span>
</button>

<div id="aiChatPanel" class="ai-chat-panel" role="dialog" aria-label="Assistant IA Agricore">
    <div class="ai-chat-header">
        <div class="ai-avatar"><i class="fas fa-robot"></i></div>
        <div class="ai-title">
            <strong>Assistant Agricore</strong>
            <small>Propulse par IA</small>
        </div>
        <button class="ai-clear" id="aiChatClear" title="Effacer la conversation">Effacer</button>
        <button class="ai-close" id="aiChatClose" title="Fermer">&times;</button>
    </div>
    <div class="ai-chat-body" id="aiChatBody"></div>
    <form class="ai-chat-footer" id="aiChatForm" autocomplete="off">
        <textarea id="aiChatInput" placeholder="Posez votre question..." rows="1" maxlength="500"></textarea>
        <button type="submit" class="ai-send" id="aiChatSend" title="Envoyer">
            <i class="fas fa-paper-plane"></i>
        </button>
    </form>
</div>

<script>
(function() {
    var STORAGE_KEY = 'agricore_chat_history';
    var USER_FIRSTNAME = {{ app.session.get('user').prenom|e('js')|json_encode|raw }};
    var API_URL = {{ path('api_chat')|json_encode|raw }};

    var bubble = document.getElementById('aiChatBubble');
    var panel  = document.getElementById('aiChatPanel');
    var body   = document.getElementById('aiChatBody');
    var form   = document.getElementById('aiChatForm');
    var input  = document.getElementById('aiChatInput');
    var send   = document.getElementById('aiChatSend');
    var closeBtn = document.getElementById('aiChatClose');
    var clearBtn = document.getElementById('aiChatClear');

    function loadHistory() {
        try {
            var raw = sessionStorage.getItem(STORAGE_KEY);
            if (!raw) return [];
            var h = JSON.parse(raw);
            return Array.isArray(h) ? h : [];
        } catch (e) { return []; }
    }

    function saveHistory(h) {
        try { sessionStorage.setItem(STORAGE_KEY, JSON.stringify(h)); } catch (e) {}
    }

    function scrollBottom() { body.scrollTop = body.scrollHeight; }

    function appendMsg(role, content) {
        var d = document.createElement('div');
        d.className = 'ai-msg ' + (role === 'user' ? 'user' : 'bot');
        d.textContent = content;
        body.appendChild(d);
        scrollBottom();
    }

    function appendTyping() {
        var d = document.createElement('div');
        d.className = 'ai-typing';
        d.id = 'aiTyping';
        d.innerHTML = '<span></span><span></span><span></span>';
        body.appendChild(d);
        scrollBottom();
    }

    function removeTyping() {
        var t = document.getElementById('aiTyping');
        if (t) t.remove();
    }

    function render() {
        body.innerHTML = '';
        var h = loadHistory();
        if (h.length === 0) {
            appendMsg('assistant', 'Bonjour ' + USER_FIRSTNAME + ' ! Je suis l\'assistant Agricore. Comment puis-je vous aider aujourd\'hui ?');
        } else {
            h.forEach(function(m) { appendMsg(m.role, m.content); });
        }
    }

    bubble.addEventListener('click', function() {
        panel.classList.add('open');
        bubble.style.display = 'none';
        render();
        setTimeout(function() { input.focus(); }, 100);
    });

    closeBtn.addEventListener('click', function() {
        panel.classList.remove('open');
        bubble.style.display = 'flex';
    });

    clearBtn.addEventListener('click', function() {
        sessionStorage.removeItem(STORAGE_KEY);
        render();
    });

    function sendMessage() {
        var text = input.value.trim();
        if (!text || send.disabled) return;

        appendMsg('user', text);
        var history = loadHistory();
        history.push({ role: 'user', content: text });
        saveHistory(history);

        input.value = '';
        input.style.height = '38px';
        send.disabled = true;
        appendTyping();

        fetch(API_URL, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ message: text, history: history.slice(0, -1) }),
            credentials: 'same-origin'
        })
        .then(function(r) { return r.json().catch(function(){ return {}; }); })
        .then(function(data) {
            removeTyping();
            var reply = (data && data.reply) ? data.reply
                       : 'Desole, une erreur est survenue. Reessayez dans un instant.';
            appendMsg('assistant', reply);
            var h = loadHistory();
            h.push({ role: 'assistant', content: reply });
            saveHistory(h);
        })
        .catch(function() {
            removeTyping();
            appendMsg('assistant', 'Desole, je ne peux pas vous repondre pour le moment.');
        })
        .finally(function() { send.disabled = false; input.focus(); });
    }

    form.addEventListener('submit', function(e) {
        e.preventDefault();
        sendMessage();
    });

    input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    input.addEventListener('input', function() {
        input.style.height = '38px';
        input.style.height = Math.min(input.scrollHeight, 100) + 'px';
    });
})();
</script>
{% endif %}

{% endblock %}
