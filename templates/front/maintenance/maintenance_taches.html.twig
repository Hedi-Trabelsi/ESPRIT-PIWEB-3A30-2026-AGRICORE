{% extends 'front/base_front.html.twig' %}

{% block navbar %}
<!-- Navbar Start -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
    <a href="{{ path('app_home') }}" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <img src="{{ asset('img/logo.png') }}" alt="Logo" style="height: 40px; width: auto;" />
    </a>
    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto p-4 p-lg-0">
            <a href="{{ path('app_home') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_home' %} active{% endif %}">Accueil</a>
            <a href="{{ path('app_about') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_about' %} active{% endif %}">À propos</a>
            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle{% if app.request.attributes.get('_route') in ['app_tech_home', 'app_maintenance_traiter', 'app_maintenance', 'app_tache_new', 'app_maintenance_taches'] %} active{% endif %}" data-bs-toggle="dropdown">Maintenances</a>
                <div class="dropdown-menu bg-light m-0">
                    <a href="{{ path('app_maintenance_traiter') }}" class="dropdown-item">Interventions à traiter</a>
                    <a href="{{ path('app_maintenance') }}" class="dropdown-item">Historique des maintenances</a>
                </div>
            </div>
            <a href="{{ path('app_contact') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_contact' %} active{% endif %}">Contact</a>
        </div>
        <a href="{{ path('app_profile') }}" class="d-none d-lg-block me-4">
            <img src="{{ asset('img/profile.webp') }}" alt="Profile"
                 style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #198754;">
        </a>
    </div>
</nav>
<!-- Navbar End -->
{% endblock %}

{% block title %}Tâches de maintenance{% endblock %}

{% block body %}
<div class="container mt-5">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Tâches pour : {{ maintenance.nomMaintenance }}</h2>
        <a href="{{ path('app_tache_new', {'id_maintenance': maintenance.Id_maintenance}) }}" class="btn btn-success">
            <i class="fas fa-plus"></i> Ajouter une tâche
        </a>
    </div>

    <!-- Informations de la maintenance -->
    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Détails de la maintenance</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <strong>Équipement:</strong> {{ maintenance.Equipement }}
                </div>
                <div class="col-md-3">
                    <strong>Lieu:</strong> {{ maintenance.Lieu }}
                </div>
                <div class="col-md-3">
                    <strong>Type:</strong> {{ maintenance.Type }}
                </div>
                <div class="col-md-3">
                    <strong>Priorité:</strong>
                    <span class="badge {% if maintenance.Priorite == 'Urgente' %}bg-danger{% else %}bg-secondary{% endif %}">
                        {{ maintenance.Priorite }}
                    </span>
                </div>
            </div>
            <div class="row mt-2">
                <div class="col-md-6">
                    <strong>Date de déclaration:</strong> {{ maintenance.dateDeclaration|date('d/m/Y') }}
                </div>
                <div class="col-md-6">
                    <strong>Statut:</strong> {{ maintenance.Statut }}
                </div>
            </div>
            <div class="mt-2">
                <strong>Description:</strong><br>
                {{ maintenance.Description|nl2br }}
            </div>
        </div>
    </div>

    <!-- Liste des tâches -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Tâches associées</h5>
        </div>
        <div class="card-body">
            {% if taches is empty %}
                <div class="alert alert-info">
                    Aucune tâche n'a encore été planifiée pour cette maintenance.
                </div>
            {% else %}
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Nom de la tâche</th>
                                <th>Date prévue</th>
                                <th>Technicien</th>
                                <th>Coût estimé</th>
                                <th>Évaluation</th>
                                <th>Description</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for tache in taches %}
                                <tr>
                                    <td>{{ tache.nomTache }}</td>
                                <td>{{ tache.getDatePrevue()|date('d/m/Y') }}</td>
                                   {# templates/front/maintenance/maintenance_taches.html.twig #}

<td>
    {# On utilise la méthode getIdTechnicien() que nous avons créée dans l'entité #}
    {% if tache.getIdTechnicien() %}
        {{ tache.getIdTechnicien().nom }} {{ tache.getIdTechnicien().prenom }}
    {% else %}
        <span class="text-muted">Non assigné</span>
    {% endif %}
</td><td>{{ tache.getCoutEstimee() }} €</td>
                                    <td>{{ tache.evaluation }}/10</td>
                                    <td>{{ tache.description|nl2br }}</td>
                                    <td>
                                        <a href="{{ path('app_tache_edit', {'id_tache': tache.id_tache}) }}" class="btn btn-sm btn-warning me-1">
                                            <i class="fas fa-edit"></i> Modifier
                                        </a>
                                        <form method="post" action="{{ path('app_tache_delete', {'id_tache': tache.id_tache}) }}" class="d-inline" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cette tâche ?');">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id_tache) }}">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="fas fa-trash"></i> Supprimer
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% endif %}
        </div>
    </div>

    <div class="mt-3">
        <a href="{{ path('app_maintenance_traiter') }}" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Retour aux interventions
        </a>
    </div>
</div>
{% endblock %}