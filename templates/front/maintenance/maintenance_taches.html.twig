{% extends 'front/base_front.html.twig' %}

{% block title %}Tâches de maintenance{% endblock %}

{% block navbar %}
    {% include 'front/partials/_tech_navbar.html.twig' %}
{% endblock %}

{% block body %}
<style>
    /* Section Titre & Header */
    .header-section { margin-bottom: 2rem; border-bottom: 1px solid #eee; padding-bottom: 20px; }

    /* Carte Principale de Maintenance */
    .custom-card {
        background-color: #ffffff; border: 1px solid #f0f0f0; border-radius: 0 70px 0 70px;
        transition: all 0.4s ease; padding: 40px;
    }

    .card-title-custom { font-weight: 800; font-size: 1.3rem; text-transform: uppercase; color: #0F4229; }
    .card-info-val { color: #555; font-weight: 500; font-size: 0.95rem; margin-bottom: 10px; }

    /* Boutons d'actions */
    .btn-action-simple { border: none; background: none; padding: 8px 15px; font-weight: 600; font-size: 0.9rem; transition: 0.2s; text-decoration: none; }
    .btn-edit-text { color: #0F4229; }
    .btn-add-text { color: #198754; }
    .btn-close-text { color: #dc3545; }

    /* Cartes de Tâches */
    .task-card { border: 1px solid #f0f0f0; border-radius: 20px; transition: all 0.3s ease; cursor: pointer; overflow: hidden; background-color: #fff; position: relative; }
    .task-card:hover { transform: translateY(-5px); box-shadow: 0 10px 20px rgba(0,0,0,0.05); }
    .task-card.active { background-color: #f8f9fa; border-color: #198754; }

    .task-card-details {
        max-height: 0; overflow: hidden; opacity: 0;
        transition: max-height 0.3s ease-out, opacity 0.3s ease;
    }

    .task-card.active .task-card-details {
        max-height: 600px; padding-top: 1rem; margin-top: 1rem;
        border-top: 1px solid #e9ecef; opacity: 1;
    }
</style>

<div class="container mt-5">
    {# Messages Flash #}
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {# Header avec Actions #}
    <div class="header-section d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
        <div>
            <h1 class="fw-bold m-0">{{ maintenance.nomMaintenance }}</h1>
            <div class="mt-2 d-flex flex-column">
                <span>Statut : <span class="{% if maintenance.Statut in ['Résolu', 'Résolue'] %}text-success fw-bold{% else %}text-warning{% endif %}">{{ maintenance.Statut }}</span></span>
                <span class="text-muted">Coût Total : <strong class="text-dark">{{ totalCost }} DT</strong></span>
            </div>
        </div>
        
        <div class="d-flex flex-wrap gap-2">
            {% if maintenance.Statut not in ['Résolu', 'Résolue'] %}
                <a href="{{ path('app_tache_new', {'id_maintenance': maintenance.Id_maintenance}) }}" class="btn-action-simple btn-add-text">
                    <i class="fas fa-plus-circle me-1"></i> Ajouter Tâche
                </a>
                <form method="post" action="{{ path('app_maintenance_cloturer', {'id_maintenance': maintenance.Id_maintenance}) }}" onsubmit="return confirm('Clôturer cette maintenance ?');">
                    <input type="hidden" name="_token" value="{{ csrf_token('cloturer' ~ maintenance.Id_maintenance) }}">
                    <button type="submit" class="btn-action-simple btn-close-text">
                        <i class="fas fa-check-double me-1"></i> Clôturer l'intervention
                    </button>
                </form>
            {% endif %}
        </div>
    </div>

    {# Détails de la Maintenance #}
    <div class="row mb-5">
        <div class="col-12">
            <div class="custom-card shadow-sm">
                <h5 class="card-title-custom mb-4">Informations Générales</h5>
                <div class="row g-3">
                    <div class="col-md-4 card-info-val"><small class="text-muted d-block">Équipement</small><span>{{ maintenance.Equipement }}</span></div>
                    <div class="col-md-4 card-info-val"><small class="text-muted d-block">Localisation</small><span>{{ maintenance.Lieu }}</span></div>
                    <div class="col-md-4 card-info-val"><small class="text-muted d-block">Priorité</small><span class="{% if maintenance.Priorite == 'Urgente' %}text-danger fw-bold{% endif %}">{{ maintenance.Priorite }}</span></div>
                    <div class="col-md-4 card-info-val"><small class="text-muted d-block">Type</small><span>{{ maintenance.Type }}</span></div>
                    <div class="col-md-4 card-info-val"><small class="text-muted d-block">Date de déclaration</small><span>{{ maintenance.dateDeclaration|date('d/m/Y') }}</span></div>
                </div>

                {# --- DESCRIPTION DE LA MAINTENANCE AJOUTÉE ICI --- #}
                <div class="mt-4 pt-3 border-top">
                    <small class="text-muted d-block mb-1">Description de la maintenance :</small>
                    <p class="text-dark mb-0" style="font-size: 0.95rem; line-height: 1.5;">
                        {{ maintenance.description ? maintenance.description|nl2br : "Aucune description détaillée pour cette maintenance." }}
                    </p>
                </div>
            </div>
        </div>
    </div>

    <h3 class="fw-bold mb-4">Travaux & Tâches</h3>

    <div class="row g-4">
        {% for tache in taches %}
            <div class="col-lg-4 col-md-6">
                <div class="task-card p-4 shadow-sm" onclick="toggleTask(this)">
                    <div class="d-flex justify-content-between align-items-start">
                        <h5 class="fw-bold mb-1" style="font-size: 1rem; color: #0F4229;">{{ tache.nomTache }}</h5>
                        <span class="text-success fw-bold">{{ tache.getCoutEstimee() }} DT</span>
                    </div>
                    
                    <div class="task-card-details">
                        <div class="card-info-val"><small class="text-muted">Technicien :</small>
                            <div class="fw-bold text-dark">{{ tache.getIdTechnicien() ? tache.getIdTechnicien().nom ~ ' ' ~ tache.getIdTechnicien().prenom : "Non assigné" }}</div>
                        </div>
                        <div class="card-info-val"><small class="text-muted">Date :</small><div>{{ tache.getDatePrevue()|date('d/m/Y') }}</div></div>

                        {# Description de la tâche #}
                        <div class="mt-3">
                            <small class="text-muted d-block mb-1">Description / Notes :</small>
                            <p class="small text-secondary mb-0" style="line-height: 1.4;">
                                {{ tache.description ? tache.description|nl2br : "Aucune description fournie." }}
                            </p>
                        </div>

                        <div class="d-flex justify-content-end gap-2 border-top pt-3 mt-3">
                            {% set is_past = tache.getDatePrevue()|date('Y-m-d') < "now"|date('Y-m-d') %}
                            {% if not is_past %}
                                <a href="{{ path('app_tache_edit', {'id_tache': tache.id_tache}) }}" class="btn-action-simple btn-edit-text p-0 pe-2" onclick="event.stopPropagation();">
                                    <i class="fas fa-edit small"></i> Modifier
                                </a>
                                <button type="button" class="btn-action-simple text-danger p-0" data-bs-toggle="modal" data-bs-target="#confirmDeleteTache{{ tache.id_tache }}" onclick="event.stopPropagation();">
                                    <i class="fas fa-trash small"></i> Supprimer
                                </button>
                            {% else %}
                                <span class="text-muted small"><i class="fas fa-lock small"></i> Tâche verrouillée</span>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>

            {# Modale de suppression #}
            <div class="modal fade" id="confirmDeleteTache{{ tache.id_tache }}" tabindex="-1" aria-hidden="true" onclick="event.stopPropagation();">
                <div class="modal-dialog modal-sm modal-dialog-centered">
                    <div class="modal-content shadow border-0" style="border-radius: 15px;">
                        <div class="modal-body text-center py-4">
                            <i class="fas fa-exclamation-circle text-danger mb-3" style="font-size: 2.5rem;"></i>
                            <p class="mb-0 fw-bold text-dark">Supprimer cette tâche ?</p>
                            <div class="d-flex justify-content-center gap-2 mt-4">
                                <button type="button" class="btn btn-light btn-sm px-3" data-bs-dismiss="modal">Annuler</button>
                                <form method="post" action="{{ path('app_tache_delete', {'id_tache': tache.id_tache}) }}" class="m-0">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ tache.id_tache) }}">
                                    <button type="submit" class="btn btn-danger btn-sm px-3">Confirmer</button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<script>
    function toggleTask(element) {
        const isActive = element.classList.contains('active');
        document.querySelectorAll('.task-card').forEach(card => card.classList.remove('active'));
        if (!isActive) {
            element.classList.add('active');
        }
    }
</script>
{% endblock %}