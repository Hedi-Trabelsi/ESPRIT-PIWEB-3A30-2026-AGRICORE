{% extends 'front/base_front.html.twig' %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4" style="border-radius: 15px;">
        <h2 class="mb-4 text-center">Modifier la Maintenance</h2>

        {# novalidate est là pour laisser Symfony gérer les messages d'erreur personnalisés #}
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
        
        <div class="row">
            <div class="col-md-4 mb-3">
                {{ form_label(form.Nom_maintenance, "Nom Maintenance") }}
                {{ form_widget(form.Nom_maintenance, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Nom_maintenance) }}</div>
            </div>
            <div class="col-md-4 mb-3">
                {{ form_label(form.Equipement, "Équipement") }}
                {{ form_widget(form.Equipement, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Equipement) }}</div>
            </div>
            <div class="col-md-4 mb-3">
                {{ form_label(form.Lieu, "Lieu") }}
                {{ form_widget(form.Lieu, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Lieu) }}</div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-4 mb-3">
                {{ form_label(form.Date_declaration, "Date de déclaration ") }}
                {{ form_widget(form.Date_declaration, {'attr': {'class': 'form-control', 'readonly': 'readonly'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Date_declaration) }}</div>
            </div>
            <div class="col-md-4 mb-3">
                {{ form_label(form.Type, "Type") }}
                {{ form_widget(form.Type, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Type) }}</div>
            </div>
            <div class="col-md-4 mb-3">
                {{ form_label(form.Priorite, "Priorité") }}
                {{ form_widget(form.Priorite, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small mt-1">{{ form_errors(form.Priorite) }}</div>
            </div>
        </div>

        <div class="mt-3 mb-3">
            {{ form_label(form.Description, "Description") }}
            {{ form_widget(form.Description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
            <div class="text-danger small mt-1">{{ form_errors(form.Description) }}</div>
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn px-5" style="background-color: #0F4229; color: white; border-radius: 25px;">
                Enregistrer les modifications
            </button>
            <a href="{{ path('app_maintenance') }}" class="btn btn-light px-5" style="border-radius: 25px; margin-left: 10px; border: 1px solid #ddd;">
                Annuler
            </a>
        </div>
        
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}