{% extends 'front/base_front.html.twig' %}

{% block navbar %}
<!-- Navbar Start -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
    <a href="{{ path('app_home') }}" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <img src="{{ asset('img/logo.png') }}" alt="Logo" style="height: 40px; width: auto;" />
    </a>
    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto p-4 p-lg-0">
            <a href="{{ path('app_home') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_home' %} active{% endif %}">Accueil</a>
            <a href="{{ path('app_about') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_about' %} active{% endif %}">À propos</a>
            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle{% if app.request.attributes.get('_route') in ['app_tech_home', 'app_maintenance_traiter', 'app_maintenance', 'app_tache_new'] %} active{% endif %}" data-bs-toggle="dropdown">Maintenances</a>
                <div class="dropdown-menu bg-light m-0">
                    <a href="{{ path('app_maintenance_traiter') }}" class="dropdown-item">Interventions à traiter</a>
                    <a href="{{ path('app_maintenance') }}" class="dropdown-item">Historique des maintenances</a>
                </div>
            </div>
            <a href="{{ path('app_contact') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_contact' %} active{% endif %}">Contact</a>
        </div>
        <a href="{{ path('app_profile') }}" class="d-none d-lg-block me-4">
            <img src="{{ asset('img/profile.webp') }}" alt="Profile"
                 style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #198754;">
        </a>
    </div>
</nav>
<!-- Navbar End -->
{% endblock %}

{% block title %}Interventions à traiter{% endblock %}

{% block body %}
<div class="container mt-5">
    <h2 class="mb-4 text-center">Interventions à traiter</h2>

    {% if listeMaintenances is empty %}
        <div class="alert alert-info text-center">
            Aucune intervention à traiter pour le moment.
        </div>
    {% else %}
        <div class="row g-4">
            {% for m in listeMaintenances %}
                <div class="col-lg-4 col-md-6">
                    <div class="card rounded-4 h-100 shadow-sm border-0">
                        <div class="card-body d-flex flex-column">
                            <div class="mb-3">
                                <span class="badge {% if m.Priorite == 'Urgente' %}bg-danger{% else %}bg-secondary{% endif %}">
                                    {{ m.Priorite }}
                                </span>
                            </div>
                            <h5 class="card-title fw-bold">{{ m.nomMaintenance }}</h5>
                            <p class="card-text text-muted mb-1">
                                <i class="fas fa-cogs text-primary me-2"></i>{{ m.Equipement }}
                            </p>
                            <p class="card-text text-muted mb-3">
                                <i class="fas fa-map-marker-alt text-primary me-2"></i>{{ m.Lieu }}
                            </p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <button type="button" class="btn btn-outline-primary rounded-3" data-bs-toggle="modal" data-bs-target="#detailModal{{ m.Id_maintenance }}">
                                    Plus
                                </button>
                                <a href="{{ path('app_tache_new', {'id_maintenance': m.Id_maintenance}) }}" class="btn btn-success btn-sm rounded-3">
                                    Planifier
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal fade" id="detailModal{{ m.Id_maintenance }}" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content rounded-4">
                            <div class="modal-header bg-primary text-white rounded-top-4">
                                <h5 class="modal-title">{{ m.nomMaintenance }}</h5>
                                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                            </div>
                            <div class="modal-body">
                                <div class="row mb-3">
                                    <div class="col-md-6 mb-2">
                                        <strong>Équipement :</strong> {{ m.Equipement }}
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>Lieu :</strong> {{ m.Lieu }}
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="col-md-6 mb-2">
                                        <strong>Priorité :</strong>
                                        <span class="badge {% if m.Priorite == 'Urgente' %}bg-danger{% else %}bg-secondary{% endif %}">
                                            {{ m.Priorite }}
                                        </span>
                                    </div>
                                    <div class="col-md-6 mb-2">
                                        <strong>Date :</strong> {{ m.dateDeclaration|date('d/m/Y') }}
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <strong>Description :</strong>
                                    <p class="mt-2 ps-3" style="border-left: 3px solid #198754;">
                                        {{ m.Description|nl2br }}
                                    </p>
                                </div>
                                <div class="mb-3">
                                    <span class="badge bg-info text-dark">Statut : {{ m.Statut }}</span>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <a href="{{ path('app_maintenance_taches', {'id_maintenance': m.Id_maintenance}) }}" class="btn btn-info rounded-3">
                                    Voir tâches
                                </a>
                                <button type="button" class="btn btn-secondary rounded-3" data-bs-dismiss="modal">Fermer</button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
