{% extends 'front/base_front.html.twig' %}

{% block navbar %}
{% include 'front/partials/_tech_navbar.html.twig' %}
{% endblock %}

{% block title %}Interventions à traiter{% endblock %}

{% block body %}
<style>
    .header-section {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }
.agri-badge {
    position: absolute;
    top: 10px;
    left: 10px;
    font-size: 0.75rem;
    font-weight: 600;
    color: #0F4229;
    background: #E9F7EF;
    padding: 4px 10px;
    border-radius: 999px;
    border: 1px solid #CFE9DB;
}
    .custom-card {
        background-color: #ffffff;
        border: 1px solid #f0f0f0;
        border-radius: 0 70px 0 70px;
        transition: all 0.4s ease;
        min-height: 250px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 25px;
        text-align: center;
        position: relative;
    }

    .custom-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08);
    }

    .card-title-custom {
        font-weight: 800;
        font-size: 1.3rem;
        text-transform: uppercase;
        color: #0F4229;
        margin-top: 10px;
    }

    .btn-plus {
        background: transparent;
        border: none;
        border-bottom: 1.5px solid #000;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 1px;
        margin-top: 20px;
        cursor: pointer;
        padding: 0 5px;
        transition: 0.3s;
    }
    .btn-plus:hover {
        color: #198754;
        border-color: #198754;
    }

    .modal-content-custom {
        background-color: #ffffff;
        border-radius: 0 70px 0 70px !important;
        border: none;
        padding: 40px;
    }

    .detail-value {
        color: #0F4229;
        font-weight: 600;
    }

    .distance-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-top: 8px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #0F4229;
        background: #E9F7EF;
        border: 1px solid #CFE9DB;
    }

    .distance-chip.muted {
        color: #6c757d;
        background: #f8f9fa;
        border-color: #eaecef;
    }

    .btn-add-custom {
        display: inline-flex;
        align-items: center;
        background-color: #0F4229;
        color: #fff;
        padding: 8px 20px;
        border-radius: 30px;
        font-size: 0.9rem;
        text-decoration: none;
        transition: 0.3s;
        border: none;
    }

    .btn-add-custom:hover {
        color: #fff;
        opacity: 0.92;
    }

    .recommendation-section {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    .recommendation-panel {
        border: 1px solid #e7ece9;
        border-radius: 14px;
        background: #ffffff;
        box-shadow: 0 4px 12px rgba(15, 66, 41, 0.06);
    }

    .recommendation-card-meta {
        position: absolute;
        top: -10px;
        right: -8px;
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 999px;
        font-weight: 700;
        background: #198754;
        color: #fff;
    }

    .recommendation-score-meta {
        position: absolute;
        top: 12px;
        left: 12px;
        font-size: 0.75rem;
        padding: 3px 10px;
        border-radius: 999px;
        font-weight: 700;
        color: #0F4229;
        background: #E9F7EF;
        border: 1px solid #CFE9DB;
    }

    .recommendation-card {
        background-color: #ffffff;
        border: 1px solid #f0f0f0;
        border-radius: 0 70px 0 70px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        min-height: 250px;
        padding: 52px 16px 16px 16px;
        text-align: left;
        align-items: flex-start;
        justify-content: flex-start;
    }

    .recommendation-card .agri-badge {
        position: static;
        margin-bottom: 8px;
        align-self: flex-start;
    }

    .recommendation-card .card-info-val,
    .recommendation-card .card-lieu-val {
        margin-top: 6px;
        text-align: left;
    }

    .recommendation-card .recommendation-actions {
        margin-top: auto;
        display: flex;
        flex-direction: column;
        gap: 6px;
        align-items: center;
        width: 100%;
        padding-top: 10px;
    }

    .recommendation-card .recommendation-actions a {
        align-self: center;
    }

    .recommendation-results-frame {
        border-radius: 16px;
        padding: 16px;
    }

    .pagination {
        gap: 8px;
        flex-wrap: wrap;
    }

    .pagination .page-item .page-link {
        width: 42px;
        height: 42px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 0 !important;
        border: 1px solid #d7e6dd;
        color: #0F4229;
        background: #fff;
        font-weight: 700;
        box-shadow: 0 2px 6px rgba(15, 66, 41, 0.06);
    }

    .pagination .page-item.active .page-link {
        background: #0F4229;
        color: #fff;
        border-color: #0F4229;
    }

    .pagination .page-item.disabled .page-link {
        opacity: 0.5;
    }
</style>

<div class="container mt-5">
    <div class="header-section text-center">
        <h1 class="fw-bold m-0">Interventions à traiter</h1>
    </div>

    <div class="recommendation-panel mb-4 p-4">
        <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
            <div>
                <h2 class="h5 mb-1 fw-bold text-dark">Proposition intelligente</h2>
                <p class="mb-0 text-muted">Clique pour voir les 3 maintenances les plus pertinentes selon la distance et ton historique avec l'agriculteur.</p>
            </div>
            <button type="button" class="btn-add-custom" id="recommendMaintenanceBtn" data-recommendation-url="{{ path('app_maintenance_recommendations') }}">
                Me proposer une maintenance
            </button>
        </div>
    </div>

    <div id="recommendationFeedback" class="mb-3"></div>
    <div id="recommendationResults" class="row g-4 justify-content-center mb-4 recommendation-results-frame"></div>

    {% if listeMaintenances is empty %}
        <div class="text-center py-5">
            <p class="text-muted fs-5">Aucun résultat trouvé.</p>
        </div>
    {% else %}
        <div class="row g-4 justify-content-center">
            {% for m in listeMaintenances %}
                <div class="col-lg-4 col-md-6">
                    <div class="custom-card shadow-sm">

                        <h5 class="card-title-custom">{{ m.nomMaintenance }}</h5>

                        {# ✅ Agriculteur CORRIGÉ ICI #}
                       <div class="agri-badge">
    👨‍🌾
    {% if m.id_agriculteur is defined and m.id_agriculteur %}
        {{ m.id_agriculteur.prenom|default('') }} {{ m.id_agriculteur.nom|default('') }}
    {% else %}
        Inconnu
    {% endif %}
</div>

                        {% set distanceKm = maintenanceDistances[m.Id_maintenance]|default(null) %}

                        <div class="small text-dark fw-bold mb-1">
                            {{ m.Equipement }}
                        </div>

                        <div class="small text-muted mb-2">
                            <i class="fas fa-map-marker-alt me-1"></i> {{ m.Lieu }}
                        </div>

                        {% if proximityEnabled and distanceKm is not null %}
                            <div class="distance-chip">
                                <i class="fas fa-route"></i>
                                {{ distanceKm|number_format(2, '.', ' ') }} km
                            </div>
                        {% else %}
                            <div class="distance-chip muted">
                                Distance indisponible
                            </div>
                        {% endif %}

                        <button type="button" class="btn-plus"
                                data-bs-toggle="modal"
                                data-bs-target="#detailModal{{ m.Id_maintenance }}">
                            PLUS
                        </button>
                    </div>
                </div>

                {# Modale de détail #}
                <div class="modal fade" id="detailModal{{ m.Id_maintenance }}" tabindex="-1">
                    <div class="modal-dialog modal-lg modal-dialog-centered">
                        <div class="modal-content" style="background: transparent; border: none;">
                            <div class="modal-content-custom shadow-lg text-start">

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <h5 class="card-title-custom m-0">{{ m.nomMaintenance }}</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>

                                <div class="col-md-4">
                                    <small class="text-muted d-block">Agriculteur</small>
                                    <span class="detail-value">
                                        {% if m.id_agriculteur is defined and m.id_agriculteur %}
                                            {{ m.id_agriculteur.prenom|default('') }} {{ m.id_agriculteur.nom|default('') }}
                                        {% else %}
                                            Inconnu
                                        {% endif %}
                                    </span>
                                </div>

                                <div class="row g-4">
                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Équipement</small>
                                        <span class="detail-value">{{ m.Equipement }}</span>
                                    </div>

                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Localisation</small>
                                        <span class="detail-value">{{ m.Lieu }}</span>
                                    </div>

                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Distance estimée</small>
                                        {% set detailDistanceKm = maintenanceDistances[m.Id_maintenance]|default(null) %}
                                        {% if proximityEnabled and detailDistanceKm is not null %}
                                            <span class="detail-value">{{ detailDistanceKm|number_format(2, '.', ' ') }} km</span>
                                        {% else %}
                                            <span class="text-muted">Indisponible</span>
                                        {% endif %}
                                    </div>

                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Priorité</small>
                                        <span class="detail-value">{{ m.Priorite }}</span>
                                    </div>

                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Date déclaration</small>
                                        <span class="detail-value">{{ m.dateDeclaration|date('d/m/Y') }}</span>
                                    </div>

                                    <div class="col-md-4">
                                        <small class="text-muted d-block">Statut</small>
                                        <span class="badge bg-light border text-dark">{{ m.Statut }}</span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3 border-top">
                                    <h6 class="fw-bold small text-muted text-uppercase mb-2">Description :</h6>
                                    <p class="text-secondary mb-0">{{ m.Description|nl2br }}</p>
                                </div>

                                <div class="mt-4 d-flex justify-content-between align-items-center">
                                    <a href="{{ path('app_tache_new', {'id_maintenance': m.Id_maintenance}) }}"
                                       class="btn btn-sm btn-success rounded-pill px-4">
                                        <i class="fas fa-calendar-check me-1"></i> Planifier l'intervention
                                    </a>
                                </div>

                            </div>
                        </div>
                    </div>
                </div>

            {% endfor %}
        </div>

        <div class="d-flex justify-content-center mt-4">
            <nav aria-label="Pagination">
                <ul class="pagination">

                    {% if listeMaintenances.pageCount > 1 and listeMaintenances.currentPageNumber > 1 %}
                        <li class="page-item">
                            <a class="page-link"
                               href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': listeMaintenances.currentPageNumber - 1})) }}">
                                &laquo;
                            </a>
                        </li>
                    {% endif %}

                    {% for page in 1..listeMaintenances.pageCount %}
                        <li class="page-item {{ page == listeMaintenances.currentPageNumber ? 'active' : '' }}">
                            <a class="page-link"
                               href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': page})) }}">
                                {{ page }}
                            </a>
                        </li>
                    {% endfor %}

                    {% if listeMaintenances.pageCount > 1 and listeMaintenances.currentPageNumber < listeMaintenances.pageCount %}
                        <li class="page-item">
                            <a class="page-link"
                               href="{{ path(app.request.attributes.get('_route'), app.request.query.all|merge({'page': listeMaintenances.currentPageNumber + 1})) }}">
                                &raquo;
                            </a>
                        </li>
                    {% endif %}

                </ul>
            </nav>
        </div>

    {% endif %}
</div>
<script>
(function () {
    const button = document.getElementById('recommendMaintenanceBtn');
    const feedback = document.getElementById('recommendationFeedback');
    const results = document.getElementById('recommendationResults');

    if (!button || !feedback || !results) {
        return;
    }

    const renderMessage = (type, message) => {
        feedback.innerHTML = `<div class="alert alert-${type} mb-0">${message}</div>`;
    };

    const escapeHtml = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');

    const renderResults = (items) => {
        if (!items.length) {
            results.innerHTML = '<div class="col-12"><div class="alert alert-warning mb-0">Aucune recommandation disponible.</div></div>';
            return;
        }

        const scoreColors = ['#0F4229', '#2d6a4f', '#52b788'];

        results.innerHTML = items.map((item, index) => {
            const distance = item.distanceKm === null ? 'Indisponible' : `${Number(item.distanceKm).toFixed(2)} km`;
            const scoreColor = scoreColors[index] || '#555';
            const priorityRaw = String(item.priority || 'Non définie');
            const priorityLower = priorityRaw.toLowerCase();
            const priorityStyle = priorityLower.includes('urgent')
                ? 'background:#fde8e8;border:1px solid #f7b4b4;color:#a61b1b;'
                : (priorityLower.includes('faible')
                    ? 'background:#eaf8ef;border:1px solid #bfe5c9;color:#1f6b37;'
                    : 'background:#fff6e5;border:1px solid #f2d8a0;color:#8a5b00;');

            return `
                <div class="col-lg-4 col-md-6">
                    <div style="
                        background:#fff;
                        border:1px solid #e8f0eb;
                        border-radius: 0 50px 0 50px;
                        box-shadow: 0 4px 18px rgba(15,66,41,.07);
                        padding: 28px 22px 22px;
                        position:relative;
                        transition: transform .3s, box-shadow .3s;
                        min-height: 200px;
                        display:flex;flex-direction:column;
                    " onmouseover="this.style.transform='translateY(-6px)';this.style.boxShadow='0 14px 32px rgba(15,66,41,.12)'"
                       onmouseout="this.style.transform='';this.style.boxShadow='0 4px 18px rgba(15,66,41,.07)'">

                        <span style="position:absolute;top:-12px;right:16px;background:#0F4229;color:#fff;font-size:.72rem;font-weight:800;padding:4px 12px;border-radius:50px;">
                            Top ${index + 1}
                        </span>

                        <div style="display:inline-flex;align-items:center;gap:6px;background:#e9f7ef;border:1px solid #c3e6cb;border-radius:50px;padding:3px 12px;font-size:.75rem;font-weight:700;color:${scoreColor};margin-bottom:14px;width:fit-content;">
                            Score ${item.score}%
                        </div>

                        <div style="font-size:1.05rem;font-weight:800;text-transform:uppercase;color:#0F4229;margin-bottom:12px;line-height:1.3;">
                            ${escapeHtml(item.maintenanceName)}
                        </div>

                        <div style="display:flex;flex-direction:column;gap:5px;">
                            <div style="font-size:.82rem;color:#555;">
                                <span style="color:#999;font-weight:600;">Priorité</span><br>
                                <span style="display:inline-block;margin-top:2px;padding:3px 10px;border-radius:50px;font-size:.78rem;font-weight:700;${priorityStyle}">
                                    ${escapeHtml(priorityRaw)}
                                </span>
                            </div>
                            <div style="font-size:.82rem;color:#555;">
                                <span style="color:#999;font-weight:600;">Agriculteur</span><br>
                                <span style="font-weight:700;color:#1e2d26;">${escapeHtml(item.farmerName)}</span>
                            </div>
                            <div style="font-size:.82rem;color:#555;">
                                <span style="color:#999;font-weight:600;">Distance</span><br>
                                <span style="font-weight:700;color:#1e2d26;">${distance}</span>
                            </div>
                            <div style="font-size:.82rem;color:#555;">
                                <span style="color:#999;font-weight:600;">Historique</span><br>
                                <span style="font-weight:700;color:#1e2d26;">${item.historyCount} intervention(s)</span>
                            </div>
                            <div style="font-size:.82rem;color:#555;margin-top:2px;">
                                <i class="fas fa-map-marker-alt" style="color:#0F4229;margin-right:4px;"></i>
                                <span style="font-weight:600;color:#1e2d26;">${escapeHtml(item.location)}</span>
                            </div>
                        </div>
                    </div>
                </div>
            `;
        }).join('');
    };

    button.addEventListener('click', async () => {
        button.disabled = true;
        button.textContent = 'Calcul en cours...';
        renderMessage('info', 'Calcul des recommandations en cours...');
        results.innerHTML = '';

        try {
            const response = await fetch(button.dataset.recommendationUrl, {
                method: 'POST',
                headers: {
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json',
                },
            });

            const payload = await response.json();

            if (!response.ok || !payload.success) {
                throw new Error(payload.error || 'Erreur lors de la recommandation.');
            }

            renderMessage('success', payload.message || 'Recommandations calculées avec succès.');
            renderResults((payload.data && payload.data.recommendations) || []);
        } catch (error) {
            renderMessage('danger', error.message || 'Impossible de calculer la recommandation.');
        } finally {
            button.disabled = false;
            button.textContent = 'Me proposer une maintenance';
        }
    });
})();
</script>
{% endblock %}