{% extends 'front/base_front.html.twig' %}

{% block navbar %}
{% include 'front/partials/_tech_navbar.html.twig' %}
{% endblock %}

{% block title %}Interventions planifiées{% endblock %}

{% block body %}
<style>
    .header-section {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    .agri-badge {
        position: absolute;
        top: 10px;
        left: 10px;
        font-size: 0.75rem;
        font-weight: 600;
        color: #0F4229;
        background: #E9F7EF;
        padding: 4px 10px;
        border-radius: 999px;
        border: 1px solid #CFE9DB;
    }

    .custom-card {
        background-color: #ffffff;
        border: 1px solid #f0f0f0;
        border-radius: 0 70px 0 70px;
        transition: all 0.4s ease;
        min-height: 250px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 25px;
        text-align: center;
        position: relative;
    }

    .custom-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 15px 30px rgba(0,0,0,0.08);
    }

    .card-title-custom {
        font-weight: 800;
        font-size: 1.3rem;
        text-transform: uppercase;
        color: #0F4229;
        margin-top: 10px;
    }

    .btn-plus {
        display: inline-block;
        background: transparent;
        border: none;
        border-bottom: 1.5px solid #000;
        font-weight: 700;
        font-size: 0.75rem;
        letter-spacing: 1px;
        margin-top: 20px;
        cursor: pointer;
        padding: 0 5px;
        transition: 0.3s;
        text-decoration: none;
        color: black;
    }

    .btn-plus:hover {
        color: #198754;
        border-color: #198754;
    }

    .distance-chip {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        margin-top: 8px;
        padding: 4px 10px;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 700;
        color: #0F4229;
        background: #E9F7EF;
        border: 1px solid #CFE9DB;
    }

    .distance-chip.muted {
        color: #6c757d;
        background: #f8f9fa;
        border-color: #eaecef;
    }
</style>

<div class="container mt-5">
    <div class="header-section text-center">
        <h1 class="fw-bold m-0">Interventions planifiées</h1>
    </div>

    {% if listeMaintenances is empty %}
        <div class="text-center py-5">
            <p class="text-muted fs-5">Aucun résultat trouvé.</p>
        </div>
    {% else %}
        <div class="row g-4 justify-content-center">

            {% for m in listeMaintenances %}
                <div class="col-lg-4 col-md-6">
                    <div class="custom-card shadow-sm">

                        <div class="agri-badge">
                            👨‍🌾
                            {% if m.id_agriculteur is defined and m.id_agriculteur %}
                                {{ m.id_agriculteur.prenom|default('') }} {{ m.id_agriculteur.nom|default('') }}
                            {% else %}
                                Inconnu
                            {% endif %}
                        </div>

                        <h5 class="card-title-custom">{{ m.nomMaintenance }}</h5>

                        {% set distanceKm = maintenanceDistances[m.Id_maintenance]|default(null) %}

                        <div class="small text-dark fw-bold mb-1">
                            {{ m.Equipement }}
                        </div>

                        <div class="small text-muted mb-2">
                            <i class="fas fa-map-marker-alt me-1"></i> {{ m.Lieu }}
                        </div>

                 

{% set distanceKm = maintenanceDistances[m.Id_maintenance]|default(null) %}

{% if proximityEnabled and distanceKm is not null %}
    <div class="distance-chip">
        <i class="fas fa-route"></i>
        {{ distanceKm|number_format(2, '.', ' ') }} km
    </div>
{% else %}
    <div class="distance-chip muted">
        Distance indisponible
    </div>
{% endif %}
                        {# 🔥 ICI CHANGEMENT IMPORTANT #}
                        <a href="{{ path('app_maintenance_taches', {'id_maintenance': m.Id_maintenance}) }}"
                           class="btn-plus">
                            PLUS
                        </a>

                    </div>
                </div>
            {% endfor %}

        </div>
    {% endif %}
</div>
{% endblock %}