{% extends 'front/base_front.html.twig' %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4 text-center">Ajouter une Maintenance</h2>

        {# RQ Workshop : novalidate pour laisser Symfony valider #}
        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(form.Nom_maintenance, "Nom Maintenance") }}
                    {{ form_widget(form.Nom_maintenance, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger">{{ form_errors(form.Nom_maintenance) }}</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Équipement</label>
                    {{ form_widget(form.Equipement, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger">{{ form_errors(form.Equipement) }}</div>
                </div>
                <div class="col-md-4 mb-3">
                    <label>Lieu</label>
                    {{ form_widget(form.Lieu, {'attr': {'class': 'form-control'}}) }}
                    <div class="text-danger">{{ form_errors(form.Lieu) }}</div>
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-4 mb-3">
                    <label>Date (Auto)</label>
                    {# On affiche la date mais on empêche la modif car elle est auto #}
                    {{ form_widget(form.Date_declaration, {'attr': {'class': 'form-control', 'readonly': 'readonly'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Type</label>
                    {{ form_widget(form.Type, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Priorité</label>
                    {{ form_widget(form.Priorite, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="mt-3 mb-3">
                <label>Description</label>
                {{ form_widget(form.Description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
                <div class="text-danger">{{ form_errors(form.Description) }}</div>
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-dark px-5">Soumettre</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}