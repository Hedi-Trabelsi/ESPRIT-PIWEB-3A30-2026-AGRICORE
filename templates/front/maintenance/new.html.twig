{% extends 'front/base_front.html.twig' %}

{% block title %}Ajouter une Maintenance{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4 text-center">Ajouter une Maintenance</h2>

        {{ form_start(form) }}
            <div class="row">
                <div class="col-md-4 mb-3">
                    <label>Nom Maintenance</label>
                    {{ form_widget(form.Nom_maintenance, {'attr': {'class': 'form-control', 'placeholder': 'Nom...'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Équipement</label>
                    {{ form_widget(form.Equipement, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Tracteur'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Lieu</label>
                    {{ form_widget(form.Lieu, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Champ A'}}) }}
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-4 mb-3">
                    <label>Date</label>
                    {{ form_widget(form.Date_declaration, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Type</label>
                    {{ form_widget(form.Type, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-4 mb-3">
                    <label>Priorité</label>
                    {{ form_widget(form.Priorite, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="mt-3 mb-3">
                <label>Description</label>
                {{ form_widget(form.Description, {'attr': {'class': 'form-control', 'rows': '4', 'placeholder': 'Votre message'}}) }}
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-dark px-5">Soumettre</button>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}