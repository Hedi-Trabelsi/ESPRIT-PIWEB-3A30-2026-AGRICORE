{% extends 'front/base_front.html.twig' %}

{% block navbar %}
{% include 'front/partials/_tech_navbar.html.twig' %}
{% endblock %}

{% block title %}Ajouter une Tâche{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4 text-center">Ajouter une tâche</h2>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

        <div class="row">
            <div class="col-md-6 mb-3">
                <label>
                    Nom de la tâche
                    <span class="required-star">*</span>
                </label>
                {{ form_widget(form.nomTache, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small">{{ form_errors(form.nomTache) }}</div>
            </div>

            <div class="col-md-6 mb-3">
                <label>
                    Maintenance associée
                    <span class="required-star">*</span>
                </label>
                {{ form_widget(form.id_maintenance, {'attr': {'class': 'form-control', 'readonly': 'readonly'}}) }}
                <div class="text-danger small">{{ form_errors(form.id_maintenance) }}</div>
            </div>
        </div>

        <div class="row mt-3">
            <div class="col-md-6 mb-3">
                <label>
                    Date prévue
                    <span class="required-star">*</span>
                </label>
                {{ form_widget(form.date_prevue, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small">{{ form_errors(form.date_prevue) }}</div>
            </div>

            <div class="col-md-6 mb-3">
                <label>
                    Coût estimé
                    <span class="required-star">*</span>
                </label>
                {{ form_widget(form.cout_estimee, {'attr': {'class': 'form-control'}}) }}
                <div class="text-danger small">{{ form_errors(form.cout_estimee) }}</div>
            </div>
        </div>

        <div class="mt-3 mb-3">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <label class="mb-0">
                    Description
                    <span class="required-star">*</span>
                </label>
                <button
                    type="button"
                    class="btn btn-outline-success btn-sm"
                    id="generate-description-btn"
                >
                    Générer avec IA
                </button>
            </div>

            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4', 'id': 'tache-description'}}) }}

            <div class="text-danger small" id="ai-description-error">
                {{ form_errors(form.description) }}
            </div>

          
        </div>

        <div class="text-center mt-4">
            <button type="submit" class="btn btn-dark px-5">Enregistrer</button>
            <a href="{{ path('app_maintenance_traiter') }}" class="btn btn-light px-5">Annuler</a>
        </div>

        {{ form_end(form) }}
    </div>
</div>

<style>
.required-star {
    color: red;
    margin-left: 3px;
    transition: color 0.3s;
}
input.filled + .required-star,
textarea.filled + .required-star,
select.filled + .required-star {
    color: green;
}
</style>

{# ========================= #}
{#       IA FIX ONLY        #}
{# ========================= #}
<script>
function initAiDescriptionGenerator() {
    const generateButton = document.getElementById('generate-description-btn');
    const errorBox = document.getElementById('ai-description-error');

    const descriptionField = document.querySelector('textarea[name*="description"]');
    const taskNameField = document.querySelector('[name*="nomTache"]');
    const maintenanceField = document.querySelector('[name*="idMaintenance"], [name*="id_maintenance"]');

    const generateUrl = '{{ path('app_tache_generate_description') }}';

    console.log({
        generateButton,
        descriptionField,
        taskNameField,
        maintenanceField,
        errorBox
    });

    if (!generateButton || !descriptionField || !taskNameField || !maintenanceField || !errorBox) {
        console.error("Erreur : champs IA introuvables.");
        return;
    }

    if (generateButton.dataset.aiBound === '1') return;
    generateButton.dataset.aiBound = '1';

    generateButton.addEventListener('click', async function () {

        const maintenanceId = maintenanceField.value;
        const taskName = taskNameField.value;

        if (!maintenanceId || maintenanceId === '') {
            errorBox.textContent = 'Veuillez sélectionner une maintenance avant de générer la description.';
            return;
        }

        const payload = {
            nomTache: taskName || '',
            id_maintenance: maintenanceId
        };

        generateButton.disabled = true;
        const originalLabel = generateButton.textContent;
        generateButton.textContent = 'Génération en cours...';
        errorBox.textContent = '';

        try {
            const response = await fetch(generateUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify(payload)
            });

            const data = await response.json();

            if (!response.ok) {
                throw new Error(data.error || 'Une erreur est survenue.');
            }

            if (data.description) {
                descriptionField.value = data.description;
                descriptionField.dispatchEvent(new Event('input', { bubbles: true }));
                descriptionField.dispatchEvent(new Event('change', { bubbles: true }));
            }

        } catch (error) {
            console.error("Erreur IA :", error);
            errorBox.textContent = error.message;
        } finally {
            generateButton.disabled = false;
            generateButton.textContent = originalLabel;
        }
    });
}

document.addEventListener('DOMContentLoaded', initAiDescriptionGenerator);
document.addEventListener('turbo:load', initAiDescriptionGenerator);
</script>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const fields = document.querySelectorAll('input, textarea, select');

    fields.forEach(field => {
        const labelStar = field.parentNode.querySelector('.required-star');
        if(!labelStar) return;

        function updateStar() {
            if(field.value.trim() !== '') {
                labelStar.style.color = 'green';
            } else {
                labelStar.style.color = 'red';
            }
        }

        field.addEventListener('input', updateStar);
        updateStar();
    });
});
</script>

{% endblock %}