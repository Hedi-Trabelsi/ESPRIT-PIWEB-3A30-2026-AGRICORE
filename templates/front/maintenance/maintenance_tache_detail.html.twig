{% extends 'front/base_front.html.twig' %}

{% block title %}Détails de la maintenance{% endblock %}

{% block body %}
<style>
    /* Section Titre */
    .header-section {
        margin-bottom: 2rem;
        border-bottom: 1px solid #eee;
        padding-bottom: 20px;
    }

    /* Carte Principale */
    .custom-card {
        background-color: #ffffff;
        border: 1px solid #f0f0f0;
        border-radius: 0 70px 0 70px;
        transition: all 0.4s ease;
        padding: 40px; /* Augmenté pour plus d'espace */
    }

    .card-title-custom {
        font-weight: 800;
        font-size: 1.3rem;
        text-transform: uppercase;
        color: #0F4229;
    }

    .card-info-val {
        color: #555;
        font-weight: 500;
        font-size: 0.95rem;
        margin-bottom: 10px;
    }

    /* Actions */
    .btn-action-simple {
        border: none;
        background: none;
        padding: 8px 15px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: 0.2s;
        text-decoration: none;
    }
  .btn-edit-text { 
        color: #0F4229; /* Vert sapin identique à ton thème */
        font-weight: 600;
    }
    
    .btn-delete-text { 
        color: #6c757d; /* Gris élégant et sobre */
        font-weight: 600;
    }
    /* Tâches */
    .task-card {
        border: 1px solid #f0f0f0;
        border-radius: 20px;
        transition: all 0.3s ease;
        cursor: pointer;
        overflow: hidden;
        background-color: #fff;
    }

    .task-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }

    .task-card.active {
        background-color: #f8f9fa;
        border-color: #198754;
    }

    .task-card-details {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.3s ease-out, opacity 0.3s ease;
        opacity: 0;
    }

    .task-card.active .task-card-details {
        max-height: 500px;
        padding-top: 1rem;
        margin-top: 1rem;
        border-top: 1px solid #e9ecef;
        opacity: 1;
    }
</style>

<div class="container mt-5">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <div class="header-section d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-3">
        <div>
            <h1 class="fw-bold m-0">{{ maintenance.nomMaintenance }}</h1>
            <div class="mt-2">
                Statut : <span class="{% if maintenance.Statut in ['Résolu', 'Résolue'] %}text-success fw-bold{% else %}text-warning{% endif %}">{{ maintenance.Statut }}</span>
            </div>
        </div>
        
        <div class="d-flex gap-2">
            {% if maintenance.Statut not in ['Résolu', 'Résolue'] %}
                <a href="{{ path('app_maintenance_edit', {'id_maintenance': maintenance.Id_maintenance}) }}" class="btn-action-simple btn-edit-text">
                    <i class="fas fa-edit me-1"></i> Modifier
                </a>
                <button type="button" class="btn-action-simple btn-delete-text" data-bs-toggle="modal" data-bs-target="#confirmDeleteMaintenanceModal">
                    <i class="fas fa-trash me-1"></i> Supprimer
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-12">
            <div class="custom-card shadow-sm text-start"> {# Alignement à gauche ici #}
                <h5 class="card-title-custom mb-4">Informations Générales</h5>
                
                <div class="row g-3">
                    <div class="col-md-4 card-info-val">
                        <small class="text-muted d-block">Type d'intervention</small>
                        <span>{{ maintenance.Type }}</span>
                    </div>
                    <div class="col-md-4 card-info-val">
                        <small class="text-muted d-block">Équipement concerné</small>
                        <span>{{ maintenance.Equipement }}</span>
                    </div>
                    <div class="col-md-4 card-info-val">
                        <small class="text-muted d-block">Localisation</small>
                        <span><i class="fas fa-map-marker-alt me-1 text-secondary"></i> {{ maintenance.Lieu }}</span>
                    </div>
                    <div class="col-md-4 card-info-val">
                        <small class="text-muted d-block">Date de déclaration</small>
                        <span>{{ maintenance.dateDeclaration|date('d/m/Y') }}</span>
                    </div>
                    <div class="col-md-4 card-info-val">
                        <small class="text-muted d-block">Niveau de priorité</small>
                        <span class="{% if maintenance.Priorite == 'Urgente' %}text-danger fw-bold{% endif %}">
                            {{ maintenance.Priorite }}
                        </span>
                    </div>
                </div>

                <div class="mt-4 pt-3 border-top">
                    <h6 class="fw-bold">Description du problème :</h6>
                    <p class="text-secondary mb-0" style="line-height: 1.6;">{{ maintenance.Description|nl2br }}</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <h3 class="fw-bold">Travaux & Tâches</h3>
    </div>

    {% if maintenance.getTaches().isEmpty() %}
        <div class="alert alert-light border text-center py-4">
            <i class="fas fa-info-circle me-2"></i> Aucune tâche n'a encore été planifiée.
        </div>
    {% else %}
        <div class="row g-4">
            {% for tache in maintenance.getTaches() %}
                <div class="col-lg-4 col-md-6">
                    <div class="task-card p-4 shadow-sm" onclick="toggleTask(this)">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="fw-bold mb-0" style="font-size: 1rem; color: #0F4229;">{{ tache.nomTache }}</h5>
                            <span class="text-success fw-bold">{{ tache.getCoutEstimee() }} €</span>
                        </div>
                        
                        <div class="task-card-details text-start">
                            <div class="card-info-val">
                                <small class="text-muted">Intervention prévue le :</small>
                                <div class="fw-bold">{{ tache.getDatePrevue()|date('d/m/Y') }}</div>
                            </div>
                            <div class="card-info-val">
                                <small class="text-muted">Technicien assigné :</small>
                                <div>
                                    {% if tache.getIdTechnicien() %}
                                        <i class="fas fa-user-check me-1 small"></i> {{ tache.getIdTechnicien().nom }} {{ tache.getIdTechnicien().prenom }}
                                    {% else %}
                                        <span class="text-muted italic">En attente d'assignation</span>
                                    {% endif %}
                                </div>
                            </div>
                            <div class="mt-2">
                                <small class="text-muted d-block mb-1">Notes techniques :</small>
                                <p class="small text-secondary mb-0">{{ tache.description|nl2br }}</p>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</div>

<script>
    function toggleTask(element) {
        const isActive = element.classList.contains('active');
        
        // On ferme toutes les cartes d'abord
        document.querySelectorAll('.task-card').forEach(card => {
            card.classList.remove('active');
        });

        // Si celle sur laquelle on a cliqué n'était pas active, on l'ouvre
        if (!isActive) {
            element.classList.add('active');
        }
    }
</script>

<div class="modal fade" id="confirmDeleteMaintenanceModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content shadow border-0">
            <div class="modal-body text-center py-4">
                <i class="fas fa-exclamation-circle text-danger mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold">Supprimer ?</h5>
                <p class="text-muted small">Voulez-vous vraiment retirer cette fiche de maintenance ?</p>
                <div class="d-flex justify-content-center gap-2 mt-4">
                    <button type="button" class="btn btn-light btn-sm px-3" data-bs-dismiss="modal">Annuler</button>
                    <form method="post" action="{{ path('app_maintenance_delete', {'id_maintenance': maintenance.Id_maintenance}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ maintenance.Id_maintenance) }}">
                        <button type="submit" class="btn btn-danger btn-sm px-3">Confirmer</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}