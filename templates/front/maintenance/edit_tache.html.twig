{% extends 'front/base_front.html.twig' %}

{% block navbar %}
<!-- Navbar Start -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
    <a href="{{ path('app_home') }}" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <img src="{{ asset('img/logo.png') }}" alt="Logo" style="height: 40px; width: auto;" />
    </a>
    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto p-4 p-lg-0">
            <a href="{{ path('app_home') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_home' %} active{% endif %}">Accueil</a>
            <a href="{{ path('app_about') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_about' %} active{% endif %}">À propos</a>
            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle{% if app.request.attributes.get('_route') in ['app_tech_home', 'app_maintenance_traiter', 'app_maintenance', 'app_tache_new', 'app_tache_edit'] %} active{% endif %}" data-bs-toggle="dropdown">Maintenances</a>
                <div class="dropdown-menu bg-light m-0">
                    <a href="{{ path('app_maintenance_traiter') }}" class="dropdown-item">Interventions à traiter</a>
                    <a href="{{ path('app_maintenance') }}" class="dropdown-item">Historique des maintenances</a>
                </div>
            </div>
            <a href="{{ path('app_contact') }}" class="nav-item nav-link{% if app.request.attributes.get('_route') == 'app_contact' %} active{% endif %}">Contact</a>
        </div>
        <a href="{{ path('app_profile') }}" class="d-none d-lg-block me-4">
            <img src="{{ asset('img/profile.webp') }}" alt="Profile"
                 style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #198754;">
        </a>
    </div>
</nav>
<!-- Navbar End -->
{% endblock %}

{% block title %}Modifier une Tâche{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="card shadow p-4">
        <h2 class="mb-4 text-center">Modifier la tâche</h2>

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.nomTache, 'Nom de la tâche') }}
                    {{ form_widget(form.nomTache, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.id_maintenance, 'Maintenance associée') }}
                    {{ form_widget(form.id_maintenance, {'attr': {'class': 'form-control', 'readonly': 'readonly'}}) }}
                </div>
            </div>

            <div class="row mt-3">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.date_prevue, 'Date prévue') }}
                    {{ form_widget(form.date_prevue, {'attr': {'class': 'form-control'}}) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.cout_estimee, 'Coût estimé') }}
                    {{ form_widget(form.cout_estimee, {'attr': {'class': 'form-control'}}) }}
                </div>
            </div>

            <div class="mt-3 mb-3">
                {{ form_label(form.description, 'Description') }}
                {{ form_widget(form.description, {'attr': {'class': 'form-control', 'rows': '4'}}) }}
            </div>

            <div class="text-center mt-4">
                <button type="submit" class="btn btn-dark px-5">Enregistrer les modifications</button>
                <a href="{{ path('app_maintenance_taches', {'id_maintenance': tache.idMaintenance.id_maintenance}) }}" class="btn btn-light px-5">Annuler</a>
            </div>
        {{ form_end(form) }}
    </div>
</div>
{% endblock %}