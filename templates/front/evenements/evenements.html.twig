{% extends 'front/base_front.html.twig' %}

{% block title %}Événements - AgriCore Experience{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>

<style>
    :root {
        --agri-orange: #fd7e14;
        --agri-green: #198754;
        --glass-bg: rgba(255, 255, 255, 0.8);
        --glass-border: rgba(255, 255, 255, 0.5);
    }

    body {
        background: #f8fafc;
        background-image:
            radial-gradient(at 0% 0%, rgba(25, 135, 84, 0.05) 0px, transparent 50%),
            radial-gradient(at 100% 100%, rgba(253, 126, 20, 0.05) 0px, transparent 50%);
        min-height: 100vh;
    }

    /* --- Hero Section --- */
    .hero-visual {
        height: 380px;
        background: linear-gradient(135deg, rgba(0,0,0,0.4), rgba(0,0,0,0.7)), url('{{ asset('img/evenement.jpg') }}');
        background-size: cover;
        background-attachment: fixed;
        border-radius: 0 0 50px 50px;
        display: flex; align-items: center; justify-content: center;
        box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    }

    /* --- Search Engine (Adjusted: Lower and Taller) --- */
    .search-container-floating {
        margin-top: 15px; /* Descendu légèrement (était -40px) */
        margin-bottom: 50px;
        z-index: 100;
        position: relative;
    }

    .glass-search-box {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 2px solid var(--glass-border);
        border-radius: 35px;
        padding: 50px; /* Plus grand (était 30px) pour une meilleure vue des filtres */
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
    }

    .custom-input, .custom-select {
        background: rgba(255,255,255,0.9);
        border: 1px solid #e2e8f0 !important;
        height: 52px; border-radius: 18px !important;
        padding-left: 20px; font-weight: 500; transition: 0.3s all;
    }

    /* --- Status Pills (Previous Design) --- */
    .pill-btn {
        white-space: nowrap; border-radius: 15px; padding: 12px 28px;
        font-weight: 700; transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        border: 1px solid var(--glass-border); background: white;
        cursor: pointer;
    }

    .pill-btn.active {
        background: var(--agri-orange); color: white;
        transform: scale(1.1) rotate(-2deg);
        box-shadow: 0 10px 20px rgba(253, 126, 20, 0.3);
    }

    /* --- Cards Design & Icon Animation --- */
    .event-card { perspective: 1000px; transition: 0.5s; }

    .card-glass-morph {
        background: white; border: 1px solid #f1f5f9;
        border-radius: 35px; overflow: hidden; height: 100%;
        transition: 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
        display: flex; flex-direction: column;
    }

    .event-card:hover .card-glass-morph {
        transform: translateY(-15px) rotateX(4deg) rotateY(-2deg);
        box-shadow: 0 40px 80px rgba(0,0,0,0.1);
    }

    .card-header-visual {
        height: 140px;
        background: linear-gradient(135deg, #f8fafc, #e2e8f0);
        position: relative; display: flex; align-items: center; justify-content: center;
    }

    .dynamic-icon {
        transition: 0.5s;
        filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));
    }

    .event-card:hover .dynamic-icon {
        transform: scale(1.3) rotate(8deg);
        color: var(--agri-orange) !important;
        opacity: 1 !important;
    }

    .price-badge-refined {
        position: absolute; bottom: -20px; right: 30px;
        background: var(--agri-green); color: white;
        padding: 12px 24px; border-radius: 20px;
        font-weight: 800; box-shadow: 0 10px 20px rgba(25, 135, 84, 0.2);
    }

    .btn-discover {
        background: #1e293b; color: white; border-radius: 20px;
        padding: 15px; font-weight: 700; transition: 0.3s;
        text-align: center; text-decoration: none;
    }

    .btn-discover:hover { background: var(--agri-orange); color: white; }

    .info-row { font-size: 0.85rem; color: #64748b; display: flex; align-items: center; gap: 8px; }

    /* ── View toggle ── */
    .view-toggle-group {
        display: flex; gap: 6px;
        background: white; border-radius: 16px;
        padding: 5px; border: 1px solid #e2e8f0;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .view-btn {
        width: 40px; height: 40px;
        border: none; border-radius: 12px;
        background: transparent; color: #94a3b8;
        font-size: 1rem; cursor: pointer; transition: 0.2s;
        display: flex; align-items: center; justify-content: center;
    }
    .view-btn.active { background: var(--agri-green); color: white; box-shadow: 0 4px 12px rgba(25,135,84,0.3); }
    .view-btn:hover:not(.active) { background: #f1f5f9; color: var(--agri-dark); }

    /* ── FullCalendar overrides ── */
    #fullcalendar {
        background: white;
        border-radius: 28px;
        padding: 28px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.06);
        border: 1px solid #f1f5f9;
    }
    .fc .fc-toolbar-title { font-weight: 800; font-size: 1.2rem; color: #1e293b; }
    .fc .fc-button-primary {
        background: var(--agri-green) !important;
        border-color: var(--agri-green) !important;
        border-radius: 10px !important;
        font-weight: 700 !important;
        box-shadow: none !important;
    }
    .fc .fc-button-primary:hover { background: #157347 !important; border-color: #157347 !important; }
    .fc .fc-button-primary:not(:disabled).fc-button-active { background: #0f5132 !important; border-color: #0f5132 !important; }
    .fc-daygrid-day-number, .fc-col-header-cell-cushion { color: #1e293b; font-weight: 700; text-decoration: none; }
    .fc-day-today { background: rgba(25,135,84,0.06) !important; }
    .fc-event {
        border-radius: 8px !important;
        border: none !important;
        padding: 3px 8px !important;
        font-size: 0.78rem !important;
        font-weight: 700 !important;
        cursor: pointer;
    }
    .fc-event:hover { opacity: 0.85; transform: scale(1.02); }
    .fc-daygrid-event-dot { display: none; }

    /* Event tooltip */
    .cal-tooltip {
        position: fixed;
        background: white;
        border-radius: 18px;
        padding: 16px 20px;
        box-shadow: 0 20px 50px rgba(0,0,0,0.15);
        border: 1px solid #e2e8f0;
        z-index: 9999;
        min-width: 220px;
        pointer-events: none;
        animation: tooltipIn 0.2s ease;
    }
    @keyframes tooltipIn {
        from { opacity: 0; transform: translateY(6px) scale(0.97); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
    }
    .cal-tooltip h6 { font-weight: 800; color: #1e293b; margin: 0 0 8px; font-size: 0.9rem; }
    .cal-tooltip .tip-row { font-size: 0.78rem; color: #64748b; display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
    .cal-tooltip .tip-row i { color: var(--agri-green); width: 14px; }
</style>

<div class="hero-visual animate__animated animate__fadeIn">
    <div class="text-center text-white">
        <h1 class="display-1 fw-black mb-0">AGRICORE</h1>
        <div class="h4 fw-light opacity-80">Intelligence & Culture</div>
    </div>
</div>

<div class="container search-container-floating">
    <div class="glass-search-box animate__animated animate__fadeInUp">
        <div class="row g-4 align-items-end">
            <div class="col-lg-4">
                <label class="small fw-bold text-muted mb-2 ms-2">Recherche</label>
                <input type="text" id="search" class="form-control custom-input" placeholder="Quel futur cherchez-vous ?">
            </div>
            <div class="col-lg-2">
                <label class="small fw-bold text-muted mb-2 ms-2">Trier Prix</label>
                <select id="sortPrice" class="form-select custom-select">
                    <option value="none">Pertinence</option>
                    <option value="asc">Croissant</option>
                    <option value="desc">Décroissant</option>
                </select>
            </div>
            <div class="col-lg-3">
                <div class="d-flex justify-content-between">
                    <label class="small fw-bold text-muted mb-2 ms-2">Date</label>
                    <span id="resetDate" class="text-danger small fw-bold" style="cursor:pointer; display:none;">Reset</span>
                </div>
                <input type="date" id="filterDate" class="form-control custom-input">
            </div>
            <div class="col-lg-3">
                <label class="small fw-bold text-muted mb-2">Budget Max : <span class="text-success" id="budgetValue">500</span> DT</label>
                <input type="range" id="filterBudget" class="form-range" min="0" max="500" value="500">
            </div>
        </div>

        <hr class="my-5 opacity-10"> <div class="d-flex justify-content-center gap-4 overflow-auto pb-2">
            <button class="pill-btn active" data-filter="TOUT">Tous</button>
            <button class="pill-btn" data-filter="EN_COURS">Maintenant</button>
            <button class="pill-btn" data-filter="COMING">À venir</button>
            <button class="pill-btn" data-filter="HISTORIQUE">Archives</button>
        </div>
    </div>
</div>

<div class="container mb-5">

    {# ── View toggle ── #}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="fw-bold text-dark mb-0" id="viewLabel">Tous les événements</h5>
        <div class="view-toggle-group">
            <button class="view-btn active" id="btnGrid" title="Vue grille">
                <i class="fas fa-th-large"></i>
            </button>
            <button class="view-btn" id="btnCal" title="Vue calendrier">
                <i class="fas fa-calendar-alt"></i>
            </button>
        </div>
    </div>

    {# ── Cards grid ── #}
    <div id="gridView">
        <div class="row g-4" id="eventContainer">
        {% for ev in evenements %}
            <div class="col-xl-4 col-md-6 event-item"
                 data-title="{{ ev.evenement.titre|lower }}"
                 data-status="{{ ev.status }}"
                 data-date="{{ ev.evenement.date_debut|date('Y-m-d') }}"
                 data-price="{{ ev.evenement.frais_inscription }}">

                <div class="event-card">
                    <div class="card-glass-morph">
                        <div class="card-header-visual">
                            {% set titre = ev.evenement.titre|lower %}
                            {% if 'formation' in titre %}
                                <i class="fas fa-graduation-cap fa-4x dynamic-icon text-primary opacity-25"></i>
                            {% elseif 'tractor' in titre or 'tracteur' in titre %}
                                <i class="fas fa-tractor fa-4x dynamic-icon text-secondary opacity-25"></i>
                            {% else %}
                                <i class="fas fa-leaf fa-4x dynamic-icon text-success opacity-25"></i>
                            {% endif %}

                            <div class="price-badge-refined">
                                {{ ev.evenement.frais_inscription }} <small>DT</small>
                            </div>
                        </div>

                        <div class="p-4 pt-5 d-flex flex-column flex-grow-1">
                            <div class="mb-2">
                                {% if ev.status == 'EN_COURS' %}
                                    <span class="badge bg-warning text-dark rounded-pill shadow-sm">● LIVE</span>
                                {% elseif ev.status == 'COMING' %}
                                    <span class="badge bg-primary rounded-pill shadow-sm">FUTURE</span>
                                {% else %}
                                    <span class="badge bg-secondary rounded-pill shadow-sm">CLOSED</span>
                                {% endif %}
                            </div>

                            <h4 class="fw-bold text-dark mb-3">{{ ev.evenement.titre }}</h4>

                            <div class="mt-auto">
                                <div class="d-flex justify-content-between mb-4 border-top pt-3">
                                    <div class="info-row"><i class="far fa-calendar-alt text-success"></i> {{ ev.evenement.date_debut|date('d/m/Y') }}</div>
                                    <div class="info-row"><i class="fas fa-users text-success"></i> {{ ev.placesRestantes }}</div>
                                </div>
                                <a href="{{ path('app_evenement_show', {'id': ev.evenement.id_ev}) }}" class="btn-discover w-100 d-block text-decoration-none">
                                    Voir Détails
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
    </div>{# end gridView #}

    {# ── Calendar view ── #}
    <div id="calView" style="display:none;">
        <div id="fullcalendar"></div>
    </div>

</div>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css"/>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        // ── Grid filters ──
        const sInp = document.getElementById('search');
        const dInp = document.getElementById('filterDate');
        const bInp = document.getElementById('filterBudget');
        const sortSel = document.getElementById('sortPrice');
        const pBtns = document.querySelectorAll('.pill-btn');
        const container = document.getElementById('eventContainer');

        function update() {
            const s = sInp.value.toLowerCase().trim();
            const d = dInp.value;
            const b = parseFloat(bInp.value);
            const st = document.querySelector('.pill-btn.active').dataset.filter;
            const sortMode = sortSel.value;

            document.getElementById('budgetValue').textContent = b;
            document.getElementById('resetDate').style.display = d ? 'inline' : 'none';

            let items = Array.from(document.querySelectorAll('.event-item'));
            items.forEach(c => {
                const matchS = c.dataset.title.includes(s);
                const matchSt = (st === 'TOUT' || c.dataset.status === st);
                const matchD = !d || c.dataset.date >= d;
                const matchB = parseFloat(c.dataset.price) <= b;
                c.style.display = (matchS && matchSt && matchD && matchB) ? 'block' : 'none';
            });

            if (sortMode !== 'none') {
                items.sort((a, b) => {
                    const pA = parseFloat(a.dataset.price);
                    const pB = parseFloat(b.dataset.price);
                    return sortMode === 'asc' ? pA - pB : pB - pA;
                });
                items.forEach(i => container.appendChild(i));
            }
        }

        [sInp, dInp, bInp, sortSel].forEach(el => el.addEventListener('input', update));
        pBtns.forEach(btn => btn.addEventListener('click', function() {
            pBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            update();
        }));
        document.getElementById('resetDate').addEventListener('click', () => { dInp.value = ''; update(); });

        // ── View toggle ──
        const btnGrid = document.getElementById('btnGrid');
        const btnCal  = document.getElementById('btnCal');
        const gridView = document.getElementById('gridView');
        const calView  = document.getElementById('calView');
        const viewLabel = document.getElementById('viewLabel');

        let calInitialized = false;
        let calendar;

        btnGrid.addEventListener('click', () => {
            btnGrid.classList.add('active');
            btnCal.classList.remove('active');
            gridView.style.display = '';
            calView.style.display = 'none';
            viewLabel.textContent = 'Tous les événements';
        });

        btnCal.addEventListener('click', () => {
            btnCal.classList.add('active');
            btnGrid.classList.remove('active');
            gridView.style.display = 'none';
            calView.style.display = '';
            viewLabel.textContent = 'Calendrier des événements';
            if (!calInitialized) {
                initCalendar();
                calInitialized = true;
            }
        });

        // ── FullCalendar ──
        function initCalendar() {
            const el = document.getElementById('fullcalendar');
            let tooltip = null;

            calendar = new FullCalendar.Calendar(el, {
                initialView: 'dayGridMonth',
                locale: 'fr',
                height: 'auto',
                headerToolbar: {
                    left: 'prev,next today',
                    center: 'title',
                    right: 'dayGridMonth,timeGridWeek,listMonth'
                },
                buttonText: {
                    today: "Aujourd'hui",
                    month: 'Mois',
                    week: 'Semaine',
                    list: 'Liste'
                },
                events: {
                    url: '/fc-load-events',
                    method: 'POST',
                    extraParams: { filters: JSON.stringify({}) },
                    failure: function() { console.error('Erreur chargement événements'); }
                },
                eventClick: function(info) {
                    info.jsEvent.preventDefault();
                    window.location.href = info.event.url;
                },
                eventMouseEnter: function(info) {
                    removeTooltip();
                    const p = info.event.extendedProps;
                    tooltip = document.createElement('div');
                    tooltip.className = 'cal-tooltip';
                    tooltip.innerHTML = `
                        <h6>${info.event.title}</h6>
                        <div class="tip-row"><i class="fas fa-map-marker-alt"></i> ${p.lieu || 'N/A'}</div>
                        <div class="tip-row"><i class="fas fa-tag"></i> ${p.prix} DT</div>
                        <div class="tip-row"><i class="fas fa-users"></i> ${p.places} places restantes</div>
                        <div class="tip-row" style="margin-top:8px;color:#198754;font-weight:700;font-size:0.75rem;">
                            <i class="fas fa-arrow-right"></i> Cliquer pour voir les détails
                        </div>`;
                    document.body.appendChild(tooltip);
                    positionTooltip(info.jsEvent);
                },
                eventMouseLeave: removeTooltip,
                eventDidMount: function(info) {
                    info.el.style.transition = 'transform 0.15s, opacity 0.15s';
                }
            });

            calendar.render();

            document.addEventListener('mousemove', function(e) {
                if (tooltip) positionTooltip(e);
            });

            function positionTooltip(e) {
                if (!tooltip) return;
                const x = e.clientX + 16;
                const y = e.clientY + 16;
                const tw = tooltip.offsetWidth;
                const th = tooltip.offsetHeight;
                tooltip.style.left = (x + tw > window.innerWidth ? x - tw - 32 : x) + 'px';
                tooltip.style.top  = (y + th > window.innerHeight ? y - th - 32 : y) + 'px';
            }

            function removeTooltip() {
                if (tooltip) { tooltip.remove(); tooltip = null; }
            }
        }
    });
</script>
{% endblock %}