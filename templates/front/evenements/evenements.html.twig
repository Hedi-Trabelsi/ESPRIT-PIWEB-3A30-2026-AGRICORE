{% extends 'front/base_front.html.twig' %}

{% block title %}Événements - AgriCore{% endblock %}

{% block body %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css"/>
<style>
:root {
    --g: #16a34a;
    --g2: #22c55e;
    --orange: #f97316;
    --dark: #0f172a;
    --muted: #64748b;
}

body { background: #f8fafc; }

/* ── Hero ── */
.ev-hero {
    height: 420px;
    background: linear-gradient(160deg, rgba(15,23,42,.7) 0%, rgba(22,163,74,.5) 100%),
                url('{{ asset('img/evenement.jpg') }}') center/cover no-repeat fixed;
    display: flex; align-items: center; justify-content: center;
    clip-path: ellipse(120% 100% at 50% 0%);
    position: relative;
}
.ev-hero-title { font-size: clamp(2.5rem,6vw,5rem); font-weight: 900; color: #fff; letter-spacing: -2px; }
.ev-hero-sub   { color: rgba(255,255,255,.75); font-size: 1.1rem; font-weight: 400; }

/* ── Filter bar ── */
.filter-bar {
    background: #fff;
    border-radius: 24px;
    padding: 28px 32px;
    box-shadow: 0 8px 40px rgba(0,0,0,.07);
    margin-top: -60px;
    position: relative;
    z-index: 10;
}
.filter-input {
    border: 1.5px solid #e2e8f0;
    border-radius: 14px;
    padding: 11px 18px;
    font-size: .88rem;
    background: #f8fafc;
    outline: none;
    transition: .2s;
    width: 100%;
}
.filter-input:focus { border-color: var(--g); background: #fff; box-shadow: 0 0 0 3px rgba(22,163,74,.1); }

.status-tabs { display: flex; gap: 8px; flex-wrap: wrap; }
.stab {
    padding: 10px 26px; border-radius: 15px;
    border: 1px solid rgba(255,255,255,0.5);
    background: white; font-size: .85rem; font-weight: 700;
    cursor: pointer; transition: .4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    color: var(--muted); text-decoration: none; display: inline-block;
}
.stab:hover { color: var(--dark); border-color: #e2e8f0; }
.stab.active {
    background: var(--orange); color: #fff; border-color: var(--orange);
    transform: scale(1.08) rotate(-2deg);
    box-shadow: 0 10px 20px rgba(249,115,22,.3);
}

/* ── View toggle ── */
.view-toggle { display: flex; gap: 4px; background: #f1f5f9; border-radius: 12px; padding: 4px; }
.vtab { width: 36px; height: 36px; border: none; border-radius: 9px; background: transparent; color: #94a3b8; cursor: pointer; transition: .2s; display: flex; align-items: center; justify-content: center; }
.vtab.active { background: #fff; color: var(--g); box-shadow: 0 2px 8px rgba(0,0,0,.08); }

/* ── Cards ── */
.ev-card {
    border-radius: 22px;
    overflow: hidden;
    background: #fff;
    box-shadow: 0 2px 16px rgba(0,0,0,.06);
    transition: transform .35s cubic-bezier(.2,.8,.2,1), box-shadow .35s;
    display: flex; flex-direction: column;
    height: 100%;
}
.ev-card:hover { transform: translateY(-10px); box-shadow: 0 24px 60px rgba(0,0,0,.12); }

.ev-card-img {
    height: 180px;
    position: relative;
    overflow: hidden;
    background: linear-gradient(135deg, #e2e8f0, #f1f5f9);
    display: flex; align-items: center; justify-content: center;
}
.ev-card-img .ev-icon {
    font-size: 4.5rem;
    opacity: 0.6;
    transition: .4s;
    filter: drop-shadow(0 5px 15px rgba(0,0,0,0.1));
}
.ev-card:hover .ev-icon { opacity: 1; transform: scale(1.25) rotate(8deg); }

.ev-card-img .ev-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, transparent 40%, rgba(15,23,42,.55));
}

.ev-price {
    position: absolute; top: 14px; right: 14px;
    background: var(--g); color: #fff;
    font-size: .78rem; font-weight: 800;
    padding: 5px 14px; border-radius: 50px;
    box-shadow: 0 4px 12px rgba(22,163,74,.35);
    letter-spacing: .3px;
}
.ev-price.free { background: var(--orange); box-shadow: 0 4px 12px rgba(249,115,22,.35); }

.ev-status-ribbon {
    position: absolute; bottom: 14px; left: 14px;
    font-size: .7rem; font-weight: 800; letter-spacing: .8px;
    padding: 4px 12px; border-radius: 50px; text-transform: uppercase;
}
.ribbon-live   { background: rgba(249,115,22,.9); color: #fff; }
.ribbon-coming { background: rgba(59,130,246,.9);  color: #fff; }
.ribbon-closed { background: rgba(100,116,139,.8); color: #fff; }

.ev-card-body { padding: 20px 22px 22px; display: flex; flex-direction: column; flex: 1; }
.ev-card-title { font-size: 1rem; font-weight: 800; color: var(--dark); margin-bottom: 10px; line-height: 1.3; }

.ev-meta { display: flex; align-items: center; gap: 6px; font-size: .78rem; color: var(--muted); }
.ev-meta i { color: var(--g); width: 14px; }

.ev-capacity-bar { height: 5px; background: #e2e8f0; border-radius: 10px; overflow: hidden; margin: 14px 0 6px; }
.ev-capacity-fill { height: 100%; background: linear-gradient(90deg, var(--g), var(--g2)); border-radius: 10px; transition: width .6s ease; }

.btn-ev {
    display: block; text-align: center; text-decoration: none;
    background: var(--dark); color: #fff;
    border-radius: 14px; padding: 12px;
    font-size: .85rem; font-weight: 700;
    transition: .25s; margin-top: auto;
}
.btn-ev:hover { background: var(--g); color: #fff; box-shadow: 0 6px 20px rgba(22,163,74,.3); }

/* ── Participant avatar stack ── */
.avatar-stack {
    display: flex; align-items: center; margin-bottom: 14px;
}
.avatar-stack .av {
    width: 30px; height: 30px;
    border-radius: 50%;
    border: 2px solid #fff;
    margin-left: -8px;
    object-fit: cover;
    box-shadow: 0 2px 6px rgba(0,0,0,.12);
    background: linear-gradient(135deg, #6366f1, #8b5cf6);
    display: flex; align-items: center; justify-content: center;
    font-size: .65rem; font-weight: 800; color: #fff;
    flex-shrink: 0;
    overflow: hidden;
}
.avatar-stack .av:first-child { margin-left: 0; }
.avatar-stack .av img { width: 100%; height: 100%; object-fit: cover; }
.avatar-stack .av-more {
    background: #f1f5f9; color: var(--muted);
    font-size: .65rem; font-weight: 800;
    border: 2px solid #fff;
}
.avatar-stack .av-label {
    margin-left: 10px; font-size: .75rem;
    color: var(--muted); font-weight: 600;
    white-space: nowrap;
}

/* ── Calendar ── */
#fullcalendar {
    background: #fff;
    border-radius: 24px;
    padding: 32px;
    box-shadow: 0 8px 40px rgba(0,0,0,.07);
}
.fc .fc-toolbar {
    margin-bottom: 24px;
    flex-wrap: wrap;
    gap: 12px;
}
.fc .fc-toolbar-title {
    font-weight: 900;
    font-size: 1.4rem;
    color: var(--dark);
    letter-spacing: -0.5px;
}
.fc .fc-button {
    border-radius: 10px !important;
    font-weight: 700 !important;
    font-size: .82rem !important;
    padding: 8px 16px !important;
    box-shadow: none !important;
    border: none !important;
    transition: .2s !important;
}
.fc .fc-button-primary {
    background: var(--g) !important;
    border-color: var(--g) !important;
}
.fc .fc-button-primary:hover {
    background: #15803d !important;
    transform: translateY(-1px);
}
.fc .fc-button-primary:not(:disabled).fc-button-active {
    background: var(--dark) !important;
    border-color: var(--dark) !important;
}
.fc .fc-button-group {
    gap: 4px;
}
.fc-theme-standard td, .fc-theme-standard th {
    border-color: #f1f5f9 !important;
}
.fc-theme-standard .fc-scrollgrid {
    border-color: #f1f5f9 !important;
    border-radius: 16px;
    overflow: hidden;
}
.fc .fc-col-header-cell {
    background: #f8fafc;
    padding: 12px 0 !important;
}
.fc-col-header-cell-cushion {
    color: var(--muted) !important;
    font-weight: 800 !important;
    font-size: .78rem !important;
    text-transform: uppercase;
    letter-spacing: .5px;
    text-decoration: none !important;
}
.fc-daygrid-day-number {
    color: var(--dark) !important;
    font-weight: 700 !important;
    font-size: .85rem !important;
    text-decoration: none !important;
    padding: 8px 10px !important;
}
.fc-day-today {
    background: rgba(22,163,74,.04) !important;
}
.fc-day-today .fc-daygrid-day-number {
    background: var(--g);
    color: #fff !important;
    border-radius: 50%;
    width: 28px; height: 28px;
    display: flex; align-items: center; justify-content: center;
    margin: 6px;
    padding: 0 !important;
}
.fc-event {
    border-radius: 8px !important;
    border: none !important;
    padding: 3px 8px !important;
    font-size: .75rem !important;
    font-weight: 700 !important;
    cursor: pointer;
    transition: transform .15s, opacity .15s !important;
    margin-bottom: 2px !important;
}
.fc-event:hover {
    opacity: .88;
    transform: translateY(-1px);
}
.fc-daygrid-event-dot { display: none; }
.fc-event-title { font-weight: 700 !important; }
.fc-daygrid-day-frame { min-height: 90px !important; }

/* List view */
.fc-list-event:hover td { background: #f0fdf4 !important; }
.fc-list-event-title a { color: var(--dark) !important; font-weight: 700 !important; text-decoration: none !important; }
.fc-list-day-cushion { background: #f8fafc !important; }
.fc-list-day-text, .fc-list-day-side-text { color: var(--dark) !important; font-weight: 800 !important; }

/* Week view time */
.fc-timegrid-slot-label-cushion { color: var(--muted) !important; font-size: .75rem !important; font-weight: 600 !important; }
.fc-timegrid-now-indicator-line { border-color: var(--orange) !important; border-width: 2px !important; }
.fc-timegrid-now-indicator-arrow { border-top-color: var(--orange) !important; border-bottom-color: var(--orange) !important; }

.cal-tooltip {
    position: fixed; background: #fff; border-radius: 16px;
    padding: 14px 18px; box-shadow: 0 16px 50px rgba(0,0,0,.14);
    border: 1px solid #e2e8f0; z-index: 9999; min-width: 210px;
    pointer-events: none; animation: tipIn .18s ease;
}
@keyframes tipIn { from { opacity:0; transform:translateY(6px); } to { opacity:1; transform:none; } }
.cal-tooltip h6 { font-weight: 800; color: var(--dark); margin: 0 0 8px; font-size: .88rem; }
.cal-tooltip .tr { font-size: .76rem; color: var(--muted); display: flex; align-items: center; gap: 6px; margin-bottom: 4px; }
.cal-tooltip .tr i { color: var(--g); width: 13px; }

/* ── Section header ── */
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 28px; }
.section-header h4 { font-weight: 800; color: var(--dark); margin: 0; font-size: 1.15rem; }
.count-badge { background: #f0fdf4; color: var(--g); font-size: .75rem; font-weight: 800; padding: 4px 12px; border-radius: 50px; border: 1px solid #bbf7d0; }
</style>

<!-- Hero -->
<div class="ev-hero">
    <div class="text-center">
        <div class="ev-hero-title">AgriCore Events</div>
        <div class="ev-hero-sub">Découvrez, participez, innovez</div>
    </div>
</div>

<div class="container" style="margin-top: -60px; position: relative; z-index: 10;">

    <!-- Filter bar -->
    <div class="filter-bar mb-5">
        <form method="get" action="{{ path('app_evenement') }}" id="filterForm">
            <input type="hidden" name="filter" id="filterHidden" value="{{ filter }}">
            <div class="row g-3 align-items-end mb-4">
                <div class="col-lg-4">
                    <label class="small fw-bold text-muted mb-1 d-block">Recherche</label>
                    <div class="position-relative">
                        <i class="fas fa-search position-absolute" style="left:14px;top:50%;transform:translateY(-50%);color:#94a3b8;font-size:.85rem;"></i>
                        <input type="text" name="search" value="{{ search }}" class="filter-input" style="padding-left:38px;" placeholder="Rechercher un événement...">
                    </div>
                </div>
                <div class="col-lg-2">
                    <label class="small fw-bold text-muted mb-1 d-block">Prix</label>
                    <select name="sort_price" class="filter-input" onchange="this.form.submit()">
                        <option value="none" {{ sortPrice == 'none' ? 'selected' : '' }}>Pertinence</option>
                        <option value="asc"  {{ sortPrice == 'asc'  ? 'selected' : '' }}>Croissant</option>
                        <option value="desc" {{ sortPrice == 'desc' ? 'selected' : '' }}>Décroissant</option>
                    </select>
                </div>
                <div class="col-lg-3">
                    <label class="small fw-bold text-muted mb-1 d-block">À partir du</label>
                    <input type="date" name="date_from" value="{{ dateFrom }}" class="filter-input" onchange="this.form.submit()">
                </div>
                <div class="col-lg-2">
                    <label class="small fw-bold text-muted mb-1 d-block">Budget max : <span id="budgetDisplay" style="color:var(--g);">{{ budgetMax }}</span> DT</label>
                    <input type="range" name="budget_max" id="budgetRange" min="0" max="500" value="{{ budgetMax }}" class="form-range" style="accent-color:var(--g);">
                </div>
                <div class="col-lg-1 d-flex align-items-end">
                    <button type="submit" class="btn w-100" style="background:var(--g);color:#fff;border-radius:14px;padding:11px;font-weight:700;">
                        <i class="fas fa-search"></i>
                    </button>
                </div>
            </div>
        </form>

        <hr class="my-3 opacity-10">

        <div class="d-flex justify-content-center gap-3 flex-wrap">
            <a href="{{ path('app_evenement', {search: search, sort_price: sortPrice, date_from: dateFrom, budget_max: budgetMax}) }}"
               class="stab {{ filter == 'TOUT' ? 'active' : '' }}">Tous</a>
            <a href="{{ path('app_evenement', {filter: 'EN_COURS', search: search, sort_price: sortPrice, date_from: dateFrom, budget_max: budgetMax}) }}"
               class="stab {{ filter == 'EN_COURS' ? 'active' : '' }}">Maintenant</a>
            <a href="{{ path('app_evenement', {filter: 'COMING', search: search, sort_price: sortPrice, date_from: dateFrom, budget_max: budgetMax}) }}"
               class="stab {{ filter == 'COMING' ? 'active' : '' }}">À venir</a>
            <a href="{{ path('app_evenement', {filter: 'HISTORIQUE', search: search, sort_price: sortPrice, date_from: dateFrom, budget_max: budgetMax}) }}"
               class="stab {{ filter == 'HISTORIQUE' ? 'active' : '' }}">Archives</a>
        </div>

        <div class="d-flex justify-content-end mt-3">
            <div class="view-toggle">
                <button class="vtab active" id="btnGrid" title="Grille"><i class="fas fa-th-large"></i></button>
                <button class="vtab" id="btnCal" title="Calendrier"><i class="fas fa-calendar-alt"></i></button>
            </div>
        </div>
    </div>

    <!-- Grid view -->
    <div id="gridView">
        <div class="section-header">
            <h4 id="viewLabel">Tous les événements</h4>
            <span class="count-badge" id="countBadge">{{ evenements|length }} événements</span>
        </div>
        <div class="row g-4" id="eventContainer">
            {% for ev in evenements %}
            <div class="col-xl-4 col-md-6 event-item"
                 data-title="{{ ev.evenement.titre|lower }}"
                 data-status="{{ ev.status }}"
                 data-date="{{ ev.evenement.date_debut|date('Y-m-d') }}"
                 data-price="{{ ev.evenement.frais_inscription }}">
                <div class="ev-card h-100">
                    <div class="ev-card-img">
                        {% set titre = ev.evenement.titre|lower %}
                        {% if 'formation' in titre %}
                            <i class="fas fa-graduation-cap ev-icon text-primary"></i>
                        {% elseif 'tracteur' in titre or 'tractor' in titre %}
                            <i class="fas fa-tractor ev-icon text-secondary"></i>
                        {% elseif 'atelier' in titre %}
                            <i class="fas fa-tools ev-icon text-warning"></i>
                        {% else %}
                            <i class="fas fa-seedling ev-icon text-success"></i>
                        {% endif %}
                        <div class="ev-overlay"></div>
                        <div class="ev-price {{ ev.evenement.frais_inscription == 0 ? 'free' : '' }}">
                            {{ ev.evenement.frais_inscription == 0 ? 'Gratuit' : ev.evenement.frais_inscription ~ ' DT' }}
                        </div>
                        <div class="ev-status-ribbon
                            {% if ev.status == 'EN_COURS' %}ribbon-live
                            {% elseif ev.status == 'COMING' %}ribbon-coming
                            {% else %}ribbon-closed{% endif %}">
                            {% if ev.status == 'EN_COURS' %}<i class="fas fa-circle me-1" style="font-size:.55rem;"></i>Live
                            {% elseif ev.status == 'COMING' %}<i class="fas fa-clock me-1"></i>À venir
                            {% else %}<i class="fas fa-lock me-1"></i>Terminé{% endif %}
                        </div>
                    </div>
                    <div class="ev-card-body">
                        <div class="ev-card-title">{{ ev.evenement.titre }}</div>
                        <div class="d-flex flex-column gap-2 mb-2">
                            <div class="ev-meta"><i class="far fa-calendar-alt"></i> {{ ev.evenement.date_debut|date('d/m/Y') }}</div>
                            <div class="ev-meta"><i class="fas fa-map-marker-alt"></i> {{ ev.evenement.lieu|slice(0,30) }}{% if ev.evenement.lieu|length > 30 %}…{% endif %}</div>
                        </div>
                        {% set total = ev.evenement.capacite_max %}
                        {% set restantes = ev.placesRestantes %}
                        {% set pct = total > 0 ? ((total - restantes) / total * 100)|round : 0 %}
                        <div class="ev-capacity-bar">
                            <div class="ev-capacity-fill" style="width:{{ pct }}%"></div>
                        </div>
                        <div class="d-flex justify-content-between mb-3">
                            <span class="small text-muted">{{ restantes }} places libres</span>
                            <span class="small fw-bold" style="color:var(--g);">{{ total }} max</span>
                        </div>
                        {% if ev.totalParticipants > 0 %}
                        <div class="avatar-stack">
                            {% for avatar in ev.avatarPreviews %}
                                <div class="av">
                                    {% if avatar %}
                                        <img src="{{ avatar }}" alt="participant">
                                    {% else %}
                                        {{ loop.index }}
                                    {% endif %}
                                </div>
                            {% endfor %}
                            {% if ev.totalParticipants > ev.avatarPreviews|length %}
                                <div class="av av-more">+{{ ev.totalParticipants - ev.avatarPreviews|length }}</div>
                            {% endif %}
                            <span class="av-label">
                                {{ ev.totalParticipants }} participant{{ ev.totalParticipants > 1 ? 's' : '' }}
                            </span>
                        </div>
                        {% endif %}
                        <a href="{{ path('app_evenement_show', {'id': ev.evenement.id_ev}) }}" class="btn-ev">
                            Voir les détails <i class="fas fa-arrow-right ms-1" style="font-size:.75rem;"></i>
                        </a>                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    </div>

    <!-- Calendar view -->
    <div id="calView" style="display:none;">
        <div class="section-header">
            <h4>Calendrier des événements</h4>
        </div>
        <div id="fullcalendar"></div>
    </div>

</div>

<div style="height:60px;"></div>

<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Budget range display
    const budgetRange = document.getElementById('budgetRange');
    const budgetDisplay = document.getElementById('budgetDisplay');
    if (budgetRange) {
        budgetRange.addEventListener('input', () => {
            budgetDisplay.textContent = budgetRange.value;
        });
        budgetRange.addEventListener('change', () => {
            document.getElementById('filterForm').submit();
        });
    }

    // View toggle
    const btnGrid  = document.getElementById('btnGrid');
    const btnCal   = document.getElementById('btnCal');
    const gridView = document.getElementById('gridView');
    const calView  = document.getElementById('calView');
    let calInit = false, calendar;

    btnGrid.addEventListener('click', () => {
        btnGrid.classList.add('active'); btnCal.classList.remove('active');
        gridView.style.display = ''; calView.style.display = 'none';
    });
    btnCal.addEventListener('click', () => {
        btnCal.classList.add('active'); btnGrid.classList.remove('active');
        gridView.style.display = 'none'; calView.style.display = '';
        if (!calInit) { initCalendar(); calInit = true; }
    });

    function initCalendar() {
        let tooltip = null;
        calendar = new FullCalendar.Calendar(document.getElementById('fullcalendar'), {
            initialView: 'dayGridMonth', locale: 'fr', height: 'auto',
            headerToolbar: { left: 'prev,next today', center: 'title', right: 'dayGridMonth,timeGridWeek,listMonth' },
            buttonText: { today: "Aujourd'hui", month: 'Mois', week: 'Semaine', list: 'Liste' },
            events: { url: '/fc-load-events', method: 'POST', extraParams: { filters: JSON.stringify({}) } },
            eventClick(info) { info.jsEvent.preventDefault(); window.location.href = info.event.url; },
            eventMouseEnter(info) {
                removeTooltip();
                const p = info.event.extendedProps;
                tooltip = document.createElement('div');
                tooltip.className = 'cal-tooltip';
                tooltip.innerHTML = `<h6>${info.event.title}</h6>
                    <div class="tr"><i class="fas fa-map-marker-alt"></i>${p.lieu||'N/A'}</div>
                    <div class="tr"><i class="fas fa-tag"></i>${p.prix}</div>
                    <div class="tr"><i class="fas fa-users"></i>${p.places} places restantes</div>
                    <div class="tr" style="color:var(--g);font-weight:700;margin-top:6px;"><i class="fas fa-arrow-right"></i>Cliquer pour les détails</div>`;
                document.body.appendChild(tooltip);
                pos(info.jsEvent);
            },
            eventMouseLeave: removeTooltip,
        });
        calendar.render();
        document.addEventListener('mousemove', e => { if (tooltip) pos(e); });
        function pos(e) {
            if (!tooltip) return;
            const x = e.clientX + 16, y = e.clientY + 16;
            tooltip.style.left = (x + tooltip.offsetWidth  > window.innerWidth  ? x - tooltip.offsetWidth  - 32 : x) + 'px';
            tooltip.style.top  = (y + tooltip.offsetHeight > window.innerHeight ? y - tooltip.offsetHeight - 32 : y) + 'px';
        }
        function removeTooltip() { if (tooltip) { tooltip.remove(); tooltip = null; } }
    }
});
</script>
{% endblock %}
