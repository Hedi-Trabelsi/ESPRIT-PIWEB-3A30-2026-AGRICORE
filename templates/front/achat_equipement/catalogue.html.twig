{% extends 'front/base_front.html.twig' %}

{% block title %}Catalogue intelligent | Agricore{% endblock %}

{% block body %}
<style>
    .catalogue-page {
        --catalogue-night: #10261d;
        --catalogue-forest: #1f6c44;
        --catalogue-green: #2f9a61;
        --catalogue-lime: #b8f296;
        --catalogue-wheat: #ffd35c;
        --catalogue-cream: #f6faf3;
        --catalogue-ink-soft: #6b7e72;
        --catalogue-line: rgba(16, 38, 29, 0.1);
    }
    .catalogue-shell {
        padding-top: 1.6rem;
        padding-bottom: 2rem;
    }
    .catalogue-hero {
        position: relative;
        overflow: hidden;
        border-radius: 34px;
        padding: 2.2rem;
        margin-top: 1rem;
        background:
            linear-gradient(110deg, rgba(16,38,29,.82) 0%, rgba(18,52,31,.7) 35%, rgba(26,90,49,.52) 100%),
            url('{{ asset('img/champ-agricole.jpg') }}') center/cover;
        box-shadow: 0 34px 72px rgba(13, 42, 27, .18);
        isolation: isolate;
    }
    .catalogue-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background:
            radial-gradient(circle at top left, rgba(184, 242, 150, 0.14), transparent 22%),
            radial-gradient(circle at 82% 18%, rgba(255, 211, 92, 0.18), transparent 14%);
        z-index: -1;
    }
    .catalogue-hero-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.35fr) minmax(320px, .65fr);
        gap: 1.5rem;
        align-items: end;
    }
    .catalogue-kicker {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        background: rgba(255,255,255,.9);
        color: var(--catalogue-forest);
        border-radius: 999px;
        padding: .45rem .85rem;
        font-size: .82rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: 1rem;
    }
    .catalogue-title {
        color: #fff;
        font-size: clamp(2.4rem, 5vw, 4.5rem);
        line-height: .98;
        letter-spacing: -.03em;
        max-width: 760px;
        margin-bottom: 1rem;
        font-weight: 900;
    }
    .catalogue-copy {
        max-width: 820px;
        color: rgba(255,255,255,.88);
        font-size: 1.18rem;
        line-height: 1.55;
        margin-bottom: 1.25rem;
    }
    .catalogue-search {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: .7rem;
        padding: .75rem;
        border-radius: 24px;
        background: rgba(255,255,255,.1);
        border: 1px solid rgba(255,255,255,.12);
        backdrop-filter: blur(12px);
        max-width: 1040px;
    }
    .catalogue-search input.form-control {
        min-height: 72px;
        border: 0 !important;
        border-radius: 18px !important;
        padding-left: 1.25rem;
        font-size: 1.08rem;
        box-shadow: none !important;
        background: rgba(255,255,255,.98);
    }
    .catalogue-search input.form-control:focus {
        box-shadow: 0 0 0 4px rgba(184,242,150,.2) !important;
    }
    .catalogue-search button {
        min-width: 250px;
        min-height: 72px;
        border: 0;
        border-radius: 18px;
        background: linear-gradient(135deg, #ffd95a, #ffbd17);
        color: #173322;
        font-size: 1.08rem;
        font-weight: 900;
        box-shadow: 0 18px 30px rgba(255, 189, 23, .22);
        transition: transform .18s ease, box-shadow .18s ease;
    }
    .catalogue-search button:hover {
        transform: translateY(-2px);
        box-shadow: 0 22px 36px rgba(255, 189, 23, .28);
    }
    .catalogue-side {
        position: relative;
    }
    .catalogue-rate-card {
        border-radius: 28px;
        padding: 1.7rem;
        background: rgba(255,255,255,.96);
        box-shadow: 0 24px 50px rgba(16, 38, 29, .12);
        border: 1px solid rgba(255,255,255,.75);
    }
    .catalogue-rate-card h5 {
        color: var(--catalogue-night);
        font-size: 2rem;
        margin-bottom: 1rem;
        font-weight: 900;
    }
    .catalogue-rate-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: .95rem 0;
        border-bottom: 1px solid rgba(16, 38, 29, .1);
        font-size: 1.05rem;
    }
    .catalogue-rate-row strong {
        color: var(--catalogue-night);
        font-size: 1.5rem;
        font-weight: 900;
    }
    .catalogue-rate-meta {
        color: var(--catalogue-ink-soft);
        font-size: .96rem;
        margin-top: 1rem;
    }
    .catalogue-rate-actions {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .7rem;
        margin-top: 1.2rem;
    }
    .catalogue-rate-actions .btn {
        min-height: 52px;
        border-radius: 14px;
        font-weight: 800;
    }
    .catalogue-qty-form .input-group {
        display: flex;
        flex-wrap: nowrap;
        align-items: center;
        gap: .55rem;
    }
    .catalogue-qty-group {
        display: flex;
        align-items: center;
        gap: .45rem;
        flex: 1 1 auto;
        padding: .3rem;
        border-radius: 16px;
        border: 1px solid rgba(16, 38, 29, .12);
        background: #fff;
    }
    .catalogue-qty-btn {
        width: 42px;
        min-width: 42px;
        height: 42px;
        border: 1px solid rgba(16, 38, 29, .14);
        border-radius: 12px;
        background: #f5f8f4;
        color: var(--catalogue-night);
        font-size: 1.15rem;
        font-weight: 900;
        line-height: 1;
    }
    .catalogue-qty-input {
        flex: 1 1 auto;
        min-width: 0;
        border: 0 !important;
        box-shadow: none !important;
        background: transparent !important;
        text-align: center;
        font-weight: 800;
    }
    .catalogue-grid {
        margin-top: 1.7rem;
    }
    .equipment-card {
        position: relative;
        border: 0;
        border-radius: 30px;
        overflow: hidden;
        background: linear-gradient(180deg, #ffffff 0%, #f7fbf7 100%);
        box-shadow: 0 22px 48px rgba(13, 43, 26, .08);
        transition: transform .22s ease, box-shadow .22s ease;
    }
    .equipment-card::before {
        content: "";
        position: absolute;
        inset: auto 18px 18px 18px;
        height: 1px;
        background: linear-gradient(90deg, transparent, rgba(16,38,29,.12), transparent);
        pointer-events: none;
    }
    .equipment-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 28px 58px rgba(13, 43, 26, .14);
    }
    .equipment-thumb-wrap {
        position: relative;
        padding: .9rem .9rem 0;
    }
    .equipment-thumb {
        height: 240px;
        object-fit: cover;
        background: #eff6ef;
        border-radius: 24px;
        width: 100%;
    }
    .equipment-stock-badge {
        position: absolute;
        top: 1.3rem;
        right: 1.3rem;
        border-radius: 999px;
        padding: .55rem .85rem;
        font-weight: 800;
        font-size: .82rem;
        backdrop-filter: blur(8px);
    }
    .equipment-stock-badge.available {
        background: rgba(232,248,238,.95);
        color: #1f7a49;
    }
    .equipment-stock-badge.unavailable {
        background: rgba(255,228,232,.96);
        color: #c84261;
    }
    .equipment-card .card-body {
        padding: 1.15rem 1.2rem 1.25rem;
    }
    .equipment-type {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        padding: .4rem .75rem;
        background: #edf7ef;
        color: #266f45;
        font-size: .8rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: .04em;
        margin-bottom: .8rem;
    }
    .equipment-card .card-title {
        color: var(--catalogue-night);
        font-size: 1.35rem;
        line-height: 1.15;
        margin-bottom: .75rem;
        font-weight: 900;
    }
    .equipment-card .card-copy {
        color: var(--catalogue-ink-soft);
        min-height: 44px;
        margin-bottom: 1rem;
    }
    .equipment-price-panel {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: end;
        border-radius: 20px;
        padding: .95rem 1rem;
        background: linear-gradient(135deg, #f6fbf5, #ffffff);
        border: 1px solid rgba(16,38,29,.07);
        margin-bottom: 1rem;
    }
    .equipment-price-panel .label {
        display: block;
        color: var(--catalogue-ink-soft);
        font-size: .8rem;
        text-transform: uppercase;
        letter-spacing: .06em;
        margin-bottom: .2rem;
    }
    .equipment-price-panel .value {
        color: var(--catalogue-night);
        font-size: 1.55rem;
        font-weight: 900;
        line-height: 1;
    }
    .equipment-price-panel .mini {
        color: #2e8a57;
        font-weight: 800;
        font-size: .9rem;
    }
    .equipment-card .btn-outline-success,
    .equipment-card .btn-success,
    .equipment-card .btn-secondary,
    .equipment-card .input-group .form-control {
        min-height: 50px;
        border-radius: 14px !important;
    }
    .equipment-card .btn-outline-success,
    .equipment-card .btn-success,
    .equipment-card .btn-secondary {
        font-weight: 800;
    }
    .equipment-card .input-group {
        gap: .55rem;
    }
    .equipment-card .input-group .form-control {
        border: 1px solid rgba(16,38,29,.12);
        box-shadow: none;
    }
    .equipment-card .input-group .btn {
        border-radius: 14px !important;
        white-space: nowrap;
        flex: 0 0 auto;
    }
    .catalogue-empty {
        border-radius: 28px;
        padding: 2.4rem 1.5rem;
        background: linear-gradient(180deg, #ffffff, #f8fbf7);
        border: 1px dashed rgba(16,38,29,.14);
        text-align: center;
    }
    .catalogue-empty h3 {
        color: var(--catalogue-night);
        font-weight: 900;
    }
    @media (max-width: 1199px) {
        .catalogue-hero-grid {
            grid-template-columns: 1fr;
        }
    }
    @media (max-width: 991px) {
        .catalogue-search {
            grid-template-columns: 1fr;
        }
        .catalogue-search button {
            min-width: 100%;
        }
    }
    @media (max-width: 767px) {
        .catalogue-hero {
            padding: 1.3rem;
            border-radius: 24px;
        }
        .catalogue-title {
            font-size: 2.2rem;
        }
        .catalogue-copy {
            font-size: 1rem;
        }
        .catalogue-rate-card {
            border-radius: 22px;
            padding: 1.2rem;
        }
        .catalogue-rate-actions {
            grid-template-columns: 1fr;
        }
        .equipment-card {
            border-radius: 24px;
        }
        .equipment-thumb {
            height: 220px;
        }
    }
</style>

<div class="catalogue-page">
    <div class="container catalogue-shell">
        <section class="catalogue-hero">
            <div class="catalogue-hero-grid">
                <div>
                    <span class="catalogue-kicker">Catalogue intelligent</span>
                    <h1 class="catalogue-title">Le materiel qu'il vous faut, au bon moment</h1>
                    <p class="catalogue-copy">Explorez une selection d'equipements pensee pour le terrain, comparez facilement les options et reperez en un coup d'oeil les produits qui peuvent vraiment accompagner la performance de votre exploitation.</p>

                    <form method="get" class="catalogue-search">
                        <input type="text" name="search" value="{{ search }}" class="form-control" placeholder="Rechercher par nom, type ou usage terrain...">
                        <button type="submit">Analyser le catalogue</button>
                    </form>
                </div>

                <div class="catalogue-side">
                    <div class="catalogue-rate-card">
                        <h5>Taux live</h5>
                        <div class="catalogue-rate-row">
                            <span>1 TND en EUR</span>
                            <strong>{{ rates.EUR|number_format(3, '.', ' ') }}</strong>
                        </div>
                        <div class="catalogue-rate-row">
                            <span>1 TND en USD</span>
                            <strong>{{ rates.USD|number_format(3, '.', ' ') }}</strong>
                        </div>
                        <div class="catalogue-rate-meta">Source: {{ rates.source }} • Mise a jour: {{ rates.updated_at }}</div>
                        <div class="catalogue-rate-actions">
                            <a href="{{ path('app_my_orders') }}" class="btn btn-outline-success">Mes commandes</a>
                            <a href="{{ path('app_cart_show') }}" class="btn btn-success">Mon panier</a>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        {% for label in ['success', 'warning', 'error'] %}
            {% for message in app.flashes(label) %}
                <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show mt-4 rounded-4 border-0 shadow-sm" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Fermer"></button>
                </div>
            {% endfor %}
        {% endfor %}

        <section class="catalogue-grid">
            <div class="row g-4">
                {% for eq in equipements %}
                    <div class="col-md-6 col-xl-3">
                        <div class="card equipment-card h-100">
                            <div class="equipment-thumb-wrap">
                                {% if eq.imageFilename %}
                                    <img src="{{ vich_uploader_asset(eq, 'imageFile') }}" class="equipment-thumb" alt="{{ eq.nom }}">
                                {% else %}
                                    <div class="equipment-thumb d-flex align-items-center justify-content-center text-muted">Pas d'image</div>
                                {% endif %}
                                <span class="equipment-stock-badge {{ eq.quantite > 0 ? 'available' : 'unavailable' }}">
                                    {{ eq.quantite > 0 ? eq.quantite ~ ' en stock' : 'Rupture' }}
                                </span>
                            </div>

                            <div class="card-body d-flex flex-column">
                                <span class="equipment-type">{{ eq.type }}</span>
                                <h5 class="card-title">{{ eq.nom }}</h5>
                                <div class="card-copy">Un apercu plus inspirant pour mieux choisir, comparer et se projeter sur le terrain.</div>

                                <div class="equipment-price-panel">
                                    <div>
                                        <span class="label">Prix</span>
                                        <span class="value">{{ eq.prix }} TND</span>
                                    </div>
                                    <span class="mini">{{ eq.quantite > 0 ? 'Pret a commander' : 'Indisponible' }}</span>
                                </div>

                                <div class="mt-auto">
                                    <a href="{{ path('app_equipement_detail', {id: eq.id}) }}" class="btn btn-outline-success w-100 mb-2">Decouvrir cet equipement</a>
                                    {% if eq.quantite > 0 %}
                                        <form method="post" action="{{ path('app_add_to_cart', {id: eq.id}) }}" class="catalogue-qty-form">
                                            <div class="input-group">
                                                <div class="catalogue-qty-group" data-quantity-picker>
                                                    <button type="button" class="catalogue-qty-btn" data-quantity-action="decrease">-</button>
                                                    <input type="number" name="quantity" value="1" min="1" max="{{ eq.quantite }}" class="form-control catalogue-qty-input" data-quantity-input>
                                                    <button type="button" class="catalogue-qty-btn" data-quantity-action="increase">+</button>
                                                </div>
                                                <button class="btn btn-success" type="submit">Ajouter</button>
                                            </div>
                                        </form>
                                    {% else %}
                                        <button class="btn btn-secondary w-100" disabled>Indisponible</button>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-12">
                        <div class="catalogue-empty">
                            <h3>Aucun equipement trouve</h3>
                            <p class="text-muted mb-3">Essayez un autre nom ou type d'equipement pour relancer l'exploration.</p>
                            <a href="{{ path('app_equipement_catalogue') }}" class="btn btn-outline-success">Reinitialiser la recherche</a>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
</div>
<script>
    (() => {
        document.querySelectorAll('[data-quantity-picker]').forEach((picker) => {
            const input = picker.querySelector('[data-quantity-input]');
            if (!input) {
                return;
            }

            const min = Number(input.min || 1);
            const max = Number(input.max || Number.MAX_SAFE_INTEGER);

            picker.addEventListener('click', (event) => {
                const button = event.target.closest('[data-quantity-action]');
                if (!button) {
                    return;
                }

                const current = Number(input.value || min);
                const next = button.dataset.quantityAction === 'increase' ? current + 1 : current - 1;
                input.value = String(Math.min(max, Math.max(min, next)));
            });

            input.addEventListener('input', () => {
                const current = Number(input.value || min);
                input.value = String(Math.min(max, Math.max(min, current)));
            });
        });
    })();
</script>
{% endblock %}
