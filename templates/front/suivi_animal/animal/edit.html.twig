{% extends 'front/base_front.html.twig' %}
{% block title %}Modifier Animal{% endblock %}

{% block body %}
<style>
  .ag-header{display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;padding-bottom:1rem;border-bottom:2px solid #C0DD97;}
  .ag-title-wrap{display:flex;align-items:center;gap:10px;}
  .ag-icon-box{width:38px;height:38px;background:#3B6D11;border-radius:9px;display:flex;align-items:center;justify-content:center;}
  .ag-h1{font-size:21px;font-weight:500;color:#27500A;margin:0;}
  .ag-subtitle{font-size:13px;color:#6c757d;margin:0;}
  .ag-btn-back{background:transparent;color:#3B6D11;border:0.5px solid #3B6D11;padding:7px 14px;border-radius:8px;font-size:13px;font-weight:500;text-decoration:none;}
  .ag-form-card{background:#fff;border:0.5px solid #C0DD97;border-radius:14px;overflow:hidden;}
  .ag-form-header{background:#EAF3DE;padding:14px 20px;border-bottom:0.5px solid #C0DD97;display:flex;align-items:center;gap:8px;}
  .ag-form-header-dot{width:10px;height:10px;border-radius:50%;background:#3B6D11;}
  .ag-form-header-title{font-size:14px;font-weight:500;color:#27500A;}
  .ag-form-body{padding:22px 24px;}
  .ag-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px;}
  .ag-field{display:flex;flex-direction:column;gap:6px;}
  .ag-label{font-size:12px;font-weight:500;color:#639922;text-transform:uppercase;letter-spacing:0.4px;}
  .ag-input{background:#EAF3DE;border:0.5px solid #C0DD97;border-radius:8px;padding:9px 12px;font-size:14px;color:#27500A;width:100%;box-sizing:border-box;outline:none;}
  .ag-input:focus{border-color:#3B6D11;background:#fff;box-shadow:0 0 0 3px rgba(59,109,17,0.08);}
  .ag-form-footer{padding:16px 24px;background:#EAF3DE;border-top:0.5px solid #C0DD97;display:flex;justify-content:space-between;align-items:center;}
  .ag-btn-save{background:#3B6D11;color:white;border:none;padding:9px 24px;border-radius:8px;font-size:14px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:7px;}
  .ag-btn-save:hover{background:#27500A;}
  .ag-btn-cancel{background:transparent;color:#6c757d;border:0.5px solid #ccc;padding:9px 18px;border-radius:8px;font-size:13px;text-decoration:none;}
  .ag-btn-delete{background:transparent;color:#A32D2D;border:0.5px solid #A32D2D;padding:9px 18px;border-radius:8px;font-size:13px;font-weight:500;cursor:pointer;display:inline-flex;align-items:center;gap:6px;}
  .ag-btn-delete:hover{background:#A32D2D;color:white;}
</style>

<div class="ag-header">
  <div class="ag-title-wrap">
    <div class="ag-icon-box"><i class="fas fa-leaf" style="color:white;font-size:16px;"></i></div>
    <div>
      <p class="ag-h1">Modifier l'animal</p>
      <p class="ag-subtitle">Mise à jour — #{{ animal.codeAnimal }}</p>
    </div>
  </div>
  <a href="{{ path('app_animal_index') }}" class="ag-btn-back">← Retour à la liste</a>
</div>

<div class="ag-form-card">
  <div class="ag-form-header">
    <span class="ag-form-header-dot"></span>
    <span class="ag-form-header-title">Informations de l'animal</span>
  </div>

  <form method="post" action="{{ path('app_animal_edit', {'idAnimal': animal.idAnimal}) }}">
    <div class="ag-form-body">
      <div class="ag-form-grid">
        <div class="ag-field">
          <label class="ag-label">Code animal</label>
          <input type="text" name="codeAnimal" class="ag-input" required value="{{ animal.codeAnimal }}">
        </div>
        <div class="ag-field">
          <label class="ag-label">Espèce</label>
          <input type="text" name="espece" class="ag-input" required value="{{ animal.espece }}">
        </div>
        <div class="ag-field">
          <label class="ag-label">Race</label>
          <input type="text" name="race" class="ag-input" required value="{{ animal.race }}">
        </div>
        <div class="ag-field">
          <label class="ag-label">Sexe</label>
          <select name="sexe" class="ag-input" required>
            <option value="Mâle"    {% if animal.sexe == 'Mâle'    %}selected{% endif %}>Mâle</option>
            <option value="Femelle" {% if animal.sexe == 'Femelle' %}selected{% endif %}>Femelle</option>
          </select>
        </div>
        <div class="ag-field">
          <label class="ag-label">Date de naissance</label>
          <input type="date" name="dateNaissance" class="ag-input" required
                 value="{{ animal.dateNaissance ? animal.dateNaissance|date('Y-m-d') : '' }}"
                 max="{{ "now"|date('Y-m-d') }}">
        </div>
      </div>
    </div>

    <div class="ag-form-footer">
      <div style="display:flex;gap:8px;align-items:center;">
        <button type="submit" class="ag-btn-save">
          <i class="fas fa-save"></i> Mettre à jour
        </button>
        <a href="{{ path('app_animal_index') }}" class="ag-btn-cancel">Annuler</a>
      </div>

      {# Bouton supprimer #}
      <form method="post" action="{{ path('app_animal_delete', {'idAnimal': animal.idAnimal}) }}">
        <button type="submit" class="ag-btn-delete">
          <i class="fas fa-trash-alt"></i> Supprimer
        </button>
      </form>
    </div>
  </form>
</div>

{% endblock %}
