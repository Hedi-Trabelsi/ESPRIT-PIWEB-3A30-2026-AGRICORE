{% extends 'front/base_front.html.twig' %}
{% block title %}Nouvel Animal{% endblock %}

{% block body %}
<style>
  /* ── même CSS que les autres pages ── */
  .ag-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; padding-bottom: 1rem; border-bottom: 2px solid #C0DD97; }
  .ag-title-wrap { display: flex; align-items: center; gap: 10px; }
  .ag-icon-box { width: 38px; height: 38px; background: #3B6D11; border-radius: 9px; display: flex; align-items: center; justify-content: center; }
  .ag-h1 { font-size: 21px; font-weight: 500; color: #27500A; margin: 0; }
  .ag-subtitle { font-size: 13px; color: #6c757d; margin: 0; }
  .ag-btn-back { background: transparent; color: #3B6D11; border: 0.5px solid #3B6D11; padding: 7px 14px; border-radius: 8px; font-size: 13px; font-weight: 500; text-decoration: none; }
  .ag-form-card { background: #fff; border: 0.5px solid #C0DD97; border-radius: 14px; overflow: hidden; }
  .ag-form-header { background: #EAF3DE; padding: 14px 20px; border-bottom: 0.5px solid #C0DD97; display: flex; align-items: center; gap: 8px; }
  .ag-form-header-dot { width: 10px; height: 10px; border-radius: 50%; background: #3B6D11; }
  .ag-form-header-title { font-size: 14px; font-weight: 500; color: #27500A; }
  .ag-form-body { padding: 22px 24px; }
  .ag-form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
  .ag-field { display: flex; flex-direction: column; gap: 6px; }
  .ag-field.full { grid-column: 1 / -1; }
  .ag-label { font-size: 12px; font-weight: 500; color: #639922; text-transform: uppercase; letter-spacing: 0.4px; }
  .ag-input { background: #EAF3DE; border: 0.5px solid #C0DD97; border-radius: 8px; padding: 9px 12px; font-size: 14px; color: #27500A; width: 100%; box-sizing: border-box; outline: none; }
  .ag-input:focus { border-color: #3B6D11; background: #fff; box-shadow: 0 0 0 3px rgba(59,109,17,0.08); }
  .ag-form-footer { padding: 16px 24px; background: #EAF3DE; border-top: 0.5px solid #C0DD97; display: flex; justify-content: space-between; align-items: center; }
  .ag-btn-save { background: #3B6D11; color: white; border: none; padding: 9px 24px; border-radius: 8px; font-size: 14px; font-weight: 500; cursor: pointer; display: flex; align-items: center; gap: 7px; }
</style>

<div class="ag-header">
  <div class="ag-title-wrap">
    <div class="ag-icon-box">
      <i class="fas fa-leaf" style="color:white;font-size:16px;"></i>
    </div>
    <div>
      <p class="ag-h1">Nouvel animal</p>
      <p class="ag-subtitle">Enregistrement dans le cheptel</p>
    </div>
  </div>
  <a href="{{ path('app_animal_index') }}" class="ag-btn-back">← Retour à la liste</a>
</div>

<div class="ag-form-card">
  <div class="ag-form-header">
    <span class="ag-form-header-dot"></span>
    <span class="ag-form-header-title">Informations de l'animal</span>
  </div>
  {{ include('front/suivi_animal/animal/_form.html.twig', {'button_label': 'Enregistrer'}) }}
</div>

{% endblock %}