{{ form_start(form, {'attr': {'id': 'animalForm'}}) }}

<div class="ag-form-body">
  <div class="ag-form-grid">
    {% for field in form.children %}
      {% if field.vars.name != '_token' %}
      <div class="ag-field {% if field.vars.block_prefixes|join(' ') matches '/textarea|date/' %}full{% endif %}">
        <label class="ag-label" for="{{ field.vars.id }}">
          {{ field.vars.label|default(field.vars.name|replace({'_': ' '})|capitalize) }}
        </label>
        {{ form_widget(field, {'attr': {'class': 'ag-input' ~ (field.vars.block_prefixes|join(' ') matches '/choice|select/' ? ' ag-select' : '')}}) }}
        {% if field.vars.errors|length > 0 %}
          {% for error in field.vars.errors %}
            <span style="display:inline-flex;align-items:center;gap:5px;background:#FEE2E2;border:1.5px solid #F87171;border-radius:6px;padding:4px 10px;font-size:12px;font-weight:700;color:#B91C1C;margin-top:4px;">⚠ {{ error.message }}</span>
          {% endfor %}
        {% endif %}
      </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

<div class="ag-form-footer">
  <div style="display:flex;gap:8px;">
    <button type="submit" class="ag-btn-save">
      <i class="fas fa-save"></i>
      {{ button_label|default('Enregistrer') }}
    </button>
    <a href="{{ path('app_animal_index') }}" class="ag-btn-back">Annuler</a>
  </div>
  {% block delete_action %}{% endblock %}
</div>

{{ form_end(form) }}

<script>
document.getElementById('animalForm').addEventListener('submit', function(e) {
  var errors = [];

  var code  = document.getElementById('animal_codeAnimal');
  var espece = document.getElementById('animal_espece');
  var race  = document.getElementById('animal_race');
  var sexe  = document.getElementById('animal_sexe');
  var date  = document.getElementById('animal_dateNaissance');

  [code, espece, race, sexe, date].forEach(function(f) {
    if (f) f.style.borderColor = '';
  });

  if (!code || !code.value.trim()) {
    errors.push('Le code animal est obligatoire.');
    if (code) code.style.borderColor = '#F87171';
  }
  if (!espece || !espece.value.trim()) {
    errors.push("L'espèce est obligatoire.");
    if (espece) espece.style.borderColor = '#F87171';
  }
  if (!race || !race.value.trim()) {
    errors.push('La race est obligatoire.');
    if (race) race.style.borderColor = '#F87171';
  }
  if (!sexe || !sexe.value) {
    errors.push('Le sexe est obligatoire.');
    if (sexe) sexe.style.borderColor = '#F87171';
  }
  if (!date || !date.value) {
    errors.push('La date de naissance est obligatoire.');
    if (date) date.style.borderColor = '#F87171';
  }

  if (errors.length > 0) {
    e.preventDefault();
    alert('Veuillez corriger les erreurs suivantes :\n\n' + errors.join('\n'));
  }
});
</script>