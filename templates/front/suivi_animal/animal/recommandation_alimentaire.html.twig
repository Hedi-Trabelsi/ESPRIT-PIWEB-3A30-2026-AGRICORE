{% extends 'front/base_front.html.twig' %}
{% block title %}Recommandation Alimentaire IA{% endblock %}
{% block body %}
<style>
:root{--g:#2d6a4f;--g2:#40916c;--g3:#74c69d;--gl:#d8f3dc;--gd:#1b4332;--or:#e65100;--or2:#ff8f00;--or3:#ffcc02;}
.ra-page{max-width:960px;margin:0 auto;padding:2rem 1rem 5rem;}
.ra-hero{background:linear-gradient(135deg,#1b4332 0%,#2d6a4f 40%,#e65100 100%);border-radius:28px;padding:2.8rem;margin-bottom:2rem;position:relative;overflow:hidden;box-shadow:0 28px 72px rgba(27,67,50,.35);}
.ra-hero::before{content:'';position:absolute;top:-90px;right:-90px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle,rgba(255,204,2,.15),transparent 70%);}
.ra-hero-inner{position:relative;z-index:1;display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
.ra-badge{display:inline-flex;align-items:center;gap:6px;background:rgba(255,204,2,.2);border:1px solid rgba(255,204,2,.4);color:#ffcc02;padding:5px 14px;border-radius:20px;font-size:11px;font-weight:700;letter-spacing:.6px;text-transform:uppercase;margin-bottom:10px;animation:badgePulse 3s ease-in-out infinite;}
.ra-hero-title{font-size:28px;font-weight:800;color:#fff;margin:0 0 6px;}
.ra-hero-sub{font-size:13px;color:rgba(255,255,255,.65);margin:0;}
.ra-back{background:rgba(255,255,255,.12);border:1.5px solid rgba(255,255,255,.25);color:#fff;padding:10px 22px;border-radius:14px;font-size:13px;font-weight:700;text-decoration:none;transition:.25s;white-space:nowrap;}
.ra-back:hover{background:rgba(255,255,255,.22);color:#fff;}
.ra-card{background:#fff;border-radius:22px;padding:2rem;box-shadow:0 6px 36px rgba(45,106,79,.08);border:1px solid rgba(116,198,157,.2);margin-bottom:1.5rem;}
.ra-card-title{font-size:14px;font-weight:800;color:var(--gd);display:flex;align-items:center;gap:10px;margin-bottom:1.5rem;padding-bottom:14px;border-bottom:2px solid #f0fdf4;}
.ra-card-icon{width:36px;height:36px;border-radius:11px;background:linear-gradient(135deg,var(--or),var(--or2));display:flex;align-items:center;justify-content:center;color:#fff;font-size:15px;flex-shrink:0;}
.ra-grid{display:grid;grid-template-columns:1fr 1fr;gap:1.2rem;}
.ra-field{display:flex;flex-direction:column;gap:7px;}
.ra-field.full{grid-column:1/-1;}
.ra-label{font-size:11px;font-weight:800;color:var(--g2);text-transform:uppercase;letter-spacing:.7px;}
.ra-select,.ra-input{background:#f8fffe;border:1.5px solid #c8e6c9;border-radius:12px;padding:12px 15px;font-size:13px;color:var(--gd);width:100%;box-sizing:border-box;outline:none;transition:.25s;appearance:none;}
.ra-select:focus,.ra-input:focus{border-color:var(--g);background:#fff;box-shadow:0 0 0 4px rgba(45,106,79,.1);}
.animal-preview{background:linear-gradient(135deg,#f1f8e9,#dcedc8);border:1.5px solid #aed581;border-radius:16px;padding:14px 18px;margin-top:8px;display:none;align-items:center;gap:14px;}
.animal-preview.show{display:flex;}
.ap-avatar{width:50px;height:50px;border-radius:50%;background:linear-gradient(135deg,var(--gd),var(--g));display:flex;align-items:center;justify-content:center;font-size:22px;flex-shrink:0;}
.ap-code{font-size:18px;font-weight:800;color:var(--gd);}
.ap-info{font-size:12px;color:var(--g2);margin-top:2px;}
.ap-poids{background:linear-gradient(135deg,var(--or),var(--or2));color:#fff;padding:3px 12px;border-radius:20px;font-size:11px;font-weight:700;margin-top:5px;display:inline-block;}
.ra-btn{width:100%;padding:16px;margin-top:1.5rem;background:linear-gradient(135deg,var(--gd),var(--g),var(--or));background-size:200%;color:#fff;border:none;border-radius:16px;font-size:15px;font-weight:800;cursor:pointer;transition:.3s;animation:gradShift 5s ease infinite;box-shadow:0 8px 24px rgba(45,106,79,.3);display:flex;align-items:center;justify-content:center;gap:10px;}
.ra-btn:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(45,106,79,.4);}
.ra-btn:disabled{opacity:.6;cursor:not-allowed;transform:none;}
.ra-loading{background:#fff;border-radius:22px;padding:3.5rem 2rem;box-shadow:0 6px 36px rgba(45,106,79,.08);border:1px solid rgba(116,198,157,.2);text-align:center;display:none;margin-bottom:1.5rem;}
.ra-loading.show{display:block;}
.food-loader{display:flex;justify-content:center;gap:10px;margin-bottom:1.5rem;font-size:28px;}
.food-item{animation:foodBounce 1.2s ease-in-out infinite;}
.food-item:nth-child(1){animation-delay:0s;}
.food-item:nth-child(2){animation-delay:.2s;}
.food-item:nth-child(3){animation-delay:.4s;}
.food-item:nth-child(4){animation-delay:.6s;}
.ra-result{background:#fff;border-radius:22px;box-shadow:0 6px 36px rgba(45,106,79,.1);border:1px solid rgba(116,198,157,.2);overflow:hidden;display:none;margin-bottom:1.5rem;}
.ra-result.show{display:block;}
.ra-result-header{background:linear-gradient(135deg,var(--gd),var(--g),var(--or));padding:1.8rem 2rem;}
.ra-result-title{font-size:16px;font-weight:800;color:#fff;display:flex;align-items:center;gap:8px;margin-bottom:1rem;}
.score-box{display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;}
.score-circle{width:80px;height:80px;border-radius:50%;background:rgba(255,255,255,.15);border:3px solid rgba(255,255,255,.4);display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;}
.score-num{font-size:24px;font-weight:900;color:#fff;line-height:1;}
.score-max{font-size:10px;color:rgba(255,255,255,.7);}
.score-statut{font-size:16px;font-weight:800;color:#fff;}
.score-animal{font-size:12px;color:rgba(255,255,255,.75);margin-top:4px;}
.ra-result-actions{display:flex;gap:.6rem;margin-top:1rem;}
.ra-action-btn{padding:8px 18px;border-radius:10px;font-size:12px;font-weight:700;cursor:pointer;border:none;transition:.2s;}
.btn-copy-ra{background:rgba(255,255,255,.18);color:#fff;border:1px solid rgba(255,255,255,.3);}
.btn-copy-ra:hover{background:rgba(255,255,255,.28);}
.ra-body{padding:2rem;}
.ra-section-title{font-size:12px;font-weight:800;color:var(--gd);text-transform:uppercase;letter-spacing:.7px;margin:1.8rem 0 .8rem;display:flex;align-items:center;gap:8px;padding-bottom:8px;border-bottom:2px solid #f0fdf4;}
.ra-section-title:first-child{margin-top:0;}
.ra-items-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-bottom:1rem;}
.ra-item{padding:10px 14px;border-radius:12px;font-size:13px;font-weight:600;display:flex;align-items:center;gap:8px;}
.ra-item.green{background:#f1f8e9;color:#2e7d32;border:1px solid #c8e6c9;}
.ra-item.blue{background:#e3f2fd;color:#1565c0;border:1px solid #bbdefb;}
.ra-item.red{background:#ffebee;color:#c62828;border:1px solid #ffcdd2;}
.ra-item.gray{background:#f5f5f5;color:#555;border:1px solid #e0e0e0;}
.besoins-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin-bottom:1rem;}
.besoin-card{background:linear-gradient(135deg,#f8fffe,#f1f8e9);border:1.5px solid #c8e6c9;border-radius:14px;padding:14px;text-align:center;}
.besoin-val{font-size:20px;font-weight:800;color:var(--gd);}
.besoin-lbl{font-size:10px;color:var(--g2);text-transform:uppercase;letter-spacing:.5px;margin-top:3px;}
.ra-error{background:#fef2f2;border:1.5px solid #fca5a5;border-radius:14px;padding:14px 18px;color:#dc2626;font-size:13px;font-weight:600;display:none;margin-top:1rem;align-items:center;gap:8px;}
.ra-error.show{display:flex;}
@keyframes badgePulse{0%,100%{box-shadow:0 0 0 0 rgba(255,204,2,.3)}50%{box-shadow:0 0 0 6px rgba(255,204,2,0)}}
@keyframes gradShift{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes foodBounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}
@media(max-width:640px){.ra-grid{grid-template-columns:1fr;}.ra-items-grid{grid-template-columns:1fr;}.besoins-grid{grid-template-columns:repeat(2,1fr);}.ra-hero-inner{flex-direction:column;}}
</style>

<div class="ra-page">
  <div class="ra-hero">
    <div class="ra-hero-inner">
      <div>
        <span class="ra-badge">🌿 Moteur Expert Nutritionnel</span>
        <h1 class="ra-hero-title">🥗 Recommandation Alimentaire IA</h1>
        <p class="ra-hero-sub">Plan nutritionnel personnalisé basé sur l'espèce, l'état de santé, la saison et l'objectif</p>
      </div>
      <a href="{{ path('app_animal_index') }}" class="ra-back"><i class="fas fa-arrow-left me-1"></i> Retour</a>
    </div>
  </div>

  <div class="ra-card" style="animation:fadeUp .5s ease;">
    <div class="ra-card-title">
      <div class="ra-card-icon"><i class="fas fa-carrot"></i></div>
      Paramètres de l'animal
    </div>
    <form id="raForm">
      <div class="ra-grid">
        <div class="ra-field full">
          <label class="ra-label">🐄 Animal</label>
          <select class="ra-select" name="animalId" id="animalSelect" required>
            <option value="">— Sélectionner un animal —</option>
            {% for animal in animals %}
            <option value="{{ animal.idAnimal }}" data-code="{{ animal.codeAnimal }}" data-espece="{{ animal.espece }}" data-race="{{ animal.race }}" data-sexe="{{ animal.sexe }}">
              {{ animal.codeAnimal }} — {{ animal.espece }} · {{ animal.race }}
            </option>
            {% endfor %}
          </select>
          <div class="animal-preview" id="animalPreview">
            <div class="ap-avatar">🐾</div>
            <div>
              <div class="ap-code" id="previewCode"></div>
              <div class="ap-info" id="previewInfo"></div>
              <div class="ap-poids" id="previewPoids" style="display:none"></div>
            </div>
          </div>
        </div>
        <div class="ra-field">
          <label class="ra-label">⚖️ Poids (kg)</label>
          <input type="number" step="0.1" min="0.1" class="ra-input" name="poids" id="poidsInput" placeholder="Ex: 45.5" required>
        </div>
        <div class="ra-field">
          <label class="ra-label">🎂 Âge (années)</label>
          <input type="number" min="0" max="30" class="ra-input" name="age" id="ageInput" placeholder="Ex: 3" required>
        </div>
        <div class="ra-field">
          <label class="ra-label">🏥 État de santé</label>
          <select class="ra-select" name="etat" id="etatSelect">
            <option value="Bon">Bon</option>
            <option value="Moyen">Moyen</option>
            <option value="Mauvais">Mauvais / Malade</option>
            <option value="Convalescent">Convalescent</option>
          </select>
        </div>
        <div class="ra-field">
          <label class="ra-label">🏃 Niveau d'activité</label>
          <select class="ra-select" name="niveau" id="niveauSelect">
            <option value="Faible">Faible</option>
            <option value="Moyen" selected>Moyen</option>
            <option value="Élevé">Élevé</option>
          </select>
        </div>
        <div class="ra-field">
          <label class="ra-label">🌤️ Saison</label>
          <select class="ra-select" name="saison" id="saisonSelect">
            <option value="Printemps">🌱 Printemps</option>
            <option value="Été">☀️ Été</option>
            <option value="Automne">🍂 Automne</option>
            <option value="Hiver">❄️ Hiver</option>
          </select>
        </div>
        <div class="ra-field full">
          <label class="ra-label">🎯 Objectif nutritionnel</label>
          <select class="ra-select" name="objectif">
            <option value="Maintien du poids">Maintien du poids</option>
            <option value="Prise de poids">Prise de poids</option>
            <option value="Perte de poids">Perte de poids</option>
            <option value="Production laitière">Production laitière</option>
            <option value="Performance sportive">Performance sportive</option>
            <option value="Convalescence">Convalescence</option>
            <option value="Croissance">Croissance</option>
          </select>
        </div>
      </div>
      <button type="submit" class="ra-btn" id="submitBtn">
        <i class="fas fa-seedling"></i> Générer le plan alimentaire
      </button>
    </form>
    <div class="ra-error" id="errorBox"><i class="fas fa-exclamation-circle"></i><span id="errorText"></span></div>
  </div>

  <div class="ra-loading" id="loadingBox">
    <div class="food-loader">
      <span class="food-item">🌾</span><span class="food-item">🥕</span>
      <span class="food-item">🌿</span><span class="food-item">🌽</span>
    </div>
    <p style="font-size:17px;font-weight:800;color:var(--gd);margin-bottom:6px;">🥗 Calcul du plan nutritionnel...</p>
    <p style="font-size:13px;color:#9ca3af;">Analyse de l'espèce, de l'état de santé et de la saison</p>
  </div>

  <div class="ra-result" id="resultBox">
    <div class="ra-result-header">
      <div class="ra-result-title"><i class="fas fa-leaf"></i> Plan Nutritionnel Personnalisé</div>
      <div class="score-box">
        <div class="score-circle"><div class="score-num" id="scoreNum">—</div><div class="score-max">/100</div></div>
        <div>
          <div class="score-statut" id="scoreStatut">—</div>
          <div class="score-animal" id="scoreAnimal">—</div>
        </div>
      </div>
      <div class="ra-result-actions">
        <button class="ra-action-btn btn-copy-ra" id="copyBtn" onclick="copyRa()">📋 Copier</button>
        <button class="ra-action-btn btn-copy-ra" onclick="window.print()">🖨 Imprimer</button>
      </div>
    </div>
    <div class="ra-body" id="raBody"></div>
  </div>
</div>

<script>
// Saison auto selon mois
const mois = new Date().getMonth() + 1;
const saison = mois <= 2 || mois === 12 ? 'Hiver' : mois <= 5 ? 'Printemps' : mois <= 8 ? 'Été' : 'Automne';
document.getElementById('saisonSelect').value = saison;

// Auto-remplir depuis dernier suivi
document.getElementById('animalSelect').addEventListener('change', async function() {
  const opt = this.options[this.selectedIndex];
  const preview = document.getElementById('animalPreview');
  if (!this.value) { preview.classList.remove('show'); return; }
  document.getElementById('previewCode').textContent = opt.dataset.code;
  document.getElementById('previewInfo').textContent = opt.dataset.espece + ' · ' + opt.dataset.race + ' · ' + opt.dataset.sexe;
  preview.classList.add('show');
  try {
    const r = await fetch('/animal/recommandation-alimentaire/dernier-suivi/' + this.value);
    const d = await r.json();
    if (d && d.poids) {
      document.getElementById('poidsInput').value = d.poids;
      document.getElementById('previewPoids').textContent = '⚖️ Dernier poids : ' + d.poids + ' kg';
      document.getElementById('previewPoids').style.display = 'inline-block';
      if (d.etat) document.getElementById('etatSelect').value = d.etat;
      if (d.activite) document.getElementById('niveauSelect').value = d.activite;
    }
  } catch(e) {}
});

// Soumission
document.getElementById('raForm').addEventListener('submit', async function(e) {
  e.preventDefault();
  const btn = document.getElementById('submitBtn');
  const loading = document.getElementById('loadingBox');
  const result = document.getElementById('resultBox');
  const error = document.getElementById('errorBox');
  btn.disabled = true;
  btn.innerHTML = '<i class="fas fa-circle-notch fa-spin"></i> Calcul...';
  loading.classList.add('show');
  result.classList.remove('show');
  error.classList.remove('show');
  try {
    const resp = await fetch('{{ path("app_reco_generer") }}', { method:'POST', body:new FormData(this) });
    const data = await resp.json();
    if (data.error) {
      document.getElementById('errorText').textContent = data.error;
      error.classList.add('show');
    } else {
      renderResult(data);
      result.classList.add('show');
      result.scrollIntoView({ behavior:'smooth' });
    }
  } catch(err) {
    document.getElementById('errorText').textContent = 'Erreur : ' + err.message;
    error.classList.add('show');
  } finally {
    btn.disabled = false;
    btn.innerHTML = '<i class="fas fa-seedling"></i> Générer le plan alimentaire';
    loading.classList.remove('show');
  }
});

function renderResult(data) {
  document.getElementById('scoreNum').textContent = data.scoreNutri;
  document.getElementById('scoreStatut').textContent = data.statut;
  document.getElementById('scoreAnimal').textContent = data.animal;

  const b = data.besoins;
  let html = `
    <div class="ra-section-title">📊 Besoins journaliers estimés</div>
    <div class="besoins-grid">
      <div class="besoin-card"><div class="besoin-val">${b.energie} Mcal</div><div class="besoin-lbl">Énergie/jour</div></div>
      <div class="besoin-card"><div class="besoin-val">${b.proteine} kg</div><div class="besoin-lbl">Protéines/jour</div></div>
      <div class="besoin-card"><div class="besoin-val">${b.fibre}%</div><div class="besoin-lbl">Fibres ration</div></div>
      <div class="besoin-card"><div class="besoin-val">${b.calcium} g</div><div class="besoin-lbl">Calcium/jour</div></div>
      <div class="besoin-card"><div class="besoin-val">${b.phosphore} g</div><div class="besoin-lbl">Phosphore/jour</div></div>
      <div class="besoin-card"><div class="besoin-val">${b.eau_min}-${b.eau_max} L</div><div class="besoin-lbl">Eau/jour</div></div>
    </div>
    <div class="ra-section-title">✅ Aliments recommandés</div>
    <div class="ra-items-grid">${data.aliments.map(a => `<div class="ra-item green">🌿 ${a}</div>`).join('')}</div>`;

  if (data.supplements.length) {
    html += `<div class="ra-section-title">💊 Suppléments conseillés</div>
    <div class="ra-items-grid">${data.supplements.map(s => `<div class="ra-item blue">${s}</div>`).join('')}</div>`;
  }

  html += `<div class="ra-section-title">❌ Aliments interdits</div>
    <div class="ra-items-grid">${data.interdits.map(i => `<div class="ra-item red">❌ ${i}</div>`).join('')}</div>`;

  if (data.plan.length) {
    html += `<div class="ra-section-title">📅 Plan alimentaire</div>
    <div class="ra-items-grid">${data.plan.map(p => `<div class="ra-item gray">${p}</div>`).join('')}</div>`;
  }

  document.getElementById('raBody').innerHTML = html;
}

function copyRa() {
  const text = document.getElementById('raBody').innerText;
  navigator.clipboard.writeText(text).then(() => {
    const btn = document.getElementById('copyBtn');
    btn.textContent = '✅ Copié !';
    setTimeout(() => btn.textContent = '📋 Copier', 2500);
  });
}
</script>
{% endblock %}