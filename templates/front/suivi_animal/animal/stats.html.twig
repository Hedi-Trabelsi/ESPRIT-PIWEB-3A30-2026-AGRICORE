{% extends 'front/base_front.html.twig' %}
{% block title %}Statistiques du Cheptel{% endblock %}
{% block body %}

<style>
:root { --g:#2d6a4f; --g2:#40916c; --g3:#74c69d; --gl:#d8f3dc; --gd:#1b4332; --accent:#52b788; }

.stats-page { background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%); min-height: 100vh; padding: 2rem 1.5rem 4rem; }

/* Hero header */
.stats-hero {
  background: linear-gradient(135deg, var(--gd) 0%, var(--g) 60%, var(--g2) 100%);
  border-radius: 24px;
  padding: 2.5rem 2.5rem;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: relative;
  overflow: hidden;
  box-shadow: 0 20px 60px rgba(27,67,50,.25);
}
.stats-hero::before {
  content: '';
  position: absolute;
  top: -60px; right: -60px;
  width: 220px; height: 220px;
  border-radius: 50%;
  background: rgba(255,255,255,.06);
}
.stats-hero::after {
  content: '';
  position: absolute;
  bottom: -40px; left: 30%;
  width: 160px; height: 160px;
  border-radius: 50%;
  background: rgba(255,255,255,.04);
}
.hero-title { font-size: 28px; font-weight: 700; color: #fff; margin: 0 0 4px; }
.hero-sub { font-size: 13px; color: rgba(255,255,255,.7); margin: 0; }
.hero-badge {
  background: rgba(255,255,255,.15);
  border: 1px solid rgba(255,255,255,.25);
  color: #fff;
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: .5px;
  backdrop-filter: blur(4px);
  margin-bottom: 12px;
  display: inline-block;
}
.hero-back {
  background: rgba(255,255,255,.15);
  border: 1.5px solid rgba(255,255,255,.3);
  color: #fff;
  padding: 9px 20px;
  border-radius: 12px;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  backdrop-filter: blur(4px);
  transition: all .2s;
  z-index: 1;
}
.hero-back:hover { background: rgba(255,255,255,.28); color: #fff; }

/* KPI cards */
.kpi-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}
.kpi-card {
  background: #fff;
  border-radius: 18px;
  padding: 20px 16px;
  text-align: center;
  box-shadow: 0 4px 20px rgba(45,106,79,.08);
  border: 1px solid rgba(116,198,157,.2);
  transition: transform .2s, box-shadow .2s;
  position: relative;
  overflow: hidden;
}
.kpi-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 3px;
  background: linear-gradient(90deg, var(--g), var(--g3));
  border-radius: 18px 18px 0 0;
}
.kpi-card:hover { transform: translateY(-4px); box-shadow: 0 12px 32px rgba(45,106,79,.15); }
.kpi-icon { font-size: 22px; margin-bottom: 8px; }
.kpi-val { font-size: 28px; font-weight: 800; color: var(--gd); line-height: 1; }
.kpi-lbl { font-size: 10px; color: #6c757d; margin-top: 5px; text-transform: uppercase; letter-spacing: .6px; font-weight: 600; }

/* Charts grid */
.charts-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.2rem;
}
.chart-card {
  background: #fff;
  border-radius: 20px;
  padding: 22px 24px;
  box-shadow: 0 4px 20px rgba(45,106,79,.07);
  border: 1px solid rgba(116,198,157,.2);
  transition: box-shadow .2s;
}
.chart-card:hover { box-shadow: 0 8px 32px rgba(45,106,79,.13); }
.chart-card.full { grid-column: 1 / -1; }
.chart-header {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 16px;
  padding-bottom: 12px;
  border-bottom: 1px solid #f0fdf4;
}
.chart-icon {
  width: 36px; height: 36px;
  background: linear-gradient(135deg, var(--g), var(--g2));
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  color: #fff;
  font-size: 14px;
  flex-shrink: 0;
}
.chart-title { font-size: 14px; font-weight: 700; color: var(--gd); margin: 0; }
.chart-sub { font-size: 11px; color: #9ca3af; margin: 0; }

/* Top races table */
.race-table { width: 100%; border-collapse: collapse; }
.race-table th {
  background: linear-gradient(135deg, var(--gd), var(--g));
  color: #fff;
  font-size: 11px;
  font-weight: 700;
  padding: 10px 14px;
  text-transform: uppercase;
  letter-spacing: .5px;
}
.race-table th:first-child { border-radius: 10px 0 0 0; }
.race-table th:last-child { border-radius: 0 10px 0 0; }
.race-table td { padding: 10px 14px; border-bottom: 1px solid #f0fdf4; font-size: 13px; }
.race-table tr:last-child td { border-bottom: none; }
.race-table tr:hover td { background: #f0fdf4; }
.race-num {
  background: linear-gradient(135deg, var(--g), var(--g2));
  color: #fff;
  padding: 3px 10px;
  border-radius: 20px;
  font-size: 12px;
  font-weight: 700;
}
.bar-wrap { height: 10px; background: #f0fdf4; border-radius: 5px; overflow: hidden; }
.bar-fill { height: 100%; background: linear-gradient(90deg, var(--g), var(--g3)); border-radius: 5px; transition: width .8s ease; }

@media(max-width:900px) {
  .kpi-grid { grid-template-columns: repeat(3, 1fr); }
  .charts-grid { grid-template-columns: 1fr; }
  .chart-card.full { grid-column: 1; }
}
@media(max-width:500px) {
  .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-hero { flex-direction: column; gap: 1rem; }
}
</style>

<div class="stats-page">

  {# ── Hero ── #}
  <div class="stats-hero">
    <div style="z-index:1">
      <span class="hero-badge"><i class="fas fa-chart-pie me-1"></i> Google Charts Bundle</span>
      <h1 class="hero-title"><i class="fas fa-seedling me-2"></i>Statistiques du Cheptel</h1>
      <p class="hero-sub">Tableau de bord analytique — données en temps réel</p>
    </div>
    <a href="{{ path('app_animal_index') }}" class="hero-back">
      <i class="fas fa-arrow-left me-2"></i>Retour
    </a>
  </div>

  {# ── KPI ── #}
  <div class="kpi-grid">
    <div class="kpi-card">
      <div class="kpi-icon">🐄</div>
      <div class="kpi-val">{{ totalAnimaux }}</div>
      <div class="kpi-lbl">Animaux</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">📋</div>
      <div class="kpi-val">{{ totalSuivis }}</div>
      <div class="kpi-lbl">Suivis</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">🌡️</div>
      <div class="kpi-val">{{ moyTemp }}°</div>
      <div class="kpi-lbl">Temp. moy.</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">⚖️</div>
      <div class="kpi-val">{{ moyPoids }}</div>
      <div class="kpi-lbl">Poids moy. kg</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">💓</div>
      <div class="kpi-val">{{ moyRythme }}</div>
      <div class="kpi-lbl">BPM moy.</div>
    </div>
    <div class="kpi-card">
      <div class="kpi-icon">✅</div>
      <div class="kpi-val">{{ parEtat['Bon'] }}</div>
      <div class="kpi-lbl">État Bon</div>
    </div>
  </div>

  {# ── Charts ── #}
  <div class="charts-grid">

    <div class="chart-card">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-paw"></i></div>
        <div>
          <p class="chart-title">Animaux par espèce</p>
          <p class="chart-sub">Répartition du cheptel</p>
        </div>
      </div>
      <div id="chartEspece" style="height:280px"></div>
    </div>

    <div class="chart-card">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-venus-mars"></i></div>
        <div>
          <p class="chart-title">Répartition par sexe</p>
          <p class="chart-sub">Mâles vs Femelles</p>
        </div>
      </div>
      <div id="chartSexe" style="height:280px"></div>
    </div>

    <div class="chart-card">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-heartbeat"></i></div>
        <div>
          <p class="chart-title">État de santé</p>
          <p class="chart-sub">Distribution des suivis sanitaires</p>
        </div>
      </div>
      <div id="chartEtat" style="height:280px"></div>
    </div>

    <div class="chart-card">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-running"></i></div>
        <div>
          <p class="chart-title">Niveau d'activité</p>
          <p class="chart-sub">Faible / Modéré / Élevé</p>
        </div>
      </div>
      <div id="chartActivite" style="height:280px"></div>
    </div>

    {% if derniersMois is not empty %}
    <div class="chart-card full">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-calendar-alt"></i></div>
        <div>
          <p class="chart-title">Évolution des suivis</p>
          <p class="chart-sub">6 derniers mois</p>
        </div>
      </div>
      <div id="chartMois" style="height:280px"></div>
    </div>
    {% endif %}

    {% if parRace is not empty %}
    <div class="chart-card full">
      <div class="chart-header">
        <div class="chart-icon"><i class="fas fa-list-ol"></i></div>
        <div>
          <p class="chart-title">Top races</p>
          <p class="chart-sub">Classement par nombre d'animaux</p>
        </div>
      </div>
      <table class="race-table">
        <thead>
          <tr><th>#</th><th>Race</th><th>Animaux</th><th style="width:45%">Proportion</th></tr>
        </thead>
        <tbody>
        {% for race, nb in parRace %}
        <tr>
          <td style="color:#9ca3af;font-weight:700;">{{ loop.index }}</td>
          <td style="font-weight:600;color:var(--gd)">{{ race }}</td>
          <td><span class="race-num">{{ nb }}</span></td>
          <td>
            <div class="bar-wrap">
              <div class="bar-fill" style="width:{{ parRaceMax > 0 ? (nb/parRaceMax*100)|round : 0 }}%"></div>
            </div>
          </td>
        </tr>
        {% endfor %}
        </tbody>
      </table>
    </div>
    {% endif %}

  </div>
</div>

<script src="https://www.gstatic.com/charts/loader.js"></script>
<script>
{{ gc_draw([chartEspece, chartSexe, chartEtat, chartActivite, chartMois], ['chartEspece', 'chartSexe', 'chartEtat', 'chartActivite', 'chartMois']) }}
</script>

{% endblock %}
