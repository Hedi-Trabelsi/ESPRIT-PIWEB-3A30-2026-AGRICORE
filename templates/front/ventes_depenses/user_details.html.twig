{% extends 'front/base_front.html.twig' %}

{% block body %}
<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
<!-- Animate.css -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css"/>
<!-- Plus Jakarta Sans Font -->
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #38a169 0%, #2f855a 100%);
        --danger-gradient: linear-gradient(135deg, #e53e3e 0%, #c53030 100%);
        --info-gradient: linear-gradient(135deg, #3182ce 0%, #2b6cb0 100%);
    }
    .details-container {
        font-family: 'Plus Jakarta Sans', sans-serif;
        color: #1a202c;
        padding: 40px 0;
    }
    .page-title {
        font-weight: 800;
        font-size: 1.75rem;
        margin: 0;
        color: #1a202c;
        letter-spacing: -0.025em;
    }
    .card-detail {
        background: #fff;
        border-radius: 20px;
        border: none;
        padding: 25px;
        height: 100%;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
        transition: transform 0.3s ease;
    }
    .card-detail:hover {
        transform: translateY(-5px);
    }
    .card-title-custom {
        font-size: 1.1rem;
        font-weight: 700;
        color: #2d3748;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 20px;
    }
    .card-title-custom::before {
        content: "";
        width: 10px;
        height: 10px;
        background: #e53e3e;
        border-radius: 3px;
        display: inline-block;
    }
    .card-title-custom.vente::before {
        background: #38a169;
    }
    .card-title-custom.info::before {
        background: #3182ce;
    }
    .kpi-card {
        border-radius: 20px;
        padding: 20px;
        color: white;
        position: relative;
        overflow: hidden;
        border: none;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
    }
    .kpi-card.sales { background: var(--primary-gradient); }
    .kpi-card.expenses { background: var(--danger-gradient); }
    .kpi-card.net { background: var(--info-gradient); }
    .kpi-card.anomaly { background: var(--danger-gradient); border: 2px solid rgba(255,255,255,0.2); }
    
    .kpi-card .icon {
        position: absolute;
        right: -5px;
        bottom: -5px;
        font-size: 4rem;
        opacity: 0.2;
        transform: rotate(-15deg);
    }
    .kpi-label { font-size: 0.8rem; font-weight: 600; opacity: 0.9; text-transform: uppercase; letter-spacing: 0.05em; }
    .kpi-value { font-size: 1.5rem; font-weight: 800; margin: 5px 0 0; }

    .item-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 12px 15px;
        border-radius: 12px;
        margin-bottom: 10px;
        background: #f8fafc;
        border: 1px solid #edf2f7;
        transition: all 0.2s;
    }
    .item-row:hover {
        background: #fff;
        border-color: #cbd5e0;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    .item-info { display: flex; flex-direction: column; gap: 2px; }
    .item-name { font-weight: 700; color: #1a202c; font-size: 0.95rem; }
    .item-meta { font-size: 0.8rem; color: #718096; display: flex; align-items: center; gap: 6px; }
    .item-price { font-weight: 800; font-size: 1rem; }
    
    .z-badge {
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.7rem;
        margin-left: 8px;
    }
    .z-badge.normal { background: #dcfce7; color: #166534; }
    .z-badge.danger { 
        background: #fee2e2; 
        color: #991b1b; 
        border: 1px solid #fecaca;
        animation: pulse-red 2s infinite;
    }
    
    @keyframes pulse-red {
        0% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0.4); }
        70% { box-shadow: 0 0 0 10px rgba(239, 68, 68, 0); }
        100% { box-shadow: 0 0 0 0 rgba(239, 68, 68, 0); }
    }

    .advice-container {
        background: #f0fff4;
        border: 1px solid #c6f6d5;
        border-radius: 20px;
        padding: 20px;
        margin-top: 20px;
        position: relative;
        overflow: hidden;
        display: flex;
        align-items: center;
        gap: 20px;
    }
    .ai-badge {
        position: absolute;
        top: 15px;
        left: 20px;
        background: #10b981;
        color: white;
        padding: 4px 12px;
        border-radius: 50px;
        font-size: 0.65rem;
        font-weight: 800;
        text-transform: uppercase;
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .forecast-left {
        min-width: 150px;
        padding-top: 15px;
        border-right: 1px solid #c6f6d5;
        padding-right: 20px;
    }
    .forecast-label { font-size: 0.7rem; font-weight: 700; color: #718096; text-transform: uppercase; }
    .forecast-value { font-size: 1.25rem; font-weight: 800; color: #059669; }
    .advice-right { flex-grow: 1; padding-top: 15px; }
    .advice-quote { font-size: 0.95rem; color: #065f46; font-style: italic; line-height: 1.5; }

    .anomaly-alert {
        background: #fff5f5;
        border-left: 5px solid #e53e3e;
        border-radius: 15px;
        padding: 15px;
        margin-bottom: 25px;
        display: flex;
        align-items: center;
        gap: 15px;
    }

    /* World Bank Section */
    .wb-header {
        background: #1a4d2e;
        border-radius: 20px 20px 0 0;
        padding: 15px 25px;
        color: white;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .wb-title { font-size: 1.1rem; font-weight: 700; margin: 0; color: white; }
    .wb-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: #e2e8f0;
        border: 1px solid #e2e8f0;
        border-radius: 0 0 20px 20px;
        overflow: hidden;
    }
    .wb-card { background: white; padding: 20px; display: flex; flex-direction: column; gap: 8px; }
    .wb-icon-box {
        width: 35px; height: 35px; background: #f0fff4; color: #38a169;
        border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 1rem;
    }
    .wb-label { font-size: 0.8rem; color: #718096; font-weight: 600; }
    .wb-value { font-size: 1.5rem; font-weight: 800; color: #1a202c; }
    .wb-unit { font-size: 0.7rem; color: #a0aec0; }

    .btn-retour {
        background: white; border: 1px solid #e2e8f0; color: #4a5568;
        border-radius: 12px; padding: 8px 16px; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: all 0.2s;
    }
    .btn-retour:hover { background: #f7fafc; transform: translateX(-3px); }
    .btn-report {
        background: var(--info-gradient); border: none; color: white;
        border-radius: 12px; padding: 8px 16px; font-weight: 600;
        text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: all 0.2s;
    }
    .btn-report:hover { background: #2b6cb0; color: white; transform: translateY(-2px); }
</style>

<div class="container details-container">
    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div class="d-flex align-items-center gap-3">
            <a href="{{ app.request.attributes.get('_route') == 'app_my_details' ? path('app_home') : path('app_ventes_depenses') }}" class="btn-retour">
                <i class="bi bi-arrow-left"></i> Retour
            </a>
            <div>
                <h1 class="page-title">{{ user.nom }} {{ user.prenom }}</h1>
                <p class="text-muted mb-0 small">Analyse détaillée de vos activités financières</p>
            </div>
        </div>
        <a href="{{ path('app_user_report_pdf', {id: user.id}) }}" class="btn-report">
            <i class="bi bi-file-earmark-pdf-fill"></i> Rapport Mensuel
        </a>
    </div>

    <!-- KPI Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="kpi-card sales">
                <div class="icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="kpi-label">Total Ventes</div>
                <div class="kpi-value">{{ totalSales|number_format(2, '.', ' ') }} DT</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card expenses">
                <div class="icon"><i class="bi bi-cart-dash"></i></div>
                <div class="kpi-label">Total Dépenses</div>
                <div class="kpi-value">{{ totalExpenses|number_format(2, '.', ' ') }} DT</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card net">
                <div class="icon"><i class="bi bi-piggy-bank"></i></div>
                <div class="kpi-label">Bénéfice Net</div>
                <div class="kpi-value">{{ netProfit|number_format(2, '.', ' ') }} DT</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card anomaly">
                <div class="icon"><i class="bi bi-exclamation-triangle"></i></div>
                <div class="kpi-label">Anomalies Détectées</div>
                <div class="kpi-value">{{ anomaliesCount }} <small style="font-size: 0.9rem; opacity: 0.8;">({{ anomalyRate|number_format(0) }}%)</small></div>
            </div>
        </div>
    </div>

    <!-- World Bank Agriculture Section -->
    <div class="mb-4">
        <div class="wb-header">
            <div>
                <h3 class="wb-title">Indicateurs Agricoles (Tunisie)</h3>
                <p class="mb-0 small opacity-75">Source : World Bank API</p>
            </div>
            <span class="badge bg-white bg-opacity-10">API</span>
        </div>
        <div class="wb-grid" id="wb-indicators">
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-truck"></i></div>
                    <span class="wb-label">Tracteurs / 100 km²</span>
                </div>
                <div class="wb-value" id="wb-tractors"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-tractors-year"></div>
            </div>
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-tree"></i></div>
                    <span class="wb-label">Terres arables</span>
                </div>
                <div class="wb-value" id="wb-arable"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-arable-year"></div>
            </div>
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-patch-check"></i></div>
                    <span class="wb-label">Terres agricoles</span>
                </div>
                <div class="wb-value" id="wb-agri-land"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-agri-land-year"></div>
            </div>
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-bar-chart-line"></i></div>
                    <span class="wb-label">Agriculture / PIB</span>
                </div>
                <div class="wb-value" id="wb-gdp"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-gdp-year"></div>
            </div>
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-people"></i></div>
                    <span class="wb-label">Emploi agricole</span>
                </div>
                <div class="wb-value" id="wb-employment"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-employment-year"></div>
            </div>
            <div class="wb-card">
                <div class="d-flex align-items-center gap-2">
                    <div class="wb-icon-box"><i class="bi bi-moisture"></i></div>
                    <span class="wb-label">Rendement céréalier</span>
                </div>
                <div class="wb-value" id="wb-yield"><small class="text-muted italic">Chargement...</small></div>
                <div class="wb-unit" id="wb-yield-year"></div>
            </div>
        </div>
    </div>

    {% if anomaliesCount > 0 %}
        <div class="anomaly-alert animate__animated animate__headShake">
            <div class="icon text-danger fs-3"><i class="bi bi-shield-fill-exclamation"></i></div>
            <div>
                <h6 class="mb-1 fw-bold text-danger">Anomalies détectées par l'IA</h6>
                <p class="mb-0 text-muted small">Nous avons identifié {{ anomaliesCount }} dépense(s) inhabituelle(s). Veuillez vérifier vos transactions.</p>
            </div>
        </div>
    {% endif %}

    <div class="row g-4 mb-4">
        <!-- Dépenses Column -->
        <div class="col-lg-6">
            <div class="card-detail">
                <h3 class="card-title-custom">Dépenses Récentes</h3>
                {% if anomalyResults is empty %}
                    <div class="text-center py-4">
                        <i class="bi bi-inbox text-muted fs-2"></i>
                        <p class="text-muted mt-2 small">Aucune dépense enregistrée.</p>
                    </div>
                {% else %}
                    <div class="overflow-auto" style="max-height: 350px;">
                        {% for res in anomalyResults %}
                            <div class="item-row" {% if res.analysis.isAnomaly %}style="border-left: 4px solid #e53e3e;"{% endif %}>
                                <div class="item-info">
                                    <div class="d-flex align-items-center">
                                        <span class="item-name">{{ res.depense.type }}</span>
                                        {% if res.analysis.isAnomaly %}
                                            <span class="z-badge danger animate__animated animate__pulse animate__infinite">
                                                <i class="bi bi-exclamation-triangle-fill"></i> ANOMALIE
                                            </span>
                                        {% else %}
                                            <span class="z-badge normal">Z: {{ res.analysis.score|number_format(1) }}</span>
                                        {% endif %}
                                    </div>
                                    <span class="item-meta"><i class="bi bi-calendar3"></i> {{ res.depense.date|date('d M Y') }}</span>
                                </div>
                                <div class="item-price text-danger">-{{ res.depense.montant|number_format(2, '.', ' ') }} DT</div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- Ventes Column -->
        <div class="col-lg-6">
            <div class="card-detail">
                <h3 class="card-title-custom vente">Ventes Récentes</h3>
                {% if ventes is empty %}
                    <div class="text-center py-4">
                        <i class="bi bi-inbox text-muted fs-2"></i>
                        <p class="text-muted mt-2 small">Aucune vente enregistrée.</p>
                    </div>
                {% else %}
                    <div class="overflow-auto" style="max-height: 350px;">
                        {% for vente in ventes %}
                            <div class="item-row" style="border-left: 4px solid #38a169;">
                                <div class="item-info">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="item-name">{{ vente.produit }}</span>
                                        <span class="badge-modern bg-success-subtle text-success" style="background: #dcfce7; color: #166534; font-size: 0.7rem; font-weight: 600; padding: 4px 8px; border-radius: 8px;">
                                            {{ vente.prixUnitaire }} DT × {{ vente.quantite }}
                                        </span>
                                    </div>
                                    <span class="item-meta"><i class="bi bi-calendar3"></i> {{ vente.date|date('d M Y') }}</span>
                                </div>
                                <div class="item-price text-success">+{{ vente.chiffreAffaires|number_format(2, '.', ' ') }} DT</div>
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    

    <!-- FullCalendar Section -->
    <div class="card-detail mb-4">
        <h3 class="card-title-custom info">Calendrier des Activités</h3>
        <div id="calendar-holder"></div>
    </div>
</div>

<!-- FullCalendar JS & CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fullcalendar/core@4.1.0/main.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@4.1.0/main.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fullcalendar/timegrid@4.1.0/main.min.css">

<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/core@4.1.0/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/interaction@4.1.0/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/daygrid@4.1.0/main.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@fullcalendar/timegrid@4.1.0/main.min.js"></script>

<style>
    #calendar-holder {
        background: white;
        padding: 20px;
        border-radius: 20px;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }
    .fc-header-toolbar {
        margin-bottom: 1.5rem !important;
    }
    .fc-center h2 {
        font-size: 1.2rem !important;
        font-weight: 800 !important;
        color: #1a202c !important;
    }
    .fc-button {
        background: #fff !important;
        border: 1px solid #e2e8f0 !important;
        color: #4a5568 !important;
        font-weight: 600 !important;
        padding: 6px 12px !important;
        border-radius: 10px !important;
        box-shadow: none !important;
    }
    .fc-button-active {
        background: #38a169 !important;
        border-color: #38a169 !important;
        color: white !important;
    }
    .fc-event {
        border-radius: 8px !important;
        padding: 3px 8px !important;
        font-size: 0.75rem !important;
        font-weight: 700 !important;
        border: none !important;
    }
    .fc-time { display: none !important; }
</style>

<!-- ApexCharts Script -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const themeColors = ['#38a169', '#e53e3e', '#3182ce', '#ecc94b', '#805ad5', '#319795', '#ed64a6'];
        
        // Z-Score Chart
        const zScoreData = {{ anomalyResults|map(r => {
            'type': r.depense.type,
            'zScore': r.analysis.score
        })|json_encode|raw }};

        const zScoreOptions = {
            series: [{
                name: 'Z-Score',
                data: zScoreData.map(r => r.zScore.toFixed(2))
            }],
            chart: {
                type: 'bar',
                height: 320,
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            plotOptions: {
                bar: {
                    distributed: true,
                    borderRadius: 4,
                    columnWidth: '40%'
                }
            },
            colors: zScoreData.map(r => r.zScore > 2.0 ? '#e53e3e' : '#38a169'),
            dataLabels: { enabled: false },
            xaxis: {
                categories: zScoreData.map((r, i) => r.type + ' ' + (i + 1)),
                labels: { show: false }
            },
            yaxis: {
                min: 0,
                labels: { style: { colors: '#718096', fontWeight: 600 } }
            },
            legend: { show: false },
            grid: { borderColor: '#edf2f7', strokeDashArray: 4 }
        };
        new ApexCharts(document.querySelector("#zScoreChart"), zScoreOptions).render();

        // Forecast Chart
        const historyData = {{ forecastData.history|json_encode|raw }};
        const forecastData = {{ forecastData.forecast|json_encode|raw }};
        
        const allDates = [...historyData.map(h => h.date), ...forecastData.map(f => f.date)];
        const historySeries = historyData.map(h => h.value);
        const forecastSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.value)];
        const lowerSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.lower)];
        const upperSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.upper)];

        const forecastOptions = {
            series: [
                { name: 'Historique', type: 'line', data: historySeries },
                { name: 'Prévision', type: 'line', data: forecastSeries },
                { 
                    name: 'Intervalle', 
                    type: 'area', 
                    data: upperSeries.map((u, i) => ({
                        x: allDates[i],
                        y: [lowerSeries[i], u]
                    })).filter(p => p.y[0] !== null)
                }
            ],
            chart: {
                height: 320,
                type: 'line',
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            colors: ['#38a169', '#3182ce', '#cbd5e0'],
            stroke: { width: [3, 3, 0], curve: 'smooth', dashArray: [0, 8, 0] },
            fill: { type: ['solid', 'solid', 'gradient'], gradient: { opacityFrom: 0.3, opacityTo: 0.1 } },
            markers: { size: [4, 4, 0] },
            xaxis: {
                categories: allDates.map(d => {
                    const [year, month] = d.split('-');
                    const date = new Date(year, month - 1);
                    return date.toLocaleString('default', { month: 'short' });
                }),
                labels: { style: { colors: '#718096', fontWeight: 600 } }
            },
            yaxis: {
                labels: { 
                    style: { colors: '#718096', fontWeight: 600 },
                    formatter: (val) => val ? val.toLocaleString() + ' DT' : '0'
                }
            },
            grid: { borderColor: '#edf2f7', strokeDashArray: 4 },
            legend: { position: 'top', horizontalAlign: 'right' }
        };
        new ApexCharts(document.querySelector("#forecastChart"), forecastOptions).render();

        // World Bank API
        async function fetchWBData(indicator, elementId, yearElementId) {
            try {
                const response = await fetch(`https://api.worldbank.org/v2/country/TUN/indicator/${indicator}?format=json&per_page=5`);
                const data = await response.json();
                if (data && data[1]) {
                    const latest = data[1].find(item => item.value !== null);
                    if (latest) {
                        document.getElementById(elementId).innerText = latest.value.toLocaleString(undefined, { maximumFractionDigits: 1 });
                        document.getElementById(yearElementId).innerText = `. ${latest.date}`;
                    }
                }
            } catch (error) {
                console.error(`Error:`, error);
            }
        }

        fetchWBData('AG.LND.TRAC.ZS', 'wb-tractors', 'wb-tractors-year');
        fetchWBData('AG.LND.ARBL.ZS', 'wb-arable', 'wb-arable-year');
        fetchWBData('AG.LND.AGRI.ZS', 'wb-agri-land', 'wb-agri-land-year');
        fetchWBData('NV.AGR.TOTL.ZS', 'wb-gdp', 'wb-gdp-year');
        fetchWBData('SL.AGR.EMPL.ZS', 'wb-employment', 'wb-employment-year');
        fetchWBData('AG.YLD.CREL.KG', 'wb-yield', 'wb-yield-year');

        // FullCalendar
        var calendarEl = document.getElementById('calendar-holder');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            plugins: [ 'interaction', 'dayGrid', 'timeGrid' ],
            defaultView: 'dayGridMonth',
            header: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            eventSources: [
                {
                    url: "{{ path('api_finance_calendar_events', {id: user.id}) }}",
                    method: "GET"
                },
            ],
            locale: 'fr',
            buttonText: {
                today:    'Aujourd\'hui',
                month:    'Mois',
                week:     'Semaine',
                day:      'Jour'
            }
        });
        calendar.render();
    });
</script>
{% endblock %}
