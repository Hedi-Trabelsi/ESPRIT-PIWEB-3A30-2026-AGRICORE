    }
    .fc-view-container {
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid #edf2f7;
    }
    .fc-head-container {
        background: #f8fafc;
        border-bottom: 1px solid #edf2f7;
    }
    .fc-day-header {
        padding: 15px 0 !important;
        font-weight: 700 !important;
        color: #718096 !important;
        text-transform: uppercase;
