<!-- ApexCharts Script -->
<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        const themeColors = ['#38a169', '#e53e3e', '#3182ce', '#ecc94b', '#805ad5', '#319795', '#ed64a6'];
        
        // Pie Chart
        const pieData = {{ expensesByCategory|json_encode|raw }};
        const pieOptions = {
            series: Object.values(pieData),
            labels: Object.keys(pieData),
            chart: {
                type: 'donut',
                height: 380,
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            colors: themeColors,
            stroke: { show: false },
            legend: {
                position: 'bottom',
                fontSize: '14px',
                fontWeight: 600,
                labels: { colors: '#4a5568' },
                markers: { radius: 12 }
            },
            plotOptions: {
                pie: {
                    donut: {
                        size: '70%',
                        labels: {
                            show: true,
                            total: {
                                show: true,
                                label: 'Total',
                                formatter: () => '{{ totalExpenses|number_format(0, ".", " ") }} DT',
                                color: '#1a202c',
                                fontWeight: 800
                            }
                        }
                    }
                }
            },
            dataLabels: { enabled: false }
        };
        new ApexCharts(document.querySelector("#pieChart"), pieOptions).render();

        // Bar Chart
        const monthlyStats = {{ monthlyStats|json_encode|raw }};
        const months = Object.keys(monthlyStats);
        const expenses = months.map(m => monthlyStats[m].expenses);
        const sales = months.map(m => monthlyStats[m].sales);

        const barOptions = {
            series: [
                { name: 'Ventes', data: sales },
                { name: 'Dépenses', data: expenses }
            ],
            chart: {
                type: 'bar',
                height: 380,
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            plotOptions: {
                bar: {
                    horizontal: false,
                    columnWidth: '55%',
                    borderRadius: 8,
                    dataLabels: { position: 'top' }
                },
            },
            colors: ['#38a169', '#e53e3e'],
            dataLabels: {
                enabled: false,
                offsetY: -20,
                style: { fontSize: '12px', colors: ["#304758"] }
            },
            stroke: { show: true, width: 2, colors: ['transparent'] },
            xaxis: {
                categories: months.map(m => {
                    const [year, month] = m.split('-');
                    const date = new Date(year, month - 1);
                    return date.toLocaleString('default', { month: 'short' });
                }),
                axisBorder: { show: false },
                axisTicks: { show: false },
                labels: { style: { colors: '#718096', fontWeight: 600 } }
            },
            yaxis: {
                labels: { 
                    style: { colors: '#718096', fontWeight: 600 },
                    formatter: (val) => val.toLocaleString() + ' DT'
                }
            },
            grid: {
                borderColor: '#edf2f7',
                strokeDashArray: 4,
                xaxis: { lines: { show: false } }
            },
            fill: {
                type: 'gradient',
                gradient: {
                    shade: 'light',
                    type: "vertical",
                    shadeIntensity: 0.25,
                    gradientToColors: undefined,
                    inverseColors: true,
                    opacityFrom: 0.85,
                    opacityTo: 0.85,
                    stops: [50, 0, 100]
                },
            },
            tooltip: {
                theme: 'light',
                x: { show: false },
                y: { formatter: (val) => val.toLocaleString() + ' DT' }
            }
        };
        new ApexCharts(document.querySelector("#barChart"), barOptions).render();

        // Z-Score Chart
        const zScoreData = {{ anomalyResults|map(r => {
            'type': r.depense.type,
            'zScore': r.analysis.score
        })|json_encode|raw }};

        const zScoreOptions = {
            series: [{
                name: 'Z-Score',
                data: zScoreData.map(r => r.zScore.toFixed(2))
            }],
            chart: {
                type: 'bar',
                height: 380,
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            plotOptions: {
                bar: {
                    distributed: true,
                    borderRadius: 4,
                    columnWidth: '40%'
                }
            },
            colors: zScoreData.map(r => r.zScore > 2.0 ? '#e53e3e' : '#38a169'),
            dataLabels: { enabled: false },
            xaxis: {
                categories: zScoreData.map((r, i) => r.type + ' ' + (i + 1)),
                labels: { show: false }
            },
            yaxis: {
                min: 0,
                labels: { style: { colors: '#718096', fontWeight: 600 } }
            },
            legend: { show: false },
            grid: { borderColor: '#edf2f7', strokeDashArray: 4 }
        };
        new ApexCharts(document.querySelector("#zScoreChart"), zScoreOptions).render();

        // Forecast Chart
        const historyData = {{ forecastData.history|json_encode|raw }};
        const forecastData = {{ forecastData.forecast|json_encode|raw }};
        
        const allDates = [...historyData.map(h => h.date), ...forecastData.map(f => f.date)];
        const historySeries = historyData.map(h => h.value);
        const forecastSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.value)];
        const lowerSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.lower)];
        const upperSeries = [...Array(historyData.length).fill(null), ...forecastData.map(f => f.upper)];

        const forecastOptions = {
            series: [
                { name: 'Historique', type: 'line', data: historySeries },
                { name: 'Prévision', type: 'line', data: forecastSeries },
                { 
                    name: 'Intervalle de Confiance', 
                    type: 'area', 
                    data: upperSeries.map((u, i) => ({
                        x: allDates[i],
                        y: [lowerSeries[i], u]
                    })).filter(p => p.y[0] !== null)
                }
            ],
            chart: {
                height: 380,
                type: 'line',
                toolbar: { show: false },
                fontFamily: 'Plus Jakarta Sans, sans-serif'
            },
            colors: ['#38a169', '#3182ce', '#cbd5e0'],
            stroke: {
                width: [4, 4, 0],
                curve: 'smooth',
                dashArray: [0, 8, 0]
            },
            fill: {
                type: ['solid', 'solid', 'gradient'],
                gradient: {
                    inverseColors: false,
                    shade: 'light',
                    type: "vertical",
                    opacityFrom: 0.3,
                    opacityTo: 0.1,
                    stops: [0, 100]
                }
            },
            markers: {
                size: [5, 5, 0],
                strokeWidth: 0,
                hover: { size: 7 }
            },
            xaxis: {
                categories: allDates.map(d => {
                    const [year, month] = d.split('-');
                    const date = new Date(year, month - 1);
                    return date.toLocaleString('default', { month: 'short', year: '2-digit' });
                }),
                axisBorder: { show: false },
                labels: { style: { colors: '#718096', fontWeight: 600 } }
            },
            yaxis: {
                labels: { 
                    style: { colors: '#718096', fontWeight: 600 },
                    formatter: (val) => val ? val.toLocaleString() + ' DT' : '0 DT'
                }
            },
            grid: { borderColor: '#edf2f7', strokeDashArray: 4 },
            legend: { 
                position: 'top', 
                horizontalAlign: 'right',
                fontWeight: 600,
                markers: { radius: 12 }
            },
            tooltip: {
                shared: true,
                intersect: false,
                theme: 'light',
                y: { formatter: (val) => val ? val.toLocaleString() + ' DT' : null }
            }
        };
        new ApexCharts(document.querySelector("#forecastChart"), forecastOptions).render();

        // World Bank API Fetch
        async function fetchWBData(indicator, elementId, yearElementId) {
            try {
                const response = await fetch(`https://api.worldbank.org/v2/country/TUN/indicator/${indicator}?format=json&per_page=5`);
                const data = await response.json();
                
                if (data && data[1]) {
                    // Find first non-null value
                    const latest = data[1].find(item => item.value !== null);
                    if (latest) {
                        document.getElementById(elementId).innerText = latest.value.toLocaleString(undefined, { maximumFractionDigits: 1 });
                        document.getElementById(yearElementId).innerText = `. ${latest.date}`;
                    } else {
                        document.getElementById(elementId).innerText = "N/A";
                    }
                }
            } catch (error) {
                console.error(`Error fetching ${indicator}:`, error);
                document.getElementById(elementId).innerText = "Err.";
            }
        }

        // Fetch all indicators
        fetchWBData('AG.LND.TRAC.ZS', 'wb-tractors', 'wb-tractors-year'); // Tractors
        fetchWBData('AG.LND.ARBL.ZS', 'wb-arable', 'wb-arable-year');     // Arable land %
        fetchWBData('AG.LND.AGRI.ZS', 'wb-agri-land', 'wb-agri-land-year'); // Agricultural land %
        fetchWBData('NV.AGR.TOTL.ZS', 'wb-gdp', 'wb-gdp-year');           // Agri % GDP
        fetchWBData('SL.AGR.EMPL.ZS', 'wb-employment', 'wb-employment-year'); // Agri employment %
        fetchWBData('AG.YLD.CREL.KG', 'wb-yield', 'wb-yield-year');      // Cereal yield

        // FullCalendar
        var calendarEl = document.getElementById('calendar-holder');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            plugins: [ 'interaction', 'dayGrid', 'timeGrid' ],
            defaultView: 'dayGridMonth',
            editable: true,
            header: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay'
            },
            eventSources: [
                {
                    url: "{{ path('fc_load_events') }}",
                    method: "POST",
                    extraParams: {
                        filters: JSON.stringify({ "userId": "{{ user.id }}" })
                    },
                    failure: function() {
                        // alert('There was an error while fetching FullCalendar events!');
                    },
                },
            ],
            timeFormat: 'H:i',
            locale: 'fr',
            buttonText: {
                today:    'Aujourd\'hui',
                month:    'Mois',
                week:     'Semaine',
                day:      'Jour'
            }
        });
        calendar.render();
    });
</script>
{% endblock %}
