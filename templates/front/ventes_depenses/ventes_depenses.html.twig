{% extends 'front/base_front.html.twig' %}

{% block body %}
<style>
    .user-card {
        background: #fff;
        border-radius: 15px;
        border: 1px solid #e8e8e8;
        padding: 20px;
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
        position: relative;
    }
    .user-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
    }
    .user-avatar {
        width: 60px;
        height: 60px;
        background: #198754;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 700;
        font-size: 1.2rem;
        margin-right: 15px;
        overflow: hidden;
    }
    .user-avatar img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .user-name {
        font-weight: 700;
        font-size: 1.1rem;
        margin: 0;
        color: #2d3748;
    }
    .user-handle {
        color: #a0aec0;
        font-size: 0.85rem;
    }
    .badge-role {
        background: #dcfce7;
        color: #166534;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        display: inline-block;
        margin-top: 5px;
    }
    .user-stats {
        display: flex;
        justify-content: space-between;
        margin-top: 20px;
        padding-top: 15px;
        border-top: 1px solid #f7fafc;
    }
    .user-stat-item {
        text-align: center;
    }
    .user-stat-value {
        display: block;
        font-weight: 700;
        color: #2d3748;
    }
    .user-stat-label {
        font-size: 0.7rem;
        color: #a0aec0;
        text-transform: uppercase;
    }
    .btn-card {
        width: 100%;
        padding: 10px;
        border-radius: 8px;
        font-size: 0.85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        transition: all 0.2s;
        text-decoration: none;
        margin-top: 20px;
        background: #f8fafc;
        color: #4a5568;
        border: 1px solid #e2e8f0;
    }
    .btn-card:hover {
        background: #edf2f7;
        color: #2d3748;
    }
</style>

<div class="container py-5">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h1 class="display-4 font-weight-bold mb-3">Ventes & Dépenses</h1>
            <p class="lead text-muted">Consultez les statistiques financières de nos membres</p>
        </div>
    </div>

    <div class="row g-4">
        {% for stat in usersWithStats %}
            {% set user = stat.user %}
            <div class="col-md-4">
                <div class="user-card">
                    <div class="d-flex align-items-center">
                        <div class="user-avatar">
                            {% if user.imageBase64 %}
                                <img src="data:image/png;base64,{{ user.imageBase64 }}" alt="{{ user.nom }}">
                            {% else %}
                                {{ user.nom|slice(0, 1)|upper }}{{ user.prenom|slice(0, 1)|upper }}
                            {% endif %}
                        </div>
                        <div>
                            <h3 class="user-name">{{ user.nom }} {{ user.prenom }}</h3>
                            <p class="user-handle">@{{ user.nom|lower }}.{{ user.prenom|lower }} • #00{{ user.id }}</p>
                            <span class="badge-role">
                                <i class="bi bi-leaf"></i> Agriculteur
                            </span>
                        </div>
                    </div>

                    <div class="user-stats">
                        <div class="user-stat-item">
                            <span class="user-stat-value">{{ stat.totalExpenses|number_format(0, ',', ' ') }}</span>
                            <span class="user-stat-label">Dépenses</span>
                        </div>
                        <div class="user-stat-item">
                            <span class="user-stat-value">{{ stat.totalVentes|number_format(0, ',', ' ') }}</span>
                            <span class="user-stat-label">Ventes</span>
                        </div>
                        <div class="user-stat-item">
                            <span class="user-stat-value">{{ stat.grandTotal|number_format(0, ',', ' ') }} DT</span>
                            <span class="user-stat-label">Total</span>
                        </div>
                    </div>

                    <a href="{{ path('app_user_details_front', {'id': user.id}) }}" class="btn-card">
                        <i class="bi bi-file-earmark-text"></i> Détails
                    </a>
                </div>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
