    <style>
        .profile-header {
            background: linear-gradient(135deg, #0F4229 0%, #348E38 100%);
            padding: 80px 0 120px;
            position: relative;
            overflow: hidden;
        }
        .profile-header::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -20%;
            width: 500px;
            height: 500px;
            background: rgba(255, 255, 255, 0.05);
            border-radius: 50%;
        }
        .profile-header::after {
            content: '';
            position: absolute;
            bottom: -30%;
            left: -10%;
            width: 400px;
            height: 400px;
            background: rgba(255, 255, 255, 0.03);
            border-radius: 50%;
        }
        .profile-header h1 {
            font-family: 'Jost', sans-serif;
            font-weight: 700;
            color: #fff;
        }
        .profile-header .breadcrumb-item,
        .profile-header .breadcrumb-item a {
            color: rgba(255, 255, 255, 0.8);
            text-decoration: none;
        }
        .profile-header .breadcrumb-item.active {
            color: #fff;
        }
        .profile-header .breadcrumb-item + .breadcrumb-item::before {
            color: rgba(255, 255, 255, 0.5);
        }

        .profile-content {
            margin-top: -80px;
            position: relative;
            z-index: 2;
            padding-bottom: 60px;
        }

        .profile-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 10px 40px rgba(15, 66, 41, 0.12);
            overflow: hidden;
        }

        .profile-avatar-section {
            text-align: center;
            padding: 40px 30px 30px;
            background: linear-gradient(180deg, #f8fdf8 0%, #ffffff 100%);
            border-bottom: 1px solid #E8F5E9;
        }

        .profile-avatar {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            object-fit: cover;
            border: 5px solid #fff;
            box-shadow: 0 5px 25px rgba(15, 66, 41, 0.2);
            margin-bottom: 20px;
        }

        .profile-avatar-placeholder {
            width: 140px;
            height: 140px;
            border-radius: 50%;
            background: linear-gradient(135deg, #348E38, #0F4229);
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            border: 5px solid #fff;
            box-shadow: 0 5px 25px rgba(15, 66, 41, 0.2);
        }

        .profile-avatar-placeholder span {
            font-size: 48px;
            font-weight: 700;
            color: #fff;
            font-family: 'Jost', sans-serif;
        }

        .profile-name {
            font-family: 'Jost', sans-serif;
            font-weight: 700;
            color: #0F4229;
            font-size: 24px;
            margin-bottom: 5px;
        }

        .profile-role {
            display: inline-block;
            padding: 4px 16px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: 600;
            margin-top: 8px;
        }

        .role-user {
            background: #E8F5E9;
            color: #348E38;
        }

        .role-admin {
            background: #FFF3E0;
            color: #E65100;
        }

        .profile-stats {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-top: 20px;
            padding-top: 20px;
            border-top: 1px solid #E8F5E9;
        }

        .profile-stat {
            text-align: center;
        }

        .profile-stat .stat-value {
            font-family: 'Jost', sans-serif;
            font-weight: 700;
            font-size: 22px;
            color: #348E38;
        }

        .profile-stat .stat-label {
            font-size: 13px;
            color: #525368;
        }

        .profile-info-section {
            padding: 30px;
        }

        .info-card {
            background: #f8fdf8;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 15px;
            border: 1px solid #E8F5E9;
            transition: all 0.3s;
        }

        .info-card:hover {
            border-color: #348E38;
            box-shadow: 0 3px 15px rgba(52, 142, 56, 0.1);
        }

        .info-card .info-icon {
            width: 45px;
            height: 45px;
            border-radius: 10px;
            background: linear-gradient(135deg, #348E38, #0F4229);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-size: 18px;
            flex-shrink: 0;
        }

        .info-card .info-label {
            font-size: 13px;
            color: #525368;
            margin-bottom: 2px;
        }

        .info-card .info-value {
            font-weight: 600;
            color: #0F4229;
            font-size: 15px;
        }

        .quick-actions .action-btn {
            display: flex;
            align-items: center;
            padding: 15px 20px;
            border-radius: 12px;
            border: 2px solid #E8F5E9;
            background: #fff;
            color: #0F4229;
            text-decoration: none;
            transition: all 0.3s;
            font-weight: 500;
            margin-bottom: 10px;
        }

        .quick-actions .action-btn:hover {
            border-color: #348E38;
            background: #f8fdf8;
            transform: translateX(5px);
            color: #348E38;
        }

        .quick-actions .action-btn i {
            width: 35px;
            height: 35px;
            border-radius: 8px;
            background: #E8F5E9;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 12px;
            color: #348E38;
            font-size: 14px;
            flex-shrink: 0;
        }

        .quick-actions .action-btn.logout-btn {
            border-color: #ffebee;
            color: #c62828;
        }

        .quick-actions .action-btn.logout-btn:hover {
            background: #ffebee;
            border-color: #ef9a9a;
            color: #c62828;
        }

        .quick-actions .action-btn.logout-btn i {
            background: #ffebee;
            color: #c62828;
        }

        .section-title {
            font-family: 'Jost', sans-serif;
            font-weight: 600;
            color: #0F4229;
            font-size: 18px;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid #E8F5E9;
        }

        .member-since {
            text-align: center;
            color: #525368;
            font-size: 13px;
            padding: 15px;
            background: #f8fdf8;
            border-radius: 0 0 16px 16px;
        }

        .member-since i {
            color: #348E38;
        }
    </style>
</head>

