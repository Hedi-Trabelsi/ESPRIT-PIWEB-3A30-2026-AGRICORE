                <i class="fas fa-user-circle me-2"></i>
                {{ app.user.prenom }} {{ app.user.nom }}
            </span>
        </div>
    </div>
</div>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
