                    <a href="{{ path('app_evenements') }}" class="dropdown-item">Evenements</a>
                    <a href="{{ path('app_suivi_animal') }}" class="dropdown-item">Suivi animal</a>
                    <a href="{{ path('app_achat_equipement') }}" class="dropdown-item">Achat d'equipement</a>
                    <a href="{{ path('app_ventes_depenses') }}" class="dropdown-item">Ventes & depenses</a>
                </div>
            </div>
        </div>

        <a href="{{ path('app_profile') }}" class="d-none d-lg-block me-4">
            {% if app.user.photo %}
                <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Profile"
                     style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #198754;">
            {% else %}
                <img src="{{ asset('img/profile.webp') }}" alt="Profile"
                     style="width:45px; height:45px; border-radius:50%; object-fit:cover; border:2px solid #198754;">
            {% endif %}
        </a>
    </div>
</nav>

<!-- Profile Header -->
<div class="profile-header">
    <div class="container">
        <div class="text-center">
            <h1 class="mb-3">Mon Profil</h1>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb justify-content-center mb-0">
                    <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Profil</li>
                </ol>
            </nav>
        </div>
    </div>
</div>

<!-- Profile Content -->
<div class="profile-content">
    <div class="container">
        <div class="row g-4">

            <!-- Left Column: Avatar & Quick Actions -->
            <div class="col-lg-4">
                <div class="profile-card">
                    <div class="profile-avatar-section">
                        {% if app.user.photo %}
                            <img src="{{ asset('uploads/photos/' ~ app.user.photo) }}" alt="Photo de profil" class="profile-avatar">
                        {% else %}
                            <div class="profile-avatar-placeholder">
                                <span>{{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}</span>
                            </div>
                        {% endif %}

                        <h4 class="profile-name">{{ app.user.prenom }} {{ app.user.nom }}</h4>
                        <p style="color: #525368; font-size: 14px; margin-bottom: 5px;">{{ app.user.email }}</p>

                        {% if 'ROLE_ADMIN' in app.user.roles %}
                            <span class="profile-role role-admin"><i class="fas fa-crown me-1"></i> Administrateur</span>
                        {% else %}
                            <span class="profile-role role-user"><i class="fas fa-user me-1"></i> Agriculteur</span>
                        {% endif %}

                        <div class="profile-stats">
                            <div class="profile-stat">
                                <div class="stat-value">
                                    {% if app.user.createdAt %}
                                        {{ app.user.createdAt|date('Y') == "now"|date('Y') ? '< 1' : (("now"|date('Y')) - (app.user.createdAt|date('Y'))) }}
                                    {% else %}
                                        -
                                    {% endif %}
                                </div>
                                <div class="stat-label">An(s) membre</div>
                            </div>
                        </div>
                    </div>

                    <div class="member-since">
                        <i class="fas fa-clock me-1"></i>
                        Membre depuis
                        {% if app.user.createdAt %}
                            {{ app.user.createdAt|date('d/m/Y') }}
                        {% else %}
                            -
                        {% endif %}
                    </div>
                </div>

                <!-- Quick Actions -->
                <div class="profile-card mt-4" style="padding: 25px;">
                    <h5 class="section-title"><i class="fas fa-bolt me-2" style="color: #348E38;"></i>Actions rapides</h5>
                    <div class="quick-actions">
                        <a href="{{ path('app_dashboard') }}" class="action-btn">
                            <i class="fas fa-tachometer-alt"></i>
                            <span>Tableau de bord</span>
                        </a>
                        <a href="{{ path('app_maintenance') }}" class="action-btn">
                            <i class="fas fa-wrench"></i>
                            <span>Maintenance</span>
                        </a>
                        <a href="{{ path('app_suivi_animal') }}" class="action-btn">
                            <i class="fas fa-paw"></i>
                            <span>Suivi animal</span>
                        </a>
                        <a href="{{ path('app_ventes_depenses') }}" class="action-btn">
                            <i class="fas fa-chart-line"></i>
                            <span>Ventes & depenses</span>
                        </a>
                        <a href="{{ path('app_logout') }}" class="action-btn logout-btn">
                            <i class="fas fa-sign-out-alt"></i>
                            <span>Deconnexion</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Right Column: User Info -->
            <div class="col-lg-8">
                <div class="profile-card">
                    <div class="profile-info-section">
                        <h5 class="section-title"><i class="fas fa-id-card me-2" style="color: #348E38;"></i>Informations personnelles</h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Nom</div>
                                            <div class="info-value">{{ app.user.nom }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-user"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Prenom</div>
                                            <div class="info-value">{{ app.user.prenom }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="info-card">
                            <div class="d-flex align-items-center">
                                <div class="info-icon me-3">
                                    <i class="fas fa-envelope"></i>
                                </div>
                                <div>
                                    <div class="info-label">Adresse email</div>
                                    <div class="info-value">{{ app.user.email }}</div>
                                </div>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-phone-alt"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Telephone</div>
                                            <div class="info-value">{{ app.user.telephone ?? 'Non renseigne' }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-map-marker-alt"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Adresse</div>
                                            <div class="info-value">{{ app.user.adresse ?? 'Non renseignee' }}</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Account Details Card -->
                <div class="profile-card mt-4">
                    <div class="profile-info-section">
                        <h5 class="section-title"><i class="fas fa-shield-alt me-2" style="color: #348E38;"></i>Details du compte</h5>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-user-tag"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Role</div>
                                            <div class="info-value">
                                                {% if 'ROLE_ADMIN' in app.user.roles %}
                                                    Administrateur
                                                {% else %}
                                                    Utilisateur
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="info-card">
                                    <div class="d-flex align-items-center">
                                        <div class="info-icon me-3">
                                            <i class="fas fa-calendar-check"></i>
                                        </div>
                                        <div>
                                            <div class="info-label">Date d'inscription</div>
                                            <div class="info-value">
                                                {% if app.user.createdAt %}
                                                    {{ app.user.createdAt|date('d/m/Y') }}
                                                {% else %}
                                                    -
                                                {% endif %}
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        {% if app.user.updatedAt %}
                        <div class="info-card">
                            <div class="d-flex align-items-center">
                                <div class="info-icon me-3">
                                    <i class="fas fa-sync-alt"></i>
                                </div>
                                <div>
                                    <div class="info-label">Derniere mise a jour</div>
                                    <div class="info-value">{{ app.user.updatedAt|date('d/m/Y a H:i') }}</div>
                                </div>
                            </div>
                        </div>
                        {% endif %}
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

