<!-- Topbar -->
<div class="container-fluid bg-dark text-light px-0 py-2">
    <div class="row gx-0 d-none d-lg-flex">
        <div class="col-lg-7 px-5 text-start">
            <div class="h-100 d-inline-flex align-items-center me-4">
                <span class="fa fa-phone-alt me-2"></span>
                <span>+216 21 987 654</span>
            </div>
            <div class="h-100 d-inline-flex align-items-center">
                <span class="far fa-envelope me-2"></span>
                <span>info.agricore@gmail.com</span>
            </div>
        </div>
    </div>
</div>

<!-- Navbar -->
<nav class="navbar navbar-expand-lg bg-white navbar-light sticky-top p-0">
    <a href="{{ path('app_home') }}" class="navbar-brand d-flex align-items-center px-4 px-lg-5">
        <img src="{{ asset('img/logo.png') }}" alt="Logo" style="height:50px;">
    </a>

    <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navbarCollapse">
        <div class="navbar-nav ms-auto p-4 p-lg-0">
            <a href="{{ path('app_home') }}" class="nav-item nav-link">Accueil</a>
            <a href="{{ path('app_about') }}" class="nav-item nav-link">A propos</a>
            <a href="{{ path('app_contact') }}" class="nav-item nav-link">Contact</a>

            <div class="nav-item dropdown">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Services</a>
                <div class="dropdown-menu bg-light m-0">
                    <a href="{{ path('app_maintenance') }}" class="dropdown-item">Maintenance</a>
                    <a href="{{ path('app_evenements') }}" class="dropdown-item">Evenements</a>
                    <a href="{{ path('app_suivi_animal') }}" class="dropdown-item">Suivi animal</a>
                    <a href="{{ path('app_achat_equipement') }}" class="dropdown-item">Achat d'equipement</a>
                    <a href="{{ path('app_ventes_depenses') }}" class="dropdown-item">Ventes & depenses</a>
                </div>
            </div>
        </div>
    </div>
</nav>

<!-- Auth Section -->
<div class="auth-page">
    <div class="auth-section">
        <div class="container">
            <div class="auth-card mx-auto">
                <div class="row g-0">

                    <!-- Sidebar -->
                    <div class="col-lg-5 auth-sidebar d-none d-lg-flex">
                        <img src="{{ asset('img/logo.png') }}" alt="Agricore">
                        <h2>Bon retour !</h2>
                        <p>Connectez-vous pour acceder a votre espace personnel et gerer votre exploitation agricole en toute simplicite.</p>
                        <div class="mt-4">
                            <i class="fas fa-seedling fa-2x mb-3" style="opacity: 0.6;"></i>
                        </div>
                    </div>

                    <!-- Form -->
                    <div class="col-lg-7">
                        <div class="auth-form-section">
                            <h3>Connexion</h3>
                            <p class="subtitle">Entrez vos identifiants pour continuer</p>

                            {% if error %}
                                <div class="alert alert-danger d-flex align-items-center" role="alert">
                                    <i class="fas fa-exclamation-circle me-2"></i>
                                    {{ error.messageKey|trans(error.messageData, 'security') }}
                                </div>
                            {% endif %}

                            {% for message in app.flashes('success') %}
                                <div class="alert alert-success d-flex align-items-center" role="alert">
                                    <i class="fas fa-check-circle me-2"></i>
                                    {{ message }}
                                </div>
                            {% endfor %}

                            <form method="post">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                                <div class="mb-3">
                                    <label for="email" class="form-label fw-medium">Email</label>
                                    <div class="input-icon-wrapper">
                                        <i class="fas fa-envelope"></i>
                                        <input type="email"
                                               class="form-control"
                                               id="email"
                                               name="email"
                                               value="{{ last_username }}"
                                               placeholder="votre@email.com"
                                               required
                                               autofocus>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label for="password" class="form-label fw-medium">Mot de passe</label>
                                    <div class="input-icon-wrapper">
                                        <i class="fas fa-lock"></i>
                                        <input type="password"
                                               class="form-control"
                                               id="password"
                                               name="password"
                                               placeholder="Votre mot de passe"
                                               required>
                                    </div>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <div class="form-check">
                                        <input type="checkbox"
                                               class="form-check-input"
                                               id="remember_me"
                                               name="_remember_me">
                                        <label class="form-check-label" for="remember_me">
                                            Se souvenir de moi
                                        </label>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-auth w-100">
                                    <i class="fas fa-sign-in-alt me-2"></i>Se connecter
                                </button>
                            </form>

                            <div class="divider">
                                <span>ou</span>
                            </div>

                            <div class="text-center">
                                <p class="mb-0">
                                    Pas encore de compte ?
                                    <a href="{{ path('app_register') }}" class="auth-link">Inscrivez-vous</a>
                                </p>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Footer -->
    <div class="container-fluid bg-dark text-light footer py-5">
        <div class="container py-5">
            <div class="row g-5">
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Contact</h4>
                    <p class="mb-2"><i class="fa fa-map-marker-alt me-3"></i>Tunisie, Ariana</p>
                    <p class="mb-2"><i class="fa fa-phone-alt me-3"></i>+216 21 987 654</p>
                    <p class="mb-2"><i class="fa fa-envelope me-3"></i>contact@agricore.com</p>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Services</h4>
                    <ul class="list-unstyled">
                        <li><a class="btn btn-link text-white ps-0" href="{{ path('app_maintenance') }}">Maintenance</a></li>
                        <li><a class="btn btn-link text-white ps-0" href="{{ path('app_evenements') }}">Evenements</a></li>
                        <li><a class="btn btn-link text-white ps-0" href="{{ path('app_suivi_animal') }}">Suivi animal</a></li>
                        <li><a class="btn btn-link text-white ps-0" href="{{ path('app_achat_equipement') }}">Achat d'equipement</a></li>
                        <li><a class="btn btn-link text-white ps-0" href="{{ path('app_ventes_depenses') }}">Suivi des ventes & depenses</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Liens rapides</h4>
                    <a class="btn btn-link" href="{{ path('app_home') }}">Accueil</a>
                    <a class="btn btn-link" href="{{ path('app_about') }}">A propos</a>
                    <a class="btn btn-link" href="{{ path('app_services') }}">Services</a>
                    <a class="btn btn-link" href="{{ path('app_contact') }}">Contact</a>
                </div>
                <div class="col-lg-3 col-md-6">
                    <h4 class="text-white mb-4">Inscrivez-vous</h4>
                    <p>Rejoignez Agricore des maintenant pour gerer efficacement votre ferme et vos equipements.</p>
                    <a href="{{ path('app_register') }}" class="btn btn-primary py-2 px-4 mt-2">Sign Up</a>
                </div>
            </div>
        </div>
    </div>

    <div class="container-fluid copyright py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a class="border-bottom" href="#">Agricore</a>, Tous droits reserves.
                </div>
            </div>
        </div>
    </div>
</div>

<!-- JavaScript Libraries -->
