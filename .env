###> groq-ai ###
# Groq AI (free tier) — powers the floating chatbot on /profil
# Sign up & create a key at: https://console.groq.com/keys
# Model used: llama-3.3-70b-versatile (OpenAI-compatible API)
GROQ_API_KEY=YOUR_GROQ_API_KEY
###< groq-ai ###

###> knpuniversity/oauth2-client-bundle ###
# Google OAuth — get keys at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://127.0.0.1:8000/oauth/google/check
OAUTH_GOOGLE_ID=YOUR_GOOGLE_CLIENT_ID
OAUTH_GOOGLE_SECRET=YOUR_GOOGLE_CLIENT_SECRET


# Facebook OAuth — get keys at https://developers.facebook.com/apps
# Valid OAuth Redirect URI: http://127.0.0.1:8000/oauth/facebook/check
OAUTH_FACEBOOK_ID=YOUR_FACEBOOK_APP_ID
OAUTH_FACEBOOK_SECRET=YOUR_FACEBOOK_APP_SECRET

# GitHub OAuth — get keys at https://github.com/settings/developers
# Authorization callback URL: http://127.0.0.1:8000/oauth/github/check
OAUTH_GITHUB_ID=YOUR_GITHUB_CLIENT_ID
OAUTH_GITHUB_SECRET=YOUR_GITHUB_CLIENT_SECRET
###< knpuniversity/oauth2-client-bundle ###
